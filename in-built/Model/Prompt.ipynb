 z-10 cursor-zoom-in transition-opacity duration-500 ${isEditing ? \u0027opacity-30\u0027 : \u0027opacity-100\u0027}`}\\n        /\u003e\\n\\n        {isEditing \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"absolute inset-0 z-20 flex flex-col items-center justify-center bg-slate-900/40 backdrop-blur-sm\\\"\u003e\\n             \u003cdiv className\u003d\\\"p-6 bg-slate-900 rounded-3xl border border-cyan-500/50 flex flex-col items-center gap-4 shadow-2xl\\\"\u003e\\n                \u003cRefreshCcw className\u003d\\\"w-10 h-10 text-cyan-500 animate-spin\\\" /\u003e\\n                \u003cp className\u003d\\\"text-xs font-bold text-white uppercase tracking-widest\\\"\u003eGenerative Matrix Active...\u003c/p\u003e\\n             \u003c/div\u003e\\n          \u003c/div\u003e\\n        )}\\n        \\n        {/* Overlay Actions */}\\n        \u003cdiv className\u003d\\\"absolute top-6 right-6 flex flex-col gap-2 opacity-0 group-hover:opacity-100 transition-opacity z-30\\\"\u003e\\n          \u003cbutton \\n            onClick\u003d{() \u003d\u003e setIsFullscreen(true)}\\n            className\u003d\\\"bg-black/60 backdrop-blur-md text-white p-3 rounded-xl shadow-lg hover:bg-cyan-600 transition-colors border border-white/10\\\"\\n            title\u003d\\\"Fullscreen View\\\"\\n          \u003e\\n            \u003cMaximize2 className\u003d\\\"w-5 h-5\\\" /\u003e\\n          \u003c/button\u003e\\n          \u003ca \\n            href\u003d{image.data} \\n            download\u003d{`vision-visual-${image.id}.png`}\\n            className\u003d\\\"bg-black/60 backdrop-blur-md text-white p-3 rounded-xl shadow-lg hover:bg-cyan-600 transition-colors border border-white/10\\\"\\n            title\u003d\\\"Download Image\\\"\\n          \u003e\\n            \u003cDownload className\u003d\\\"w-5 h-5\\\" /\u003e\\n          \u003c/a\u003e\\n        \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      {/* Control Module */}\\n      \u003cdiv className\u003d\\\"w-full max