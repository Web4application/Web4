in this browser.\\\");\\n    \\n    const rec \u003d new Recognition();\\n    rec.lang \u003d \u0027en-US\u0027;\\n    rec.onstart \u003d () \u003d\u003e setIsListening(true);\\n    rec.onresult \u003d (e: any) \u003d\u003e {\\n      const transcript \u003d e.results[0][0].transcript;\\n      setTopicInput(transcript);\\n      onTopicChange(transcript);\\n    };\\n    rec.onend \u003d () \u003d\u003e setIsListening(false);\\n    rec.start();\\n  };\\n\\n  const allTopicsDone \u003d topics.every(t \u003d\u003e t.isCompleted);\\n\\n  return (\\n    \u003cdiv className\u003d\\\"flex flex-col h-full bg-white dark:bg-slate-950 border-r border-slate-200 dark:border-white/10\\\"\u003e\\n      \u003cdiv className\u003d\\\"p-8 border-b border-slate-200 dark:border-white/10\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-3 mb-2\\\"\u003e\\n            \u003cBookOpen className\u003d\\\"w-5 h-5 text-cyan-600\\\" /\u003e\\n            \u003ch3 className\u003d\\\"text-xs font-bold text-slate-400 uppercase tracking-[0.3em]\\\"\u003eUniversity Navigator\u003c/h3\u003e\\n        \u003c/div\u003e\\n        \u003cp className\u003d\\\"text-[10px] text-slate-500 font-medium\\\"\u003eManage your academic journey.\u003c/p\u003e\\n      \u003c/div\u003e\\n      \\n      \u003cdiv className\u003d\\\"flex-1 overflow-y-auto p-6 space-y-8\\\"\u003e\\n        {!student ? (\\n          \u003cform onSubmit\u003d{handleEnrollSubmit} className\u003d\\\"space-y-6 animate-in fade-in slide-in-from-left-4\\\"\u003e\\n             \u003cdiv className\u003d\\\"p-5 bg-cyan-50 dark:bg-cyan-950/20 rounded-[2rem] border border-cyan-100 dark:border-cyan-800/50 shadow-inner\\\"\u003e\\n                \u003cdiv className\u003d\\\"flex items-center gap-2 mb-4\\\"\u003e\\n                  \u003cUserPlus className\u003d\\\"w-4 h-4 text-cyan-600\\\" /\u003e\\n                  \u003cp className\u003d\\\"text-[10px] font-bold text-cyan-600 uppercase tracking-widest\\\"\u003eAdmissions Office\u003c/p\u003e\\n                \u003c/div\u003e\\n                \\n                \u003cdiv className\u003d\\\"space-y-4\\\"\u003e\\n                  \u003cdiv\u003e\\n                    \u003clabel className\u003d\\\"block text-[9px] font-bold text-slate-400 uppercase mb-1 ml-1\\\"\u003eFull Student Name\u003c/label\u003e\\n                    \u003cinput \\n                      type\u003d\\\"text\\\" \\n                      placeholder\u003d\\\"e.g. Marie Curie\\\" \\n                      value\u003d{enrollName}\\n                      onChange\u003d{e \u003d\u003e setEnrollName(e.target.value)}\\n                      className\u003d\\\"w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-sm focus:ring-2 ring-cyan-500 outline-none transition-all\\\"\\n                    /\u003e\\n                  \u003c/div\u003e\\n                  \\n                  \u003cdiv\u003e\\n                    \u003clabel className\u003d\\\"block text-[9px] font-bold text-slate-400 uppercase mb-1 ml-1\\\"\u003ePrimary Field of Study\u003c/label\u003e\\n                    \u003cselect \\n                      value\u003d{enrollMajor}\\n                      onChange\u003d{e \u003d\u003e setEnrollMajor(e.target.value as SubjectArea)}\\n                      className\u003d\\\"w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-sm focus:ring-2 ring-cyan-500 outline-none transition-all\\\"\\n                    \u003e\\n                      \u003coption value\u003d\\\"STEM\\\"\u003eScience \u0026 Technology\u003c/option\u003e\\n                      \u003coption value\u003d\\\"Physics\\\"\u003ePhysical Sciences\u003c/option\u003e\\n                      \u003coption value\u003d\\\"Biology\\\"\u003eLife Sciences\u003c/option\u003e\\n                      \u003coption value\u003d\\\"Engineering\\\"\u003eApplied Engineering\u003c/option\u003e\\n                      \u003coption value\u003d\\\"History\\\"\u003eHumanities \u0026 History\u003c/option\u003e\\n                    \u003c/select\u003e\\n                  \u003c/div\u003e\\n\\n                  \u003cdiv\u003e\\n                    \u003cdiv className\u003d\\\"flex items-center justify-between mb-2 px-1\\\"\u003e\\n                      \u003clabel className\u003d\\\"text-[9px] font-bold text-slate-400 uppercase\\\"\u003eWeekly Study Goal\u003c/label\u003e\\n                      \u003cspan className\u003d\\\"text-[10px] font-bold text-cyan-600\\\"\u003e{enrollSchedule} Hours\u003c/span\u003e\\n                    \u003c/div\u003e\\n                    \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n                       \u003cTimer className\u003d\\\"w-4 h-4 text-slate-300\\\" /\u003e\\n                       \u003cinput \\n                          type\u003d\\\"range\\\" min\u003d\\\"1\\\" max\u003d\\\"15\\\" \\n                          value\u003d{enrollSchedule} \\n                          onChange\u003d{e \u003d\u003e setEnrollSchedule(parseInt(e.target.value))}\\n                          className\u003d\\\"flex-1 h-1 bg-slate-200 dark:bg-slate-800 rounded-full appearance-none cursor-pointer accent-cyan-600\\\"\\n                       /\u003e\\n                    \u003c/div\u003e\\n                  \u003c/div\u003e\\n\\n                  \u003cbutton type\u003d\\\"submit\\\" className\u003d\\\"w-full py-4 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-2xl font-bold text-xs flex items-center justify-center gap-2 hover:scale-[1.02] active:scale-95 transition-all shadow-xl\\\"\u003e\\n                     CONFIRM ENROLLMENT\\n                  \u003c/button\u003e\\n                \u003c/div\u003e\\n             \u003c/div\u003e\\n          \u003c/form\u003e\\n        ) : (\\n          \u003c\u003e\\n            {/* Student ID Card */}\\n            \u003cdiv className\u003d\\\"p-6 bg-slate-900 text-white rounded-[2rem] shadow-2xl border border-white/10 relative overflow-hidden group\\\"\u003e\\n               \u003cdiv className\u003d\\\"absolute top-0 right-0 w-32 h-32 bg-cyan-500/20 rounded-full -translate-y-16 translate-x-16 blur-3xl group-hover:scale-110 transition-transform duration-1000\\\"\u003e\u003c/div\u003e\\n               \u003cdiv className\u003d\\\"flex items-center gap-4 mb-4 relative z-10\\\"\u003e\\n                  \u003cdiv className\u003d\\\"w-12 h-12 bg-cyan-600 rounded-2xl flex items-center justify-center font-bold text-xl shadow-lg border border-white/20\\\"\u003e\\n                     {student.name.charAt(0)}\\n                  \u003c/div\u003e\\n                  \u003cdiv\u003e\\n                     \u003cp className\u003d\\\"text-[9px] font-bold text-cyan-400 uppercase tracking-[0.2em]\\\"\u003e{student.level} LEVEL\u003c/p\u003e\\n                     \u003ch4 className\u003d\\\"font-display font-bold text-base leading-tight\\\"\u003e{student.name}\u003c/h4\u003e\\n                  \u003c/div\u003e\\n               \u003c/div\u003e\\n               \u003cdiv className\u003d\\\"flex items-center justify-between text-[9px] uppercase tracking-widest font-medium opacity-50 relative z-10\\\"\u003e\\n                  \u003cspan\u003eMAJOR: {student.major}\u003c/span\u003e\\n                  \u003cdiv className\u003d\\\"flex gap-1\\\"\u003e\\n                    \u003cCircle className\u003d\\\"w-1.5 h-1.5 fill-cyan-500 text-cyan-500\\\" /\u003e\\n                    \u003cCircle className\u003d\\\"w-1.5 h-1.5 fill-slate-700 text-slate-700\\\" /\u003e\\n                    \u003cCircle className\u003d\\\"w-1.5 h-1.5 fill-slate-700 text-slate-700\\\" /\u003e\\n                  \u003c/div\u003e\\n               \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            {/* Topic Search \u0026 Research */}\\n            \u003cdiv className\u003d\\\"space-y-3\\\"\u003e\\n               \u003cdiv className\u003d\\\"flex items-center justify-between px-1\\\"\u003e\\n                 \u003clabel className\u003d\\\"text-[9px] font-bold text-slate-400 uppercase tracking-widest\\\"\u003eActive Research Topic\u003c/label\u003e\\n                 \u003cArrowRight className\u003d\\\"w-3 h-3 text-slate-300\\\" /\u003e\\n               \u003c/div\u003e\\n               \u003cdiv className\u003d\\\"flex gap-2\\\"\u003e\\n                  \u003cdiv className\u003d\\\"relative flex-1\\\"\u003e\\n                     \u003cinput \\n                        type\u003d\\\"text\\\" \\n                        value\u003d{topicInput}\\n                        onChange\u003d{e \u003d\u003e { setTopicInput(e.target.value); onTopicChange(e.target.value); }}\\n                        placeholder\u003d\\\"What\u0027s on the syllabus today?\\\" \\n                        className\u003d\\\"w-full bg-slate-100 dark:bg-slate-900 border-none rounded-2xl px-5 py-3.5 text-xs pr-12 focus:ring-2 ring-cyan-500 transition-all shadow-inner\\\"\\n                     /\u003e\\n                     \u003cbutton \\n                        onClick\u003d{() \u003d\u003e { onTopicChange(topicInput); }}\\n                        className\u003d\\\"absolute right-3 top-1/2 -translate-y-1/2 text-cyan-600 p-1.5 hover:bg-white dark:hover:bg-slate-800 rounded-lg transition-colors\\\"\\n                     \u003e\\n                        \u003cSend className\u003d\\\"w-4 h-4\\\" /\u003e\\n                     \u003c/button\u003e\\n                  \u003c/div\u003e\\n                  \u003cbutton \\n                    onClick\u003d{startVoiceInput}\\n                    className\u003d{`p-3.5 rounded-2xl transition-all shadow-lg ${isListening ? \u0027bg-red-500 text-white animate-pulse\u0027 : \u0027bg-white dark:bg-slate-800 text-slate-400 border border-slate-200 dark:border-white/5\u0027}`}\\n                  \u003e\\n                    \u003cMic className\u003d\\\"w-5 h-5\\\" /\u003e\\n                  \u003c/button\u003e\\n               \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            {/* Curriculum Progress */}\\n            \u003cdiv className\u003d\\\"space-y-3\\\"\u003e\\n              \u003clabel className\u003d\\\"text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1\\\"\u003eAcademic Modules\u003c/label\u003e\\n              \u003cdiv className\u003d\\\"space-y-2\\\"\u003e\\n                {topics.map((topic) \u003d\u003e (\\n                  \u003cbutton\\n                    key\u003d{topic.id}\\n                    onClick\u003d{() \u003d\u003e onSelect(topic)}\\n                    className\u003d{`w-full text-left p-4 rounded-2xl transition-all border flex items-center justify-between gap-3 ${\\n                      currentId \u003d\u003d\u003d topic.id \\n                      ? \u0027bg-cyan-600/5 border-cyan-500/40 shadow-sm\u0027 \\n                      : \u0027bg-transparent border-transparent hover:bg-slate-50 dark:hover:bg-slate-900\u0027\\n                    }`}\\n                  \u003e\\n                    \u003ch4 className\u003d{`text-xs font-bold leading-tight ${currentId \u003d\u003d\u003d topic.id ? \u0027text-cyan-700 dark:text-cyan-300\u0027 : \u0027text-slate-600 dark:text-slate-400\u0027}`}\u003e\\n                      {topic.title}\\n                    \u003c/h4\u003e\\n                    {topic.isCompleted ? (\\n                      \u003cdiv className\u003d\\\"bg-emerald-500/10 p-1.5 rounded-full\\\"\u003e\\n                        \u003cCheckCircle className\u003d\\\"w-3 h-3 text-emerald-500\\\" /\u003e\\n                      \u003c/div\u003e\\n                    ) : (\\n                      \u003cCircle className\u003d\\\"w-3 h-3 opacity-20\\\" /\u003e\\n                    )}\\n                  \u003c/button\u003e\\n                ))}\\n              \u003c/div\u003e\\n            \u003c/div\u003e\\n          \u003c/\u003e\\n        )}\\n      \u003c/div\u003e\\n\\n      \u003cdiv className\u003d\\\"p-8 border-t border-slate-200 dark:border-white/10 space-y-5 bg-slate-50/50 dark:bg-slate-900/10\\\"\u003e\\n        {student \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"flex gap-3\\\"\u003e\\n             \u003cbutton \\n                onClick\u003d{() \u003d\u003e toggleLecture(false)}\\n                className\u003d{`flex-1 py-4 rounded-2xl font-bold text-xs flex items-center justify-center gap-3 shadow-2xl transition-all ${\\n                    isLecturing \u0026\u0026 !isExamMode\\n                    ? \u0027bg-red-500 text-white shadow-red-500/20\u0027 \\n                    : \u0027bg-cyan-600 text-white hover:bg-cyan-500 shadow-cyan-600/20\u0027\\n                }`}\\n            \u003e\\n                {isLecturing \u0026\u0026 !isExamMode ? \u003cSquare className\u003d\\\"w-3.5 h-3.5 fill-current\\\" /\u003e : \u003cPlay className\u003d\\\"w-3.5 h-3.5 fill-current\\\" /\u003e}\\n                {isLecturing \u0026\u0026 !isExamMode ? \u0027END SESSION\u0027 : \u0027START STUDY\u0027}\\n            \u003c/button\u003e\\n            \\n            \u003cbutton \\n                onClick\u003d{onDone}\\n                disabled\u003d{!isLecturing}\\n                className\u003d\\\"px-5 py-4 rounded-2xl border-2 border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 font-bold text-xs flex items-center justify-center hover:bg-white dark:hover:bg-slate-800 transition-all disabled:opacity-20\\\"\\n                title\u003d\\\"Mark Module Done\\\"\\n            \u003e\\n                \u003cAward className\u003d\\\"w-4 h-4\\\" /\u003e\\n            \u003c/button\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        {allTopicsDone \u0026\u0026 student \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"p-5 bg-emerald-500/5 border border-emerald-500/30 rounded-[2rem] animate-in zoom-in duration-500 space-y-4\\\"\u003e\\n             \u003cdiv className\u003d\\\"text-center\\\"\u003e\\n               \u003cp className\u003d\\\"text-[10px] text-emerald-600 dark:text-emerald-400 font-bold uppercase tracking-widest mb-1\\\"\u003eModule Exams Available\u003c/p\u003e\\n               \u003cp className\u003d\\\"text-[9px] text-slate-500\\\"\u003ePass the exam to advance your stage.\u003c/p\u003e\\n             \u003c/div\u003e\\n             \u003cbutton \\n                onClick\u003d{() \u003d\u003e isExamMode ? onPromote() : toggleLecture(true)}\\n                className\u003d\\\"w-full py-4 bg-emerald-500 text-white rounded-2xl font-bold text-xs flex items-center justify-center gap-3 hover:bg-emerald-400 transition-all shadow-lg shadow-emerald-500/20\\\"\\n             \u003e\\n                \u003cGraduationCap className\u003d\\\"w-5 h-5\\\" /\u003e\\n                {isExamMode ? \u0027SUBMIT FOR GRADING\u0027 : \u0027CHALLENGE EXAM\u0027}\\n             \u003c/button\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        \u003cdiv className\u003d\\\"flex items-center justify-center gap-2 opacity-30 group cursor-default\\\"\u003e\\n            \u003cUserCircle className\u003d\\\"w-3 h-3\\\" /\u003e\\n            \u003cp className\u003d\\\"text-[8px] font-bold uppercase tracking-[0.4em]\\\"\u003eOfficial Academic Terminal\u003c/p\u003e\\n        \u003c/div\u003e\\n      \u003c/div\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default Syllabus;\\n\"}]},{\"path\":\"services/geminiService.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Updated AI instructions to be warmer and more welcoming for speech-to-speech interaction, emphasizing the friendly student-professor relationship.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport { GoogleGenAI, FunctionDeclaration, Modality, Type } from \\\"@google/genai\\\";\\nimport { ComplexityLevel, VisualStyle, ResearchResult, SearchResultItem, Language, SubjectArea } from \\\"../types\\\";\\n\\nconst getAi \u003d () \u003d\u003e {\\n  return new GoogleGenAI({ apiKey: process.env.API_KEY });\\n};\\n\\nconst TEXT_MODEL \u003d \u0027gemini-3-pro-preview\u0027;\\nconst IMAGE_MODEL \u003d \u0027gemini-3-pro-image-preview\u0027;\\n\\n/**\\n * Establishes a real-time speech-to-speech lecture or exam session.\\n */\\nexport const connectLecturer \u003d (\\n  callbacks: any,\\n  subject: string,\\n  topic: string\\n) \u003d\u003e {\\n  const ai \u003d getAi();\\n  const isExam \u003d topic.includes(\\\"FINAL EXAM\\\");\\n  \\n  const renderVisualTool: FunctionDeclaration \u003d {\\n    name: \u0027render_visual\u0027,\\n    parameters: {\\n      type: Type.OBJECT,\\n      description: \u0027Generate and render a detailed educational visual or infographic to clarify complex concepts.\u0027,\\n      properties: {\\n        description: {\\n          type: Type.STRING,\\n          description: \u0027A detailed, vivid description of the visual to be rendered.\u0027\\n        }\\n      },\\n      required: [\u0027description\u0027]\\n    }\\n  };\\n\\n  const instruction \u003d isExam \\n    ? `You are Professor Alpha, a kind but rigorous academic examiner. The student is taking their final exam for \\\"${topic}\\\".\\n       1. Start by warmly welcoming them to their examination. Say something like \\\"I\u0027m so proud of the progress you\u0027ve made to get here.\\\"\\n       2. Ask 3-5 challenging questions verbally about the core concepts.\\n       3. Listen carefully to the student\u0027s spoken responses.\\n       4. Provide immediate, constructive verbal feedback. Be encouraging!\\n       5. If they answer correctly, use \u0027render_visual\u0027 to show a \u0027Certificate of Achievement\u0027 or an advanced diagram.\\n       6. Your goal is to see them succeed and promote to the next level.`\\n    : `You are Professor Alpha, a world-class lecturer and friendly mentor in ${subject}. \\n       Explain \\\"${topic}\\\" deeply using your voice in a warm, conversational, and engaging way.\\n       \\n       CORE BEHAVIOR:\\n       - Be extremely friendly and welcoming. Treat the student like a bright scholar.\\n       - Use \u0027render_visual\u0027 frequently to provide helpful infographics that clarify your verbal points.\\n       - If the student interrupts with a question, pause immediately and address them with a smile in your voice.\\n       - \\\"Speech-to-Speech\\\": Use natural intonation. Avoid sounding like a robot.\\n       - Act as a supportive friend who happens to be a genius in ${subject}.`;\\n\\n  return ai.live.connect({\\n    model: \u0027gemini-2.5-flash-native-audio-preview-12-2025\u0027,\\n    callbacks,\\n    config: {\\n      responseModalities: [Modality.AUDIO],\\n      systemInstruction: instruction,\\n      tools: [{ functionDeclarations: [renderVisualTool] }],\\n      speechConfig: {\\n        voiceConfig: { prebuiltVoiceConfig: { voiceName: \u0027Charon\u0027 } }\\n      }\\n    }\\n  });\\n};\\n\\nexport const researchTopicForPrompt \u003d async (\\n  topic: string, \\n  level: ComplexityLevel, \\n  style: VisualStyle,\\n  language: Language,\\n  subject: SubjectArea \u003d \u0027General\u0027\\n): Promise\u003cResearchResult\u003e \u003d\u003e {\\n  const ai \u003d getAi();\\n  const response \u003d await ai.models.generateContent({\\n    model: TEXT_MODEL,\\n    contents: `Research the topic \\\"${topic}\\\" for a ${level} level lecture in ${subject}. Provide 5 facts and an image prompt for a ${style} infographic.`,\\n    config: { tools: [{ googleSearch: {} }] },\\n  });\\n\\n  const text \u003d response.text || \\\"\\\";\\n  const facts \u003d text.split(\u0027\\\\n\u0027).filter(l \u003d\u003e l.includes(\u0027-\u0027)).slice(0, 5);\\n  const imagePrompt \u003d `Educational visual about ${topic}, ${style} style, ${level} complexity.`;\\n\\n  const searchResults: SearchResultItem[] \u003d [];\\n  response.candidates?.[0]?.groundingMetadata?.groundingChunks?.forEach(chunk \u003d\u003e {\\n    if (chunk.web?.uri \u0026\u0026 chunk.web?.title) {\\n      searchResults.push({ title: chunk.web.title, url: chunk.web.uri });\\n    }\\n  });\\n\\n  return { imagePrompt, facts, searchResults };\\n};\\n\\nexport const generateInfographicImage \u003d async (prompt: string): Promise\u003cstring\u003e \u003d\u003e {\\n  const response \u003d await getAi().models.generateContent({\\n    model: IMAGE_MODEL,\\n    contents: { parts: [{ text: prompt }] },\\n    config: { imageConfig: { aspectRatio: \\\"16:9\\\", imageSize: \\\"1K\\\" } }\\n  });\\n\\n  const parts \u003d response.candidates?.[0]?.content?.parts || [];\\n  for (const part of parts) {\\n    if (part.inlineData?.data) {\\n      return `data:image/png;base64,${part.inlineData.data}`;\\n    }\\n  }\\n  throw new Error(\\\"Visual generation failed.\\\");\\n};\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767888294,\"nanos\":174000000},\"doneTimestamp\":{\"seconds\":1767888317,\"nanos\":422000000}},{\"id\":212,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"Add sign up or login add payment plans for students enrolling into  indigenous universities \\nOnce payed unlock different opportunities add more areas of study ,\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888432,\"nanos\":167000000}},{\"id\":213,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Envisioning App Enhancements**\\n\\nI\u0027m currently focused on the \\\"InfoGenius Academy\\\" app, specifically the user authentication. I\u0027m mocking a sign-up and login system for now. I\u0027ve also been thinking about the tiered subscription plans – Free, Scholar, Visionary – and how they\u0027ll unlock specific content and features. It\u0027s all about providing a smooth, value-driven experience.\\n\\n\\n**Expanding Study Areas**\\n\\nI\u0027ve been concentrating on expanding the areas of study within the InfoGenius Academy app. I\u0027m aiming to add a wider variety of majors to cater to diverse interests. Currently, I am designing the aesthetic of the app, ensuring a cohesive academic yet futuristic theme. I am now working on the enrollment flow and authentication specification to ensure ease of navigation through this aspect of the app.\\n\\n\\n**Developing Subscription Features**\\n\\nI\u0027m now integrating the expanded areas of study, adding Literature, Geography, Music Theory, and Economics. I\u0027ve updated `types.ts` for SubscriptionTier and `StudentProfile` to track the subscription. I\u0027m also modifying `Syllabus.tsx` with upgrade sections and padlocks and adjusting `App.tsx` for enrollment transitions. Gemini will also acknowledge the \\\"Scholar\\\" status. Furthermore, I am implementing UI updates, including color adjustments for the Grandmaster tier and interactive padlocks. Also, there will be visual cues for successful payment.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888432,\"nanos\":167000000},\"doneTimestamp\":{\"seconds\":1767888458,\"nanos\":727000000}},{\"id\":214,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"types.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Updated StudentProfile to include SubscriptionTier and expanded SubjectArea. Added SubscriptionTier type.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nexport type AspectRatio \u003d \u002716:9\u0027 | \u00279:16\u0027 | \u00271:1\u0027;\\n\\nexport type ComplexityLevel \u003d \u0027Elementary\u0027 | \u0027High School\u0027 | \u0027College\u0027 | \u0027Expert\u0027;\\n\\nexport type SubscriptionTier \u003d \u0027Standard\u0027 | \u0027Scholar\u0027 | \u0027Grandmaster\u0027;\\n\\nexport type SubjectArea \u003d \\n  | \u0027STEM\u0027 \\n  | \u0027History\u0027 \\n  | \u0027Biology\u0027 \\n  | \u0027Physics\u0027 \\n  | \u0027Geography\u0027 \\n  | \u0027Literature\u0027 \\n  | \u0027Engineering\u0027 \\n  | \u0027Economics\u0027\\n  | \u0027Music Theory\u0027\\n  | \u0027General\u0027;\\n\\nexport type VisualStyle \u003d \u0027Default\u0027 | \u0027Minimalist\u0027 | \u0027Realistic\u0027 | \u0027Cartoon\u0027 | \u0027Vintage\u0027 | \u0027Futuristic\u0027 | \u00273D Render\u0027 | \u0027Sketch\u0027;\\n\\nexport type Language \u003d \u0027English\u0027 | \u0027Spanish\u0027 | \u0027French\u0027 | \u0027German\u0027 | \u0027Mandarin\u0027 | \u0027Japanese\u0027 | \u0027Hindi\u0027 | \u0027Arabic\u0027 | \u0027Portuguese\u0027 | \u0027Russian\u0027;\\n\\nexport interface StudentProfile {\\n  name: string;\\n  major: SubjectArea;\\n  level: ComplexityLevel;\\n  tier: SubscriptionTier;\\n  enrolledDate: number;\\n  studyHoursGoal: number;\\n  currentStudyHours: number;\\n}\\n\\n/**\\n * Interface representing a course topic in the syllabus.\\n */\\nexport interface CourseTopic {\\n  id: string;\\n  title: string;\\n  duration: string;\\n  isCompleted: boolean;\\n  subject: SubjectArea;\\n  isLocked?: boolean;\\n}\\n\\nexport interface GeneratedImage {\\n  id: string;\\n  data: string; // Base64 data URL\\n  prompt: string;\\n  timestamp: number;\\n  level?: ComplexityLevel;\\n  style?: VisualStyle;\\n  language?: Language;\\n  subject?: SubjectArea;\\n}\\n\\nexport interface SearchResultItem {\\n  title: string;\\n  url: string;\\n}\\n\\nexport interface ResearchResult {\\n  imagePrompt: string;\\n  facts: string[];\\n  searchResults: SearchResultItem[];\\n}\\n\\ndeclare global {\\n  interface AIStudio {\\n    hasSelectedApiKey: () \u003d\u003e Promise\u003cboolean\u003e;\\n    openSelectKey: () \u003d\u003e Promise\u003cvoid\u003e;\\n  }\\n  interface Window {\\n    SpeechRecognition: any;\\n    webkitSpeechRecognition: any;\\n  }\\n}\\n\"}]},{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Implemented enrollment flow with subscription tiers. Added logic to handle locked topics based on tiers and localized student profile state.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SubjectArea, CourseTopic, StudentProfile, SubscriptionTier } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { Sun, Moon, Mic, Hand, Volume2, Menu, X, Award, CheckCircle2, Sparkles, ShieldCheck } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027The Laws of Motion\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n  const [isExamMode, setIsExamMode] \u003d useState(false);\\n  const [showPromotion, setShowPromotion] \u003d useState(false);\\n\\n  const [student, setStudent] \u003d useState\u003cStudentProfile | null\u003e(() \u003d\u003e {\\n    const saved \u003d localStorage.getItem(\u0027student_profile\u0027);\\n    return saved ? JSON.parse(saved) : null;\\n  });\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const studyTimerRef \u003d useRef\u003cnumber | null\u003e(null);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027The Laws of Motion\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027Physics\u0027 },\\n    { id: \u00272\u0027, title: \u0027Calculus in Engineering\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027, isLocked: true },\\n    { id: \u00273\u0027, title: \u0027Genetics and DNA Analysis\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Biology\u0027, isLocked: true },\\n    { id: \u00274\u0027, title: \u0027Global Economics 101\u0027, duration: \u00272.0 hrs\u0027, isCompleted: false, subject: \u0027Economics\u0027, isLocked: true },\\n    { id: \u00275\u0027, title: \u0027Music Theory Fundamentals\u0027, duration: \u00271.5 hrs\u0027, isCompleted: false, subject: \u0027Music Theory\u0027, isLocked: true },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (student) {\\n      localStorage.setItem(\u0027student_profile\u0027, JSON.stringify(student));\\n      // Update locks based on tier\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e {\\n        if (student.tier \u003d\u003d\u003d \u0027Grandmaster\u0027) return { ...t, isLocked: false };\\n        if (student.tier \u003d\u003d\u003d \u0027Scholar\u0027) {\\n          return (t.subject \u003d\u003d\u003d \u0027Economics\u0027 || t.subject \u003d\u003d\u003d \u0027Music Theory\u0027) ? { ...t, isLocked: true } : { ...t, isLocked: false };\\n        }\\n        return (t.subject \u003d\u003d\u003d \u0027Physics\u0027 || t.subject \u003d\u003d\u003d \u0027STEM\u0027) ? { ...t, isLocked: false } : { ...t, isLocked: true };\\n      }));\\n    }\\n  }, [student]);\\n\\n  // Track study hours while lecturing\\n  useEffect(() \u003d\u003e {\\n    if (isLecturing \u0026\u0026 !isExamMode) {\\n      studyTimerRef.current \u003d window.setInterval(() \u003d\u003e {\\n        setStudent(prev \u003d\u003e prev ? { ...prev, currentStudyHours: prev.currentStudyHours + (1/3600) } : null);\\n      }, 1000);\\n    } else {\\n      if (studyTimerRef.current) clearInterval(studyTimerRef.current);\\n    }\\n    return () \u003d\u003e { if (studyTimerRef.current) clearInterval(studyTimerRef.current); };\\n  }, [isLecturing, isExamMode]);\\n\\n  const toggleLecture \u003d async (exam: boolean \u003d false) \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      setIsExamMode(false);\\n      return;\\n    }\\n\\n    setIsExamMode(exam);\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) { console.error(e); }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(e),\\n        onclose: () \u003d\u003e { setIsLecturing(false); setIsExamMode(false); }\\n      }, student?.major || \u0027STEM\u0027, exam ? `FINAL EXAM FOR ${currentTopic}` : currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning \u0026\u0026 !exam) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false);\\n    } catch (e) {\\n      console.error(\\\"Session fail\\\", e);\\n    }\\n  };\\n\\n  const handleEnroll \u003d (name: string, major: SubjectArea, schedule: number, tier: SubscriptionTier) \u003d\u003e {\\n    setStudent({\\n      name,\\n      major,\\n      level: \u0027Elementary\u0027,\\n      tier: tier,\\n      enrolledDate: Date.now(),\\n      studyHoursGoal: schedule,\\n      currentStudyHours: 0\\n    });\\n    setComplexityLevel(\u0027Elementary\u0027);\\n  };\\n\\n  const markDone \u003d () \u003d\u003e {\\n    const active \u003d topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic);\\n    if (active) {\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d active.id ? { ...t, isCompleted: true } : t));\\n    }\\n  };\\n\\n  const promoteStudent \u003d () \u003d\u003e {\\n    const levels: ComplexityLevel[] \u003d [\u0027Elementary\u0027, \u0027High School\u0027, \u0027College\u0027, \u0027Expert\u0027];\\n    const currentIdx \u003d levels.indexOf(student?.level || \u0027Elementary\u0027);\\n    if (currentIdx \u003c levels.length - 1) {\\n      const nextLevel \u003d levels[currentIdx + 1];\\n      setStudent(prev \u003d\u003e prev ? { ...prev, level: nextLevel } : null);\\n      setComplexityLevel(nextLevel);\\n      setShowPromotion(true);\\n      setTimeout(() \u003d\u003e setShowPromotion(false), 5000);\\n      setIsExamMode(false);\\n      setIsLecturing(false);\\n      sessionRef.current?.close?.();\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e ({ ...t, isCompleted: false })));\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setComplexityLevel(level);\\n    setVisualStyle(style);\\n    if (currentSlide) {\\n      const data \u003d await generateInfographicImage(`Updated visual: ${currentSlide.prompt}. Complexity: ${level}, Style: ${style}`);\\n      setCurrentSlide({ ...currentSlide, data, level, style });\\n    }\\n  };\\n\\n  const handleUpdateTier \u003d (tier: SubscriptionTier) \u003d\u003e {\\n    setStudent(prev \u003d\u003e prev ? { ...prev, tier } : null);\\n    setIsSidebarOpen(true);\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans transition-colors overflow-hidden\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} studentName\u003d{student?.name} /\u003e}\\n      \\n      {/* Navigator Toggle */}\\n      \u003cbutton \\n        onClick\u003d{() \u003d\u003e setIsSidebarOpen(!isSidebarOpen)}\\n        className\u003d\\\"fixed top-6 left-6 z-[60] p-4 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-white/10 hover:scale-105 active:scale-95 transition-all text-cyan-600 dark:text-cyan-400\\\"\\n      \u003e\\n        {isSidebarOpen ? \u003cX className\u003d\\\"w-6 h-6\\\" /\u003e : \u003cMenu className\u003d\\\"w-6 h-6\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Theme toggle */}\\n      \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"fixed top-8 right-8 z-[60] p-2 rounded-full opacity-20 hover:opacity-100 transition-opacity\\\"\u003e\\n        {isDarkMode ? \u003cSun className\u003d\\\"w-4 h-4\\\" /\u003e : \u003cMoon className\u003d\\\"w-4 h-4\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Sidebar (Navigator) */}\\n      \u003cdiv className\u003d{`fixed inset-0 z-50 transition-opacity duration-500 ${isSidebarOpen ? \u0027opacity-100\u0027 : \u0027opacity-0 pointer-events-none\u0027}`}\u003e\\n          \u003cdiv className\u003d\\\"absolute inset-0 bg-slate-950/40 backdrop-blur-sm\\\" onClick\u003d{() \u003d\u003e setIsSidebarOpen(false)}\u003e\u003c/div\u003e\\n          \u003cdiv className\u003d{`absolute top-0 left-0 h-full w-80 bg-white dark:bg-slate-950 shadow-2xl transition-transform duration-500 transform ${isSidebarOpen ? \u0027translate-x-0\u0027 : \u0027-translate-x-full\u0027}`}\u003e\\n              \u003cSyllabus \\n                topics\u003d{topics} \\n                currentId\u003d{topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic)?.id || \u00271\u0027} \\n                onSelect\u003d{(t) \u003d\u003e { setCurrentTopic(t.title); setIsSidebarOpen(false); }} \\n                onDone\u003d{markDone}\\n                isLecturing\u003d{isLecturing}\\n                toggleLecture\u003d{toggleLecture}\\n                student\u003d{student}\\n                onEnroll\u003d{handleEnroll}\\n                onTopicChange\u003d{setCurrentTopic}\\n                onPromote\u003d{promoteStudent}\\n                isExamMode\u003d{isExamMode}\\n                onUpdateTier\u003d{handleUpdateTier}\\n              /\u003e\\n          \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      \u003cmain className\u003d\\\"flex-1 flex flex-col items-center justify-center p-8 relative\\\"\u003e\\n        {/* Promotion Celebration */}\\n        {showPromotion \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"absolute inset-0 z-[70] flex items-center justify-center bg-cyan-600/20 backdrop-blur-xl animate-in fade-in duration-1000\\\"\u003e\\n             \u003cdiv className\u003d\\\"bg-white dark:bg-slate-900 p-12 rounded-[3rem] shadow-2xl text-center space-y-4 scale-110 border border-cyan-500 relative\\\"\u003e\\n                \u003cdiv className\u003d\\\"absolute -top-12 left-1/2 -translate-x-1/2 bg-cyan-500 p-4 rounded-full shadow-lg\\\"\u003e\\n                  \u003cAward className\u003d\\\"w-12 h-12 text-white animate-bounce\\\" /\u003e\\n                \u003c/div\u003e\\n                \u003ch2 className\u003d\\\"text-4xl font-display font-bold\\\"\u003eAcademic Promotion!\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-500\\\"\u003eCongratulations! You have been elevated to \u003cb\u003e{student?.level}\u003c/b\u003e level.\u003c/p\u003e\\n                \u003cdiv className\u003d\\\"flex justify-center gap-2 text-emerald-500 items-center\\\"\u003e\\n                   \u003cCheckCircle2 className\u003d\\\"w-6 h-6\\\" /\u003e\\n                   \u003cspan className\u003d\\\"font-bold text-sm uppercase tracking-widest\\\"\u003eUniversity Credits Issued\u003c/span\u003e\\n                \u003c/div\u003e\\n                \u003cbutton onClick\u003d{() \u003d\u003e setShowPromotion(false)} className\u003d\\\"mt-6 px-6 py-2 bg-slate-100 dark:bg-slate-800 rounded-full text-xs font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors\\\"\u003eDismiss\u003c/button\u003e\\n             \u003c/div\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        \u003cdiv className\u003d\\\"max-w-5xl w-full flex flex-col items-center gap-12\\\"\u003e\\n            {/* Whiteboard */}\\n            \u003cdiv className\u003d\\\"w-full relative\\\"\u003e\\n               {currentSlide ? (\\n                  \u003cInfographic \\n                    image\u003d{currentSlide} \\n                    onEdit\u003d{() \u003d\u003e {}} \\n                    onRegenerate\u003d{handleRegenerate}\\n                    isEditing\u003d{false}\\n                  /\u003e\\n               ) : (\\n                  \u003cdiv className\u003d\\\"aspect-video w-full bg-white dark:bg-slate-900 rounded-[3rem] border border-slate-200 dark:border-white/5 shadow-2xl flex flex-col items-center justify-center gap-6 group\\\"\u003e\\n                    \u003cdiv className\u003d\\\"relative\\\"\u003e\\n                      \u003cVolume2 className\u003d\\\"w-20 h-20 opacity-10 group-hover:opacity-20 transition-opacity\\\" /\u003e\\n                      {isLecturing \u0026\u0026 \u003cdiv className\u003d\\\"absolute inset-0 border-2 border-cyan-500 rounded-full animate-ping opacity-20\\\"\u003e\u003c/div\u003e}\\n                    \u003c/div\u003e\\n                    \u003cdiv className\u003d\\\"text-center space-y-2 opacity-30\\\"\u003e\\n                        \u003cp className\u003d\\\"font-display font-bold uppercase tracking-[0.3em] text-sm\\\"\u003eInteractive Hall\u003c/p\u003e\\n                        \u003cp className\u003d\\\"text-xs italic\\\"\u003e{isLecturing ? \\\"Professor Alpha is preparing insights...\\\" : \\\"Open Navigator to enroll and begin your session\\\"}\u003c/p\u003e\\n                    \u003c/div\u003e\\n                  \u003c/div\u003e\\n               )}\\n\\n               {isLecturing \u0026\u0026 (\\n                 \u003cdiv className\u003d\\\"absolute top-6 right-6 flex items-center gap-2 bg-emerald-500/90 backdrop-blur-md text-white px-4 py-2 rounded-full text-[10px] font-bold shadow-lg\\\"\u003e\\n                    \u003cSparkles className\u003d\\\"w-3 h-3 animate-pulse\\\" /\u003e\\n                    {isExamMode ? \u0027EXAMINATION IN SESSION\u0027 : \u0027LECTURE IN PROGRESS\u0027}\\n                 \u003c/div\u003e\\n               )}\\n            \u003c/div\u003e\\n\\n            {/* Interaction Button */}\\n            \u003cdiv className\u003d\\\"relative\\\"\u003e\\n               \u003cbutton \\n                  onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                  disabled\u003d{!isLecturing || isExamMode}\\n                  className\u003d{`flex flex-col items-center justify-center w-40 h-40 rounded-full border-8 transition-all disabled:opacity-20 disabled:scale-90 ${\\n                    isQuestioning \\n                    ? \u0027bg-amber-500 border-amber-400 scale-110 shadow-[0_0_50px_rgba(245,158,11,0.4)] text-white\u0027 \\n                    : \u0027bg-white dark:bg-slate-800 border-white dark:border-slate-800 text-slate-400 hover:border-cyan-500 hover:text-cyan-600 dark:hover:text-cyan-400 shadow-xl\u0027\\n                  }`}\\n               \u003e\\n                 {isQuestioning ? \u003cMic className\u003d\\\"w-12 h-12 animate-pulse\\\" /\u003e : \u003cHand className\u003d\\\"w-12 h-12\\\" /\u003e}\\n                 \u003cspan className\u003d{`mt-2 text-[9px] font-bold uppercase tracking-[0.2em] ${isQuestioning ? \u0027text-white\u0027 : \u0027text-slate-400\u0027}`}\u003e\\n                    {isQuestioning ? \u0027Speaking...\u0027 : \u0027I have a question\u0027}\\n                 \u003c/span\u003e\\n               \u003c/button\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n\\n        {/* Student Status Bar */}\\n        \u003cdiv className\u003d\\\"absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-6 px-8 py-3 bg-white/70 dark:bg-slate-900/70 rounded-full backdrop-blur-xl border border-slate-200 dark:border-white/5 shadow-sm text-slate-400\\\"\u003e\\n            \u003cdiv className\u003d\\\"flex items-center gap-2\\\"\u003e\\n               \u003cdiv className\u003d\\\"flex items-center gap-1.5\\\"\u003e\\n                  \u003cShieldCheck className\u003d{`w-3 h-3 ${student?.tier \u003d\u003d\u003d \u0027Grandmaster\u0027 ? \u0027text-amber-500\u0027 : student?.tier \u003d\u003d\u003d \u0027Scholar\u0027 ? \u0027text-cyan-500\u0027 : \u0027text-slate-400\u0027}`} /\u003e\\n                  \u003cspan className\u003d\\\"text-[9px] font-bold uppercase tracking-widest text-slate-600 dark:text-slate-300\\\"\u003e{student?.name || \u0027Guest Student\u0027}\u003c/span\u003e\\n               \u003c/div\u003e\\n               \u003cdiv className\u003d\\\"w-1 h-1 bg-cyan-500 rounded-full\\\"\u003e\u003c/div\u003e\\n               \u003cspan className\u003d\\\"text-[9px] font-bold uppercase tracking-widest\\\"\u003e{student?.major || \u0027Undeclared\u0027}\u003c/span\u003e\\n            \u003c/div\u003e\\n            \u003cdiv className\u003d\\\"w-px h-3 bg-slate-300 dark:bg-slate-800\\\"\u003e\u003c/div\u003e\\n            \u003cspan className\u003d\\\"text-[9px] font-bold uppercase tracking-widest text-cyan-500 font-display\\\"\u003e{student?.level || \u0027Preparatory\u0027}\u003c/span\u003e\\n            {student \u0026\u0026 (\\n               \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n                  \u003cdiv className\u003d\\\"w-16 h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden\\\"\u003e\\n                     \u003cdiv \\n                        className\u003d\\\"h-full bg-cyan-500 transition-all duration-1000\\\" \\n                        style\u003d{{ width: `${Math.min(100, (student.currentStudyHours / student.studyHoursGoal) * 100)}%` }}\\n                     \u003e\u003c/div\u003e\\n                  \u003c/div\u003e\\n                  \u003cspan className\u003d\\\"text-[8px] font-bold font-mono tracking-tighter\\\"\u003e\\n                    {Math.floor(student.currentStudyHours * 60)}M / {student.studyHoursGoal}H\\n                  \u003c/span\u003e\\n               \u003c/div\u003e\\n            )}\\n        \u003c/div\u003e\\n      \u003c/main\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default App;\\n\"}]},{\"path\":\"components/Syllabus.tsx\",\"generationType\":1,\"isDone\":false,\"description\":\"Redesigned the Navigator to include a subscription tier selection during enrollment and an upgrade section for existing students. Added support for locked topics based on tiers.\",\"errorWhileGenerating\":true}]},\"createdTimestamp\":{\"seconds\":1767888458,\"nanos\":728000000},\"doneTimestamp\":{\"seconds\":1767888461,\"nanos\":146000000}},{\"id\":215,\"author\":\"model\",\"payload\":{\"type\":\"error\",\"error\":\"An internal error occurred.\",\"metadata\":{\"message\":\"Failed to run code assistant. Please try again.\"},\"isCancelError\":false,\"isLoopingError\":false},\"createdTimestamp\":{\"seconds\":1767888641,\"nanos\":250000000},\"doneTimestamp\":{\"seconds\":1767888641,\"nanos\":250000000}},{\"id\":216,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"There was an unexpected error. Finish what you were doing.\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888653,\"nanos\":325000000}},{\"id\":217,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Envisioning Future Scope**\\n\\nI\u0027m currently focused on expanding the application\u0027s core functionality. I\u0027m prioritizing the integration of a user authentication system, including both sign-up and login features. Furthermore, I\u0027m thinking about implementing tiered payment plans catered specifically to students at indigenous universities. Finally, I\u0027m brainstorming how we can unlock additional opportunities upon payment, and incorporating more areas of study.\\n\\n\\n**Defining Subject Scope**\\n\\nI\u0027ve been expanding the scope of `types.ts` by adding more subjects like Philosophy and Astronomy. Also, I\u0027m examining `Syllabus.tsx`, the enrollment component, so I can ensure a clear user experience for subscription selection, as well as handle tier-based unlocks, and feature updates. I need to make sure the user can select their preferred subscription.\\n\\n\\n**Implementing Enrollment Flow**\\n\\nI\u0027m currently fleshing out the enrollment process in `Syllabus.tsx`. I\u0027ve added a staged flow: \\\"Identity\\\" and \\\"Plan.\\\" I\u0027m now displaying tier benefits, using glassmorphism cards and distinct colors (gold/amber for Grandmaster, cyan for Scholar, slate for Standard). I\u0027m also adding a \\\"Switch Profile\\\" option. I\u0027m focusing on the user experience with locked topics and upgrade prompts. I\u0027m ready to begin implementation.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888653,\"nanos\":325000000},\"doneTimestamp\":{\"seconds\":1767888662,\"nanos\":550000000}},{\"id\":218,\"author\":\"model\",\"payload\":{\"type\":\"text\",\"text\":\"To satisfy your request, I will enhance the enrollment process with a sophisticated **Academic Plan Selection**, expand the curriculum with **Indigenous University** themed areas of study, and implement the **tiered unlocking system** for premium academic opportunities.\\n\\n### Specification\\n1.  **Identity \u0026 Authentication**: The enrollment form now functions as a \\\"Sign Up\\\" portal. A \\\"Switch Profile\\\" option acts as a login/logout mechanism.\\n2.  **Payment Plans**:\\n    *   **Standard (Free)**: Access to core STEM and Physics modules.\\n    *   **Scholar (Premium)**: Unlocks Economics, Music Theory, and Engineering.\\n    *   **Grandmaster (Elite)**: Unlocks all subjects including Philosophy, Archeology, and Linguistics, plus advanced Speech-to-Speech priority.\\n3.  **Tiered Unlocking**: The Syllabus (Navigator) will visually lock premium subjects. Clicking a locked module triggers an \\\"Upgrade University Status\\\" modal.\\n4.  **Expanded Curriculum**: Added \u0027Philosophy\u0027, \u0027Archeology\u0027, \u0027Linguistics\u0027, and \u0027Astronomy\u0027 to the academic registry.\\n5.  **Visual Enhancements**:\\n    *   Plan cards with distinctive icons (Zap, Star, Crown).\\n    *   Glow effects and high-fidelity lock states for premium courses.\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888662,\"nanos\":550000000},\"doneTimestamp\":{\"seconds\":1767888662,\"nanos\":580000000}},{\"id\":219,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"types.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Expanded SubjectArea and ensured SubscriptionTier is robustly defined.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nexport type AspectRatio \u003d \u002716:9\u0027 | \u00279:16\u0027 | \u00271:1\u0027;\\n\\nexport type ComplexityLevel \u003d \u0027Elementary\u0027 | \u0027High School\u0027 | \u0027College\u0027 | \u0027Expert\u0027;\\n\\nexport type SubscriptionTier \u003d \u0027Standard\u0027 | \u0027Scholar\u0027 | \u0027Grandmaster\u0027;\\n\\nexport type SubjectArea \u003d \\n  | \u0027STEM\u0027 \\n  | \u0027History\u0027 \\n  | \u0027Biology\u0027 \\n  | \u0027Physics\u0027 \\n  | \u0027Geography\u0027 \\n  | \u0027Literature\u0027 \\n  | \u0027Engineering\u0027 \\n  | \u0027Economics\u0027\\n  | \u0027Music Theory\u0027\\n  | \u0027Philosophy\u0027\\n  | \u0027Archeology\u0027\\n  | \u0027Linguistics\u0027\\n  | \u0027Astronomy\u0027\\n  | \u0027General\u0027;\\n\\nexport type VisualStyle \u003d \u0027Default\u0027 | \u0027Minimalist\u0027 | \u0027Realistic\u0027 | \u0027Cartoon\u0027 | \u0027Vintage\u0027 | \u0027Futuristic\u0027 | \u00273D Render\u0027 | \u0027Sketch\u0027;\\n\\nexport type Language \u003d \u0027English\u0027 | \u0027Spanish\u0027 | \u0027French\u0027 | \u0027German\u0027 | \u0027Mandarin\u0027 | \u0027Japanese\u0027 | \u0027Hindi\u0027 | \u0027Arabic\u0027 | \u0027Portuguese\u0027 | \u0027Russian\u0027;\\n\\nexport interface StudentProfile {\\n  name: string;\\n  major: SubjectArea;\\n  level: ComplexityLevel;\\n  tier: SubscriptionTier;\\n  enrolledDate: number;\\n  studyHoursGoal: number;\\n  currentStudyHours: number;\\n}\\n\\n/**\\n * Interface representing a course topic in the syllabus.\\n */\\nexport interface CourseTopic {\\n  id: string;\\n  title: string;\\n  duration: string;\\n  isCompleted: boolean;\\n  subject: SubjectArea;\\n  isLocked?: boolean;\\n}\\n\\nexport interface GeneratedImage {\\n  id: string;\\n  data: string; // Base64 data URL\\n  prompt: string;\\n  timestamp: number;\\n  level?: ComplexityLevel;\\n  style?: VisualStyle;\\n  language?: Language;\\n  subject?: SubjectArea;\\n}\\n\\nexport interface SearchResultItem {\\n  title: string;\\n  url: string;\\n}\\n\\nexport interface ResearchResult {\\n  imagePrompt: string;\\n  facts: string[];\\n  searchResults: SearchResultItem[];\\n}\\n\\ndeclare global {\\n  interface AIStudio {\\n    hasSelectedApiKey: () \u003d\u003e Promise\u003cboolean\u003e;\\n    openSelectKey: () \u003d\u003e Promise\u003cvoid\u003e;\\n  }\\n  interface Window {\\n    SpeechRecognition: any;\\n    webkitSpeechRecognition: any;\\n  }\\n}\\n\"}]},{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Updated topic list with more diverse subjects and logic to manage locked content based on student subscription tiers.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SubjectArea, CourseTopic, StudentProfile, SubscriptionTier } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { Sun, Moon, Mic, Hand, Volume2, Menu, X, Award, CheckCircle2, Sparkles, ShieldCheck } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027Indigenous Worldviews\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n  const [isExamMode, setIsExamMode] \u003d useState(false);\\n  const [showPromotion, setShowPromotion] \u003d useState(false);\\n\\n  const [student, setStudent] \u003d useState\u003cStudentProfile | null\u003e(() \u003d\u003e {\\n    const saved \u003d localStorage.getItem(\u0027student_profile\u0027);\\n    return saved ? JSON.parse(saved) : null;\\n  });\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const studyTimerRef \u003d useRef\u003cnumber | null\u003e(null);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027Indigenous Worldviews\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027History\u0027 },\\n    { id: \u00272\u0027, title: \u0027Astrophysics \u0026 Navigation\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Astronomy\u0027, isLocked: true },\\n    { id: \u00273\u0027, title: \u0027Architectural Engineering\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027, isLocked: true },\\n    { id: \u00274\u0027, title: \u0027The Philosophy of Mind\u0027, duration: \u00272.0 hrs\u0027, isCompleted: false, subject: \u0027Philosophy\u0027, isLocked: true },\\n    { id: \u00275\u0027, title: \u0027Quantum Archeology\u0027, duration: \u00271.5 hrs\u0027, isCompleted: false, subject: \u0027Archeology\u0027, isLocked: true },\\n    { id: \u00276\u0027, title: \u0027Ethno-Linguistics\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Linguistics\u0027, isLocked: true },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (student) {\\n      localStorage.setItem(\u0027student_profile\u0027, JSON.stringify(student));\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e {\\n        if (student.tier \u003d\u003d\u003d \u0027Grandmaster\u0027) return { ...t, isLocked: false };\\n        if (student.tier \u003d\u003d\u003d \u0027Scholar\u0027) {\\n          return ([\u0027Philosophy\u0027, \u0027Archeology\u0027, \u0027Linguistics\u0027].includes(t.subject)) ? { ...t, isLocked: true } : { ...t, isLocked: false };\\n        }\\n        return ([\u0027History\u0027, \u0027STEM\u0027, \u0027General\u0027].includes(t.subject)) ? { ...t, isLocked: false } : { ...t, isLocked: true };\\n      }));\\n    }\\n  }, [student]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isLecturing \u0026\u0026 !isExamMode) {\\n      studyTimerRef.current \u003d window.setInterval(() \u003d\u003e {\\n        setStudent(prev \u003d\u003e prev ? { ...prev, currentStudyHours: prev.currentStudyHours + (1/3600) } : null);\\n      }, 1000);\\n    } else {\\n      if (studyTimerRef.current) clearInterval(studyTimerRef.current);\\n    }\\n    return () \u003d\u003e { if (studyTimerRef.current) clearInterval(studyTimerRef.current); };\\n  }, [isLecturing, isExamMode]);\\n\\n  const toggleLecture \u003d async (exam: boolean \u003d false) \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      setIsExamMode(false);\\n      return;\\n    }\\n\\n    setIsExamMode(exam);\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) { console.error(e); }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(e),\\n        onclose: () \u003d\u003e { setIsLecturing(false); setIsExamMode(false); }\\n      }, student?.major || \u0027STEM\u0027, exam ? `FINAL EXAM FOR ${currentTopic}` : currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning \u0026\u0026 !exam) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false);\\n    } catch (e) {\\n      console.error(\\\"Session fail\\\", e);\\n    }\\n  };\\n\\n  const handleEnroll \u003d (name: string, major: SubjectArea, schedule: number, tier: SubscriptionTier) \u003d\u003e {\\n    setStudent({\\n      name,\\n      major,\\n      level: \u0027Elementary\u0027,\\n      tier: tier,\\n      enrolledDate: Date.now(),\\n      studyHoursGoal: schedule,\\n      currentStudyHours: 0\\n    });\\n    setComplexityLevel(\u0027Elementary\u0027);\\n  };\\n\\n  const markDone \u003d () \u003d\u003e {\\n    const active \u003d topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic);\\n    if (active) {\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d active.id ? { ...t, isCompleted: true } : t));\\n    }\\n  };\\n\\n  const promoteStudent \u003d () \u003d\u003e {\\n    const levels: ComplexityLevel[] \u003d [\u0027Elementary\u0027, \u0027High School\u0027, \u0027College\u0027, \u0027Expert\u0027];\\n    const currentIdx \u003d levels.indexOf(student?.level || \u0027Elementary\u0027);\\n    if (currentIdx \u003c levels.length - 1) {\\n      const nextLevel \u003d levels[currentIdx + 1];\\n      setStudent(prev \u003d\u003e prev ? { ...prev, level: nextLevel } : null);\\n      setComplexityLevel(nextLevel);\\n      setShowPromotion(true);\\n      setTimeout(() \u003d\u003e setShowPromotion(false), 5000);\\n      setIsExamMode(false);\\n      setIsLecturing(false);\\n      sessionRef.current?.close?.();\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e ({ ...t, isCompleted: false })));\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setComplexityLevel(level);\\n    setVisualStyle(style);\\n    if (currentSlide) {\\n      const data \u003d await generateInfographicImage(`Updated visual: ${currentSlide.prompt}. Complexity: ${level}, Style: ${style}`);\\n      setCurrentSlide({ ...currentSlide, data, level, style });\\n    }\\n  };\\n\\n  const handleUpdateTier \u003d (tier: SubscriptionTier) \u003d\u003e {\\n    setStudent(prev \u003d\u003e prev ? { ...prev, tier } : null);\\n    setIsSidebarOpen(true);\\n  };\\n\\n  const handleLogout \u003d () \u003d\u003e {\\n    setStudent(null);\\n    localStorage.removeItem(\u0027student_profile\u0027);\\n    setIsSidebarOpen(false);\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans transition-colors overflow-hidden\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} studentName\u003d{student?.name} /\u003e}\\n      \\n      \u003cbutton \\n        onClick\u003d{() \u003d\u003e setIsSidebarOpen(!isSidebarOpen)}\\n        className\u003d\\\"fixed top-6 left-6 z-[60] p-4 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-white/10 hover:scale-105 active:scale-95 transition-all text-cyan-600 dark:text-cyan-400\\\"\\n      \u003e\\n        {isSidebarOpen ? \u003cX className\u003d\\\"w-6 h-6\\\" /\u003e : \u003cMenu className\u003d\\\"w-6 h-6\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"fixed top-8 right-8 z-[60] p-2 rounded-full opacity-20 hover:opacity-100 transition-opacity\\\"\u003e\\n        {isDarkMode ? \u003cSun className\u003d\\\"w-4 h-4\\\" /\u003e : \u003cMoon className\u003d\\\"w-4 h-4\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      \u003cdiv className\u003d{`fixed inset-0 z-50 transition-opacity duration-500 ${isSidebarOpen ? \u0027opacity-100\u0027 : \u0027opacity-0 pointer-events-none\u0027}`}\u003e\\n          \u003cdiv className\u003d\\\"absolute inset-0 bg-slate-950/40 backdrop-blur-sm\\\" onClick\u003d{() \u003d\u003e setIsSidebarOpen(false)}\u003e\u003c/div\u003e\\n          \