mb-4 p-2\\\"\u003e\\n                {subjects.map((s) \u003d\u003e (\\n                    \u003cbutton\\n                        key\u003d{s.id}\\n                        type\u003d\\\"button\\\"\\n                        onClick\u003d{() \u003d\u003e setSubject(s.id)}\\n                        className\u003d{`flex items-center gap-2 px-4 py-2.5 rounded-full text-xs font-bold transition-all border ${\\n                            subject \u003d\u003d\u003d s.id \\n                            ? \u0027bg-cyan-600 text-white border-cyan-500 shadow-lg shadow-cyan-500/20 scale-105\u0027 \\n                            : \u0027bg-slate-100 dark:bg-slate-800 text-slate-500 border-transparent hover:border-slate-300 dark:hover:border-slate-700\u0027\\n                        }`}\\n                    \u003e\\n                        \u003cs.icon className\u003d{`w-3.5 h-3.5 ${subject \u003d\u003d\u003d s.id ? \u0027text-white\u0027 : s.color}`} /\u003e\\n                        {s.label}\\n                    \u003c/button\u003e\\n                ))}\\n            \u003c/div\u003e\\n\\n            \u003cdiv className\u003d\\\"flex flex-col md:flex-row gap-2\\\"\u003e\\n                \u003cdiv className\u003d\\\"flex-1 relative flex items-center\\\"\u003e\\n                    \u003cSearch className\u003d\\\"absolute left-6 w-6 h-6 text-slate-400\\\" /\u003e\\n                    \u003cinput\\n                        type\u003d\\\"text\\\"\\n                        value\u003d{topic}\\n                        onChange\u003d{(e) \u003d\u003e setTopic(e.target.value)}\\n                        placeholder\u003d\\\"e.g., Photosynthesis, The French Revolution, Quantum Tunneling...\\\"\\n                        className\u003d\\\"w-full pl-16 pr-6 py-5 bg-slate-50 dark:bg-slate-950/50 rounded-2xl border-none outline-none text-xl placeholder:text-slate-400 font-medium text-slate-900 dark:text-white\\\"\\n                    /\u003e\\n                \u003c/div\u003e\\n\\n      