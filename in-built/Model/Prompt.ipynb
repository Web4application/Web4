   return \\\"Pedagogy: Undergraduate level depth. Include quantitative data where possible, complex multi-step processes, and cross-disciplinary connections. Tone: Professional and rigorous.\\\";\\n    case \u0027Expert\u0027:\\n      return \\\"Pedagogy: Post-graduate/Professional level. Assume deep prior knowledge. Focus on nuanced mechanics, edge cases, and high-fidelity technical schematics. Tone: Technical and dense.\\\";\\n    default:\\n      return \\\"General educational overview.\\\";\\n  }\\n};\\n\\nconst getSubjectInstruction \u003d (subject: SubjectArea): string \u003d\u003e {\\n  switch (subject) {\\n    case \u0027STEM\u0027: return \\\"Field: Science \u0026 Tech. Focus on logic flow, data visualization, and technological components.\\\";\\n    case \u0027History\u0027: return \\\"Field: Humanities. Focus on timelines, geographic context, cultural artifacts, and societal impact.\\\";\\n    case \u0027Biology\u0027: return \\\"Field: Life Sciences. Focus on anatomical accuracy, cellular structures, ecological webs, and organic textures.\\\";\\n    case \u0027Physics\u0027: return \\\"Field: Physical Sciences. Focus on forces, vectors, energy states, and mathematical abstractions visualized.\\\";\\n    case \u0027Geography\u0027: return \\\"Field: Earth Sciences. Focus on cartography, terrain, climate systems, and human-environment interaction.\\\";\\n    case \u0027Engineering\u0027: return \\\"Field: Applied Science. Focus on structural integrity, mechanical systems, blueprints, and materials science.\\\";\\n    default: return \\\"Field: General Education.\\\";\\n  }\\n};\\n\\nconst getStyleInstruction \u003d (style: VisualStyle): string \u003d\u003e {\\n  switch (style) {\\n    case \u0027Minimalist\u0027: return \\\"Aesthetic: Bauhaus Minimalist. Flat vector art, limited color palette (2-3 colors), reliance on negative space and simple geometric shapes.\\\";\\n    case \u0027Realistic\u0027: return \\\"Aesthetic: Photorealistic Composite. Cinematic lighting, 8k resolution, highly detailed textures. Looks like a photograph.\\\";\\n    case \u0027Cartoon\u0027: return \\\"Aesthetic: Educational Comic. Vibrant colors, thick outlines, expressive cel-shaded style.\\\";\\n    case \u0027Vintage\u0027: return \\\"Aesthetic: 19th Century Scientific Lithograph. Engraving style, sepia tones, textured paper background, fine hatch lines.\\\";\\n    case \u0027Futuristic\u0027: return \\\"Aesthetic: Cyberpunk HUD. Glowing neon blue/cyan lines on dark background, holographic data visualization, 3D wireframes.\\\";\\n    case \u00273D Render\u0027: return \\\"Aesthetic: 3D Isometric Render. Claymorphism or high-gloss plastic texture, studio lighting, soft shadows, looks like a physical model.\\\";\\n    case \u0027Sketch\u0027: return \\\"Aesthetic: Da Vinci Notebook. Ink on parchment sketch, handwritten annotations style, rough but accurate lines.\\\";\\n    default: return \\\"Aesthetic: High-quality digital scientific illustration. Clean, modern, highly detailed.\\\";\\n  }\\n};\\n\\nexport const researchTopicForPrompt \u003d async (\\n  topic: string, \\n  level: ComplexityLevel, \\n  style: VisualStyle,\\n  language: Language,\\n  subject: SubjectArea \u003d \u0027General\u0027\\n): Promise\u003cResearchResult\u003e \u003d\u003e {\\n  \\n  const levelInstr \u003d getLevelInstruction(level);\\n  const subjectInstr \u003d getSubjectInstruction(subject);\\n  const styleInstr \u003d getStyleInstruction(style);\\n\\n  const systemPrompt \u003d `\\n    You are an AI Professor at a Visual Learning Academy.\\n    Topic: \\\"${topic}\\\"\\n    Department: ${subjectInstr}\\n    Academic Level: ${levelInstr}\\n    \\n    Goal: Research this topic using Google Search and create a lesson plan for a high-fidelity educational infographic.\\n    \\n    Structure your response as follows:\\n    \\n    FACTS:\\n    - [Key Learning Objective 1]\\n    - [Critical Process/Step 2]\\n    - [Important Context/Historical Note 3]\\n    - [Key Vocabulary Term with Definition]\\n    \\n    IMAGE_PROMPT:\\n    [Describe a masterwork educational visual. It should clearly explain the topic visually. Include layout details (e.g., \\\"central diagram with radiating labels\\\", \\\"side-by-side comparison\\\"). Ensure it adheres to the ${styleInstr}. Mention the language for any text elements is ${language}. No citations in prompt.]\\n  `;\\n\\n  // Use generateContent with googleSearch tool and access .text directly.\\n  const response \u003d await getAi().models.generateContent({\\n    model: TEXT_MODEL,\\n    contents: systemPrompt,\\n    config: {\\n      tools: [{ googleSearch: {} }],\\n    },\\n  });\\n\\n  const text \u003d response.text || \\\"\\\";\\n  \\n  const factsMatch \u003d text.match(/FACTS:\\\\s*([\\\\s\\\\S]*?)(?\u003dIMAGE_PROMPT:|$)/i);\\n  const factsRaw \u003d factsMatch ? factsMatch[1].trim() : \\\"\\\";\\n  const facts \u003d factsRaw.split(\u0027\\\\n\u0027)\\n    .map(f \u003d\u003e f.replace(/^-\\\\s*/, \u0027\u0027).trim())\\n    .filter(f \u003d\u003e f.length \u003e 0)\\n    .slice(0, 5);\\n\\n  const promptMatch \u003d text.match(/IMAGE_PROMPT:\\\\s*([\\\\s\\\\S]*?)$/i);\\n  const imagePrompt \u003d promptMatch ? promptMatch[1].trim() : `Create a detailed educational infographic about ${topic} in a ${style} style for ${level} level.`;\\n\\n  const searchResults: SearchResultItem[] \u003d [];\\n  const chunks \u003d response.candidates?.[0]?.groundingMetadata?.groundingChunks;\\n  \\n  if (chunks) {\\n    chunks.forEach(chunk \u003d\u003e {\\n      if (chunk.web?.uri \u0026\u0026 chunk.web?.title) {\\n        searchResults.push({ title: chunk.web.title, url: chunk.web.uri });\\n      }\\n    });\\n  }\\n\\n  const uniqueResults \u003d Array.from(new Map(searchResults.map(item \u003d\u003e [item.url, item])).values());\\n\\n  return {\\n    imagePrompt,\\n    facts,\\n    searchResults: uniqueResults\\n  };\\n};\\n\\nexport const generateInfographicImage \u003d async (prompt: string): Promise\u003cstring\u003e \u003d\u003e {\\n  // Use generateContent for image generation models in the gemini-3 series.\\n  const response \u003d await getAi().models.generateContent({\\n    model: IMAGE_MODEL,\\n    contents: { parts: [{ text: prompt }] },\\n    config: {\\n      imageConfig: {\\n        aspectRatio: \\\"16:9\\\",\\n        imageSize: \\\"1K\\\"\\n      }\\n    }\\n  });\\n\\n  // Nano banana series models return images in candidates[0].content.parts.\\n  const candidates \u003d response.candidates || [];\\n  if (candidates.length \u003e 0 \u0026\u0026 candidates[0].content?.parts) {\\n    for (const part of candidates[0].content.parts) {\\n      if (part.inlineData?.data) {\\n        return `data:image/png;base64,${part.inlineData.data}`;\\n      }\\n    }\\n  }\\n  throw new Error(\\\"Failed to generate educational visual.\\\");\\n};\\n\\nexport const editInfographicImage \u003d async (currentImageBase64: string, editInstruction: string): Promise\u003cstring\u003e \u003d\u003e {\\n  const cleanBase64 \u003d currentImageBase64.replace(/^data:image\\\\/(png|jpeg|jpg);base64,/, \u0027\u0027);\\n  \\n  // Use generateContent to edit images by passing both the image and the edit prompt.\\n  const response \u003d await getAi().models.generateContent({\\n    model: EDIT_MODEL,\\n    contents: {\\n      parts: [\\n         { inlineData: { mimeType: \u0027image/jpeg\u0027, data: cleanBase64 } },\\n         { text: `Educational Correction: ${editInstruction}. Maintain the pedagogical clarity and existing style.` }\\n      ]\\n    }\\n  });\\n  \\n  // Nano banana series models return edited images in candidates[0].content.parts.\\n  const candidates \u003d response.candidates || [];\\n  if (candidates.length \u003e 0 \u0026\u0026 candidates[0].content?.parts) {\\n    for (const part of candidates[0].content.parts) {\\n      if (part.inlineData?.data) {\\n        return `data:image/png;base64,${part.inlineData.data}`;\\n      }\\n    }\\n  }\\n  throw new Error(\\\"Modification failed.\\\");\\n};\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767865423,\"nanos\":397000000},\"doneTimestamp\":{\"seconds\":1767865444,\"nanos\":706000000}},{\"id\":189,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"Let genini act as lecturer that in a way that it give explanations in speech analysis with image example practical examples all in speech and the user will only pay attention add a toggle icon signify I have a question once the user click it the user will also speak the questions then genini will explain \\nAdd botton to a menu bar that displays topic to teach add hours and issue done after the whole lecture on each subject\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865629,\"nanos\":763000000}},{\"id\":190,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Shifting Towards Lecturing**\\n\\nI\u0027m now fully focused on transforming InfoGenius Academy. The goal is a speech-driven Virtual Lecturer experience, with Gemini at the helm, giving interactive lectures. I\u0027m prioritizing the conversational aspects and the user experience for this new initiative.\\n\\n\\n**Refining Interaction Flow**\\n\\nI\u0027m now zeroing in on the lecturer role and interaction flow. Speech and visual integration are my primary focus. I\u0027ve decided to leverage Gemini Live API for real-time interaction via speech-to-text and text-to-speech. I am trying to resolve how to include visual elements, like infographics, given the limitations of the Live API for image generation. I need to be able to trigger function calls or leverage the multimodal abilities in tandem.\\n\\n\\n**Designing The UI Components**\\n\\nI\u0027m now fully immersed in the UI design. I\u0027m prioritizing the lecture hall view with slide/image display, a question toggle, and the course syllabus sidebar. I\u0027m planning to use the Live API for audio input and output. I\u0027m focusing on \\\"I have a question\\\" microphone control within the Live session and managing topics and durations. Finally, I\u0027m setting up function calls for image and slide updates. The application structure will include App.tsx, Lecturer.tsx, and Syllabus.tsx.\\n\\n\\n**Refining The Architecture**\\n\\nI\u0027m now revising the app structure and API usage. I\u0027m focusing on incorporating real-time interaction using the Live API. I\u0027m planning to use `gemini-2.5-flash-native-audio-preview-12-2025` for live audio and `gemini-3-pro-image-preview` for generating lecture slides. I\u0027m updating `metadata.json` for microphone permissions. The updated structure will include components like `Lecturer.tsx` and updated data types in `types.ts`, and I\u0027m updating `App.tsx` for the new layout. I\u0027m planning to keep image generation, and possibly add Live API connection helpers.\\n\\n\\n**Streamlining Visuals and Interaction**\\n\\nI\u0027m now focusing on leveraging the Live API fully. I\u0027ve decided the model will drive image updates using a `display_slide` function, which calls an image generation function. Visually, I\u0027m going with a deep blue/gold academic theme, including a whiteboard area, audio indicators, a floating \\\"I have a question\\\" button, and a syllabus sidebar. The key code changes involve updating types, gemini services, the lecture hall UI, the main app structure, and metadata for microphone permissions.\\n\\n\\n**Implementing Audio Handling**\\n\\nI\u0027m now deep in audio processing. I am adding audio PCM decoding for the Live API, using `gemini-2.5-flash-native-audio-preview-12-2025` for Live audio. I\u0027m focusing on refining the \\\"I have a question\\\" toggle. I am realizing the Live API\u0027s full-duplex nature means the toggle can simply unmute the user\u0027s input stream. I also need to manually handle `decode` and `encode`, along with `AudioContext` and `nextStartTime` for gapless playback.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865629,\"nanos\":763000000},\"doneTimestamp\":{\"seconds\":1767865657,\"nanos\":145000000}},{\"id\":191,\"author\":\"model\",\"payload\":{\"type\":\"text\",\"text\":\"To transform **InfoGenius Academy** into a fully interactive **AI-Lecturer**, I will implement a real-time voice interface using the Gemini Live API. This version will feature a \\\"Lecture Hall\\\" experience where a virtual professor speaks to you, visualizes concepts on a digital whiteboard via function calling, and handles interruptions for student questions.\\n\\n### Specification of Updates\\n\\n1.  **Virtual Lecture Hall UI**:\\n    *   **The Whiteboard**: A large central area where infographics and diagrams are rendered in real-time as the lecturer explains.\\n    *   **Live Waveform**: A visualization of the AI\u0027s speech to signify active lecturing.\\n    *   **\\\"I Have a Question\\\" Toggle**: A floating interaction button (Hand icon). When active, it un-mutes the user\u0027s microphone and alerts the AI that the student is speaking.\\n    *   **Syllabus Sidebar**: A persistent menu showing the current curriculum, estimated lecture hours (calculated based on complexity), and a \\\"Lesson Complete\\\" status.\\n\\n2.  **Live Lecturing Logic (Gemini Live API)**:\\n    *   **Real-Time Speech**: Uses `gemini-2.5-flash-native-audio-preview-12-2025` for low-latency, human-like verbal explanations.\\n    *   **Visual Integration (Function Calling)**: The lecturer is equipped with a `render_visual` tool. When explaining a complex part, the AI will automatically trigger a tool call to generate a new infographic slide.\\n    *   **Interruptions**: The system instructions will tell the AI to pause and listen when the user \\\"raises their hand\\\" (clicks the question toggle).\\n\\n3.  **Syllabus \u0026 Progress Tracking**:\\n    *   **Topic Management**: A new menu bar for selecting \\\"Course Modules\\\".\\n    *   **Completion Flow**: Once a module is finished, a \\\"Certificate issued\\\" or \\\"Topic Done\\\" badge is applied.\\n\\n4.  **Audio Infrastructure**:\\n    *   Standard PCM 16-bit 16kHz audio encoding for user input.\\n    *   PCM 24kHz audio decoding with gapless playback for AI output.\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865657,\"nanos\":145000000},\"doneTimestamp\":{\"seconds\":1767865657,\"nanos\":174000000}},{\"id\":192,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"metadata.json\",\"generationType\":1,\"isDone\":true,\"description\":\"Added microphone permission for real-time student-lecturer interaction.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n{\\n  \\\"name\\\": \\\"InfoGenius Academy\\\",\\n  \\\"description\\\": \\\"Visual Learning Academy with interactive AI Lecturers and real-time infographics.\\\",\\n  \\\"requestFramePermissions\\\": [\\n    \\\"microphone\\\"\\n  ]\\n}\\n\"}]},{\"path\":\"types.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Updated types to support Course Topics, Lecture States, and tool definitions.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nexport type AspectRatio \u003d \u002716:9\u0027 | \u00279:16\u0027 | \u00271:1\u0027;\\n\\nexport type ComplexityLevel \u003d \u0027Elementary\u0027 | \u0027High School\u0027 | \u0027College\u0027 | \u0027Expert\u0027;\\n\\nexport type SubjectArea \u003d \u0027STEM\u0027 | \u0027History\u0027 | \u0027Biology\u0027 | \u0027Physics\u0027 | \u0027Geography\u0027 | \u0027Literature\u0027 | \u0027Engineering\u0027 | \u0027General\u0027;\\n\\nexport type VisualStyle \u003d \u0027Default\u0027 | \u0027Minimalist\u0027 | \u0027Realistic\u0027 | \u0027Cartoon\u0027 | \u0027Vintage\u0027 | \u0027Futuristic\u0027 | \u00273D Render\u0027 | \u0027Sketch\u0027;\\n\\nexport type Language \u003d \u0027English\u0027 | \u0027Spanish\u0027 | \u0027French\u0027 | \u0027German\u0027 | \u0027Mandarin\u0027 | \u0027Japanese\u0027 | \u0027Hindi\u0027 | \u0027Arabic\u0027 | \u0027Portuguese\u0027 | \u0027Russian\u0027;\\n\\nexport interface CourseTopic {\\n  id: string;\\n  title: string;\\n  duration: string;\\n  isCompleted: boolean;\\n  subject: SubjectArea;\\n}\\n\\nexport interface GeneratedImage {\\n  id: string;\\n  data: string; // Base64 data URL\\n  prompt: string;\\n  timestamp: number;\\n  level?: ComplexityLevel;\\n  style?: VisualStyle;\\n  language?: Language;\\n  subject?: SubjectArea;\\n}\\n\\nexport interface SearchResultItem {\\n  title: string;\\n  url: string;\\n}\\n\\nexport interface ResearchResult {\\n  imagePrompt: string;\\n  facts: string[];\\n  searchResults: SearchResultItem[];\\n}\\n\\ndeclare global {\\n  interface AIStudio {\\n    hasSelectedApiKey: () \u003d\u003e Promise\u003cboolean\u003e;\\n    openSelectKey: () \u003d\u003e Promise\u003cvoid\u003e;\\n  }\\n}\\n\"}]},{\"path\":\"services/audioService.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Utility for manual Base64 encoding/decoding and PCM audio buffer management for the Live API.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nexport function encodeBase64(bytes: Uint8Array): string {\\n  let binary \u003d \u0027\u0027;\\n  const len \u003d bytes.byteLength;\\n  for (let i \u003d 0; i \u003c len; i++) {\\n    binary +\u003d String.fromCharCode(bytes[i]);\\n  }\\n  return btoa(binary);\\n}\\n\\nexport function decodeBase64(base64: string): Uint8Array {\\n  const binaryString \u003d atob(base64);\\n  const len \u003d binaryString.length;\\n  const bytes \u003d new Uint8Array(len);\\n  for (let i \u003d 0; i \u003c len; i++) {\\n    bytes[i] \u003d binaryString.charCodeAt(i);\\n  }\\n  return bytes;\\n}\\n\\nexport async function decodeAudioData(\\n  data: Uint8Array,\\n  ctx: AudioContext,\\n  sampleRate: number,\\n  numChannels: number,\\n): Promise\u003cAudioBuffer\u003e {\\n  const dataInt16 \u003d new Int16Array(data.buffer);\\n  const frameCount \u003d dataInt16.length / numChannels;\\n  const buffer \u003d ctx.createBuffer(numChannels, frameCount, sampleRate);\\n\\n  for (let channel \u003d 0; channel \u003c numChannels; channel++) {\\n    const channelData \u003d buffer.getChannelData(channel);\\n    for (let i \u003d 0; i \u003c frameCount; i++) {\\n      channelData[i] \u003d dataInt16[i * numChannels + channel] / 32768.0;\\n    }\\n  }\\n  return buffer;\\n}\\n\\nexport function createPcmBlob(data: Float32Array): { data: string; mimeType: string } {\\n  const l \u003d data.length;\\n  const int16 \u003d new Int16Array(l);\\n  for (let i \u003d 0; i \u003c l; i++) {\\n    int16[i] \u003d data[i] * 32768;\\n  }\\n  return {\\n    data: encodeBase64(new Uint8Array(int16.buffer)),\\n    mimeType: \u0027audio/pcm;rate\u003d16000\u0027,\\n  };\\n}\\n\"}]},{\"path\":\"services/geminiService.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Enhanced with Live API connection logic, slide-rendering tool definitions, and lecturer instructions.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport { GoogleGenAI, Modality, Type, FunctionDeclaration } from \\\"@google/genai\\\";\\nimport { ComplexityLevel, VisualStyle, ResearchResult, SearchResultItem, Language, SubjectArea } from \\\"../types\\\";\\n\\nconst getAi \u003d () \u003d\u003e {\\n  return new GoogleGenAI({ apiKey: process.env.API_KEY });\\n};\\n\\nconst TEXT_MODEL \u003d \u0027gemini-3-pro-preview\u0027;\\nconst IMAGE_MODEL \u003d \u0027gemini-3-pro-image-preview\u0027;\\nconst LIVE_MODEL \u003d \u0027gemini-2.5-flash-native-audio-preview-12-2025\u0027;\\n\\nconst renderVisualTool: FunctionDeclaration \u003d {\\n  name: \u0027render_visual\u0027,\\n  parameters: {\\n    type: Type.OBJECT,\\n    description: \u0027Generates a detailed educational infographic or diagram on the whiteboard to help explain the current concept.\u0027,\\n    properties: {\\n      description: {\\n        type: Type.STRING,\\n        description: \u0027A vivid, detailed description for the AI image generator. Include pedagogical context.\u0027,\\n      },\\n    },\\n    required: [\u0027description\u0027],\\n  },\\n};\\n\\nexport const connectLecturer \u003d (callbacks: any, subject: SubjectArea, topic: string) \u003d\u003e {\\n  const ai \u003d getAi();\\n  return ai.live.connect({\\n    model: LIVE_MODEL,\\n    callbacks,\\n    config: {\\n      responseModalities: [Modality.AUDIO],\\n      tools: [{ functionDeclarations: [renderVisualTool] }],\\n      speechConfig: {\\n        voiceConfig: { prebuiltVoiceConfig: { voiceName: \u0027Charon\u0027 } }, // Authoritative academic voice\\n      },\\n      systemInstruction: `You are Professor Alpha, a world-class lecturer in ${subject}. \\n      You are giving a live, interactive lecture on \\\"${topic}\\\".\\n      \\n      Rules:\\n      1. Start the lecture with a warm welcome and an overview.\\n      2. Use the \u0027render_visual\u0027 tool frequently (every 1-2 minutes) to show diagrams, charts, or blueprints that support your speech.\\n      3. If the user asks a question, stop lecturing immediately, address them by name (or as \\\"Student\\\"), and explain the concept with practical examples.\\n      4. Maintain a professional, enthusiastic, and clear academic tone.\\n      5. Your explanations should include \\\"speech analysis\\\" - describing what you are showing in real-time.`,\\n    },\\n  });\\n};\\n\\n// ... Existing generation/edit functions remain but using getAi() inside for freshness\\nexport const generateInfographicImage \u003d async (prompt: string): Promise\u003cstring\u003e \u003d\u003e {\\n  const response \u003d await getAi().models.generateContent({\\n    model: IMAGE_MODEL,\\n    contents: { parts: [{ text: prompt }] },\\n    config: {\\n      imageConfig: { aspectRatio: \\\"16:9\\\", imageSize: \\\"1K\\\" }\\n    }\\n  });\\n\\n  const candidates \u003d response.candidates || [];\\n  if (candidates.length \u003e 0 \u0026\u0026 candidates[0].content?.parts) {\\n    for (const part of candidates[0].content.parts) {\\n      if (part.inlineData?.data) {\\n        return `data:image/png;base64,${part.inlineData.data}`;\\n      }\\n    }\\n  }\\n  throw new Error(\\\"Failed to generate educational visual.\\\");\\n};\\n\\nexport const researchTopicForPrompt \u003d async (\\n  topic: string, \\n  level: ComplexityLevel, \\n  style: VisualStyle,\\n  language: Language,\\n  subject: SubjectArea \u003d \u0027General\u0027\\n): Promise\u003cResearchResult\u003e \u003d\u003e {\\n  const systemPrompt \u003d `Researching \\\"${topic}\\\" for ${subject} at ${level} level. \\n  Prepare Facts and a Slide Prompt. Use googleSearch.`;\\n\\n  const response \u003d await getAi().models.generateContent({\\n    model: TEXT_MODEL,\\n    contents: systemPrompt,\\n    config: { tools: [{ googleSearch: {} }] },\\n  });\\n\\n  const text \u003d response.text || \\\"\\\";\\n  const factsMatch \u003d text.match(/FACTS:\\\\s*([\\\\s\\\\S]*?)(?\u003dIMAGE_PROMPT:|$)/i);\\n  const facts \u003d factsMatch ? factsMatch[1].trim().split(\u0027\\\\n\u0027).map(f \u003d\u003e f.replace(/^-\\\\s*/, \u0027\u0027).trim()).slice(0, 5) : [];\\n  const promptMatch \u003d text.match(/IMAGE_PROMPT:\\\\s*([\\\\s\\\\S]*?)$/i);\\n  const imagePrompt \u003d promptMatch ? promptMatch[1].trim() : `Diagram of ${topic}`;\\n\\n  const searchResults: SearchResultItem[] \u003d [];\\n  const chunks \u003d response.candidates?.[0]?.groundingMetadata?.groundingChunks || [];\\n  chunks.forEach(chunk \u003d\u003e {\\n    if (chunk.web?.uri \u0026\u0026 chunk.web?.title) {\\n      searchResults.push({ title: chunk.web.title, url: chunk.web.uri });\\n    }\\n  });\\n\\n  return { imagePrompt, facts, searchResults };\\n};\\n\"}]},{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Main App overhauled to include the Lecture Hall interface, Syllabus sidebar, and Live audio orchestration.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SearchResultItem, SubjectArea, CourseTopic } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decodeBase64, decodeAudioData, createPcmBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { GraduationCap, Sun, Moon, Key, Mic, MicOff, Hand, Play, Square, CheckCircle, Clock } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [subject, setSubject] \u003d useState\u003cSubjectArea\u003e(\u0027STEM\u0027);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027Quantum Physics Basics\u0027);\\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [hasApiKey, setHasApiKey] \u003d useState(false);\\n  \\n  // Audio State refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const streamRef \u003d useRef\u003cMediaStream | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const nextStartTimeRef \u003d useRef(0);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027Intro to Astrophysics\u0027, duration: \u00271.5 hrs\u0027, isCompleted: false, subject: \u0027STEM\u0027 },\\n    { id: \u00272\u0027, title: \u0027Cellular Biology 101\u0027, duration: \u00272 hrs\u0027, isCompleted: false, subject: \u0027Biology\u0027 },\\n    { id: \u00273\u0027, title: \u0027Thermodynamics\u0027, duration: \u00273 hrs\u0027, isCompleted: false, subject: \u0027Physics\u0027 },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  const toggleLecture \u003d async () \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close();\\n      setIsLecturing(false);\\n      return;\\n    }\\n\\n    try {\\n      if (!audioContextRef.current) {\\n        audioContextRef.current \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      }\\n      \\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      streamRef.current \u003d stream;\\n      \\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          console.log(\\\"Lecture session opened\\\");\\n          const inputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n          const source \u003d inputCtx.createMediaStreamSource(stream);\\n          const scriptProcessor \u003d inputCtx.createScriptProcessor(4096, 1, 1);\\n          \\n          scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n            if (!isQuestioning) return; // Only send audio when user is asking a question\\n            const inputData \u003d e.inputBuffer.getChannelData(0);\\n            const pcmBlob \u003d createPcmBlob(inputData);\\n            sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n          };\\n          \\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(inputCtx.destination);\\n        },\\n        onmessage: async (msg: any) \u003d\u003e {\\n          const base64Audio \u003d msg.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 audioContextRef.current) {\\n            const ctx \u003d audioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decodeBase64(base64Audio), ctx, 24000, 1);\\n            const source \u003d ctx.createBufferSource();\\n            source.buffer \u003d audioBuffer;\\n            source.connect(ctx.destination);\\n            source.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(source);\\n            source.onended \u003d () \u003d\u003e sourcesRef.current.delete(source);\\n          }\\n\\n          if (msg.toolCall) {\\n            for (const fc of msg.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                const imgData \u003d await generateInfographicImage(fc.args.description);\\n                setCurrentSlide({\\n                  id: Date.now().toString(),\\n                  data: imgData,\\n                  prompt: fc.args.description,\\n                  timestamp: Date.now()\\n                });\\n                sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                  functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Slide updated successfully\\\" } }\\n                }));\\n              }\\n            }\\n          }\\n\\n          if (msg.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n        },\\n        onclose: () \u003d\u003e setIsLecturing(false),\\n        onerror: (e: any) \u003d\u003e console.error(\\\"Session Error:\\\", e),\\n      }, subject, currentTopic);\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n    } catch (err) {\\n      console.error(\\\"Failed to start lecture:\\\", err);\\n    }\\n  };\\n\\n  const markDone \u003d (id: string) \u003d\u003e {\\n    setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d id ? { ...t, isCompleted: true } : t));\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 flex flex-col transition-colors\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} /\u003e}\\n      \\n      {/* Header */}\\n      \u003cheader className\u003d\\\"h-16 border-b border-slate-200 dark:border-white/10 flex items-center justify-between px-6 backdrop-blur-md sticky top-0 z-50\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n          \u003cGraduationCap className\u003d\\\"text-cyan-600 w-8 h-8\\\" /\u003e\\n          \u003ch1 className\u003d\\\"font-display font-bold text-xl tracking-tight\\\"\u003eAlpha \u003cspan className\u003d\\\"text-cyan-600\\\"\u003eLecturer\u003c/span\u003e\u003c/h1\u003e\\n        \u003c/div\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-4\\\"\u003e\\n          \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"p-2 hover:bg-slate-200 dark:hover:bg-slate-800 rounded-full transition-colors\\\"\u003e\\n            {isDarkMode ? \u003cSun className\u003d\\\"w-5 h-5\\\" /\u003e : \u003cMoon className\u003d\\\"w-5 h-5\\\" /\u003e}\\n          \u003c/button\u003e\\n        \u003c/div\u003e\\n      \u003c/header\u003e\\n\\n      \u003cdiv className\u003d\\\"flex-1 flex overflow-hidden\\\"\u003e\\n        {/* Sidebar Syllabus */}\\n        \u003cSyllabus topics\u003d{topics} currentId\u003d{topics[0].id} onSelect\u003d{(t) \u003d\u003e setCurrentTopic(t.title)} onDone\u003d{markDone} /\u003e\\n\\n        {/* Lecture Content */}\\n        \u003cmain className\u003d\\\"flex-1 p-8 overflow-y-auto relative bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-950 dark:to-black\\\"\u003e\\n          \u003cdiv className\u003d\\\"max-w-5xl mx-auto space-y-8\\\"\u003e\\n            \u003cdiv className\u003d\\\"flex items-center justify-between\\\"\u003e\\n              \u003cdiv\u003e\\n                \u003ch2 className\u003d\\\"text-3xl font-display font-bold text-slate-800 dark:text-white\\\"\u003e{currentTopic}\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-500 dark:text-slate-400 flex items-center gap-2 mt-1\\\"\u003e\\n                  \u003cClock className\u003d\\\"w-4 h-4\\\" /\u003e 1 hour remaining in this module\\n                \u003c/p\u003e\\n              \u003c/div\u003e\\n              \u003cbutton \\n                onClick\u003d{toggleLecture}\\n                className\u003d{`flex items-center gap-3 px-8 py-4 rounded-2xl font-bold transition-all shadow-xl ${\\n                  isLecturing \\n                  ? \u0027bg-red-500 text-white hover:bg-red-600\u0027 \\n                  : \u0027bg-cyan-600 text-white hover:bg-cyan-500 shadow-cyan-500/20\u0027\\n                }`}\\n              \u003e\\n                {isLecturing ? \u003cSquare className\u003d\\\"w-5 h-5 fill-current\\\" /\u003e : \u003cPlay className\u003d\\\"w-5 h-5 fill-current\\\" /\u003e}\\n                {isLecturing ? \u0027STOP LECTURE\u0027 : \u0027START LECTURE\u0027}\\n              \u003c/button\u003e\\n            \u003c/div\u003e\\n\\n            {/* The Whiteboard */}\\n            \u003cdiv className\u003d\\\"aspect-video w-full bg-white dark:bg-slate-900 rounded-[2.5rem] border border-slate-200 dark:border-white/5 shadow-inner overflow-hidden flex items-center justify-center relative group\\\"\u003e\\n              {currentSlide ? (\\n                \u003cimg src\u003d{currentSlide.data} alt\u003d\\\"Visual slide\\\" className\u003d\\\"w-full h-full object-cover animate-in fade-in zoom-in-95 duration-700\\\" /\u003e\\n              ) : (\\n                \u003cdiv className\u003d\\\"flex flex-col items-center gap-4 opacity-20 group-hover:opacity-40 transition-opacity\\\"\u003e\\n                  \u003cdiv className\u003d\\\"w-24 h-24 border-4 border-dashed border-slate-400 dark:border-slate-500 rounded-3xl animate-[spin_20s_linear_infinite]\\\"\u003e\u003c/div\u003e\\n                  \u003cspan className\u003d\\\"font-display font-bold text-xl uppercase tracking-widest text-slate-500\\\"\u003eThe Whiteboard\u003c/span\u003e\\n                \u003c/div\u003e\\n              )}\\n\\n              {/* Speech Waveform Overlay */}\\n              {isLecturing \u0026\u0026 (\\n                \u003cdiv className\u003d\\\"absolute bottom-10 left-1/2 -translate-x-1/2 flex items-end gap-1 h-8\\\"\u003e\\n                  {[...Array(12)].map((_, i) \u003d\u003e (\\n                    \u003cdiv \\n                      key\u003d{i} \\n                      className\u003d\\\"w-1.5 bg-cyan-500 rounded-full animate-[bounce_1s_infinite]\\\" \\n                      style\u003d{{ animationDelay: `${i * 0.1}s`, height: `${Math.random() * 100}%` }}\\n                    /\u003e\\n                  ))}\\n                \u003c/div\u003e\\n              )}\\n            \u003c/div\u003e\\n\\n            {/* Interaction Bar */}\\n            \u003cdiv className\u003d\\\"flex justify-center\\\"\u003e\\n              \u003cbutton \\n                onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                disabled\u003d{!isLecturing}\\n                className\u003d{`flex items-center gap-4 px-10 py-6 rounded-[2rem] font-bold text-xl transition-all border-4 disabled:opacity-30 disabled:grayscale ${\\n                  isQuestioning \\n                  ? \u0027bg-amber-500 text-white border-amber-400 scale-110 shadow-2xl shadow-amber-500/40\u0027 \\n                  : \u0027bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-transparent hover:border-cyan-500/50\u0027\\n                }`}\\n              \u003e\\n                {isQuestioning ? \u003cMic className\u003d\\\"w-8 h-8\\\" /\u003e : \u003cHand className\u003d\\\"w-8 h-8\\\" /\u003e}\\n                {isQuestioning ? \u0027STUDENT SPEAKING...\u0027 : \u0027I HAVE A QUESTION\u0027}\\n              \u003c/button\u003e\\n            \u003c/div\u003e\\n          \u003c/div\u003e\\n        \u003c/main\u003e\\n      \u003c/div\u003e\\n\\n      {/* Done Indicator */}\\n      \u003cdiv className\u003d\\\"fixed bottom-6 right-6\\\"\u003e\\n          \u003cbutton \\n            onClick\u003d{() \u003d\u003e markDone(\u00271\u0027)}\\n            className\u003d\\\"flex items-center gap-2 bg-emerald-500 text-white px-6 py-3 rounded-full font-bold shadow-lg hover:bg-emerald-600 transition-all\\\"\\n          \u003e\\n            \u003cCheckCircle className\u003d\\\"w-5 h-5\\\" /\u003e ISSUE DONE\\n          \u003c/button\u003e\\n      \u003c/div\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default App;\\n\"}]},{\"path\":\"components/Syllabus.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"New Syllabus sidebar component to navigate course topics and track completion status.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React from \u0027react\u0027;\\nimport { CourseTopic } from \u0027../types\u0027;\\nimport { BookOpen, CheckCircle, Circle, Clock } from \u0027lucide-react\u0027;\\n\\ninterface SyllabusProps {\\n  topics: CourseTopic[];\\n  currentId: string;\\n  onSelect: (topic: CourseTopic) \u003d\u003e void;\\n  onDone: (id: string) \u003d\u003e void;\\n}\\n\\nconst Syllabus: React.FC\u003cSyllabusProps\u003e \u003d ({ topics, currentId, onSelect, onDone }) \u003d\u003e {\\n  return (\\n    \u003caside className\u003d\\\"w-72 border-r border-slate-200 dark:border-white/10 bg-white/50 dark:bg-slate-950/50 backdrop-blur-md flex flex-col\\\"\u003e\\n      \u003cdiv className\u003d\\\"p-6 border-b border-slate-200 dark:border-white/10\\\"\u003e\\n        \u003ch3 className\u003d\\\"text-xs font-bold text-slate-400 uppercase tracking-[0.2em] flex items-center gap-2\\\"\u003e\\n          \u003cBookOpen className\u003d\\\"w-4 h-4\\\" /\u003e Course Syllabus\\n        \u003c/h3\u003e\\n      \u003c/div\u003e\\n      \u003cdiv className\u003d\\\"flex-1 overflow-y-auto p-4 space-y-2\\\"\u003e\\n        {topics.map((topic) \u003d\u003e (\\n          \u003cdiv \\n            key\u003d{topic.id}\\n            onClick\u003d{() \u003d\u003e onSelect(topic)}\\n            className\u003d{`group p-4 rounded-2xl cursor-pointer transition-all border ${\\n              currentId \u003d\u003d\u003d topic.id \\n              ? \u0027bg-cyan-600 text-white border-cyan-500 shadow-lg shadow-cyan-600/20\u0027 \\n              : \u0027hover:bg-slate-100 dark:hover:bg-slate-800/50 border-transparent text-slate-600 dark:text-slate-400\u0027\\n            }`}\\n          \u003e\\n            \u003cdiv className\u003d\\\"flex items-start justify-between\\\"\u003e\\n              \u003cspan className\u003d{`text-[10px] font-bold uppercase tracking-widest ${currentId \u003d\u003d\u003d topic.id ? \u0027text-cyan-200\u0027 : \u0027text-cyan-600 dark:text-cyan-400\u0027}`}\u003e\\n                {topic.subject}\\n              \u003c/span\u003e\\n              {topic.isCompleted ? (\\n                \u003cCheckCircle className\u003d\\\"w-4 h-4 text-emerald-400\\\" /\u003e\\n              ) : (\\n                \u003cCircle className\u003d\\\"w-4 h-4 opacity-20\\\" /\u003e\\n              )}\\n            \u003c/div\u003e\\n            \u003ch4 className\u003d\\\"font-display font-bold mt-1 text-sm leading-tight\\\"\u003e{topic.title}\u003c/h4\u003e\\n            \u003cdiv className\u003d\\\"flex items-center gap-2 mt-3 opacity-60 text-[10px] font-bold\\\"\u003e\\n              \u003cClock className\u003d\\\"w-3 h-3\\\" /\u003e {topic.duration}\\n            \u003c/div\u003e\\n          \u003c/div\u003e\\n        ))}\\n      \u003c/div\u003e\\n      \u003cdiv className\u003d\\\"p-6 border-t border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-slate-900/30\\\"\u003e\\n          \u003cdiv className\u003d\\\"flex items-center justify-between text-xs font-bold text-slate-400\\\"\u003e\\n            \u003cspan\u003eOverall Progress\u003c/span\u003e\\n            \u003cspan\u003e33%\u003c/span\u003e\\n          \u003c/div\u003e\\n          \u003cdiv className\u003d\\\"w-full h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full mt-2 overflow-hidden\\\"\u003e\\n            \u003cdiv className\u003d\\\"w-1/3 h-full bg-cyan-500 rounded-full\\\"\u003e\u003c/div\u003e\\n          \u003c/div\u003e\\n      \u003c/div\u003e\\n    \u003c/aside\u003e\\n  );\\n};\\n\\nexport default Syllabus;\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767865659,\"nanos\":575000000},\"doneTimestamp\":{\"seconds\":1767865660,\"nanos\":313000000}},{\"id\":193,\"author\":\"model\",\"payload\":{\"type\":\"text\",\"text\":\"\\n\\nThe application is now a **Virtual Lecture Hall**. It uses the **Gemini Live API** to act as a verbal professor.\\n\\n**Key Interactions**:\\n- **Start Lecture**: Initiates the Live audio session. The AI begins speaking immediately based on the selected topic.\\n- **The Whiteboard**: As the AI speaks, it will use the `render_visual` tool to generate and update infographics that match its verbal explanation.\\n- **I Have a Question**: Toggling this \\\"raises your hand,\\\" un-muting your mic so you can interrupt the lecture with spoken questions.\\n- **Syllabus Sidebar**: Keeps track of modules, their durations, and completion status.\\n- **Issue Done**: Once satisfied with the learning session, clicking the completion button marks the topic as finished in your curriculum.\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865693,\"nanos\":713000000},\"doneTimestamp\":{\"seconds\":1767865693,\"nanos\":875000000}},{\"id\":194,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"When an infographic is generated, allow users to regenerate it with different visual styles (e.g., minimalist, realistic, cartoon) and complexity levels.\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865773,\"nanos\":721000000}},{\"id\":195,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Exploring Regeneration Options**\\n\\nI\u0027m currently focused on adding the ability to regenerate infographics with altered visual styles and complexity. The `Infographic` component, which already displays generated images and has an \\\"Edit Bar\\\" for visual refinement, is the target. I\u0027m exploring how to best integrate this regeneration functionality.\\n\\n\\n**Adding Regeneration Functionality**\\n\\nI\u0027m now implementing the regeneration logic. I\u0027ve decided to add a `handleRegenerate` function in `App.tsx` and am moving on to updating the `Infographic` component. It will now include dropdowns for `ComplexityLevel` and `VisualStyle` in an expandable UI section above the edit bar, as well as a \\\"Regenerate\\\" button. Existing code will not be changed.\\n\\n\\n**Integrating Regeneration Controls**\\n\\nI\u0027m now putting the pieces together for the regeneration process. I\u0027m adding a `handleRegenerate` function that triggers a fresh research and image generation cycle, incorporating new parameters. This will refresh the `IMAGE_PROMPT` for the new style or complexity levels. Also, I will use `RefreshCcw`, `Palette`, and `Layers` Lucide icons and am now considering the best placement for the new \\\"Curriculum Controls\\\" panel within the `Infographic` component layout. The existing type definitions and service calls are being reviewed.\\n\\n\\n**Refining Infographic Props**\\n\\nI\u0027m now refining the props interface for the Infographic component to support regeneration. I\u0027ve added an `onRegenerate` handler, to be called from the new \\\"Regeneration Panel\\\". I\u0027m also planning to create the `RegenerationPanel` inside `Infographic.tsx` for visual style and complexity level selection and a \\\"Regenerate\\\" button. The existing `InfographicProps` interface will be updated to include the new function, and the new UI.\\n\\n\\n**Incorporating Regeneration Logic**\\n\\nI\u0027m now integrating regeneration into the UI. I will populate the image metadata with relevant information during generation. The `handleRegenerate` function will update `imageHistory`, maintaining the topic but modifying parameters. I\u0027ll add a \\\"Refine Lesson\\\" header above controls in `Infographic.tsx`, with local state for dropdowns and a \\\"Regenerate\\\" button. The new `handleRegenerate` function will refresh research and generate a new image, which should result in a good user experience. I will pass the handler to the `Infographic` component.\\n\\n\\n**Integrating User Controls**\\n\\nI\u0027m now focusing on the user interface for style and level adjustments. I\u0027m going to integrate \\\"Adjust Level \u0026 Style\\\" controls into a prominent \\\"Enhance\\\" bar within the infographic. I\u0027ve decided to include dropdowns for complexity levels and visual styles, using a clean, modern design. I\u0027ll make sure the \\\"Issue Done\\\" button is functional, marking progress.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865773,\"nanos\":721000000},\"doneTimestamp\":{\"seconds\":1767865789,\"nanos\":165000000}},{\"id\":196,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Implemented handleRegenerate function to allow re-creating infographics with updated complexity and style parameters. Passed this function to the Infographic component.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SearchResultItem, SubjectArea, CourseTopic } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage, researchTopicForPrompt } from \u0027./services/geminiService\u0027;\\nimport { decodeBase64, decodeAudioData, createPcmBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport Loading from \u0027./components/Loading\u0027;\\nimport { GraduationCap, Sun, Moon, Key, Mic, MicOff, Hand, Play, Square, CheckCircle, Clock, Zap } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [subject, setSubject] \u003d useState\u003cSubjectArea\u003e(\u0027STEM\u0027);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027Quantum Physics Basics\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Default\u0027);\\n  const [language, setLanguage] \u003d useState\u003cLanguage\u003e(\u0027English\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [isLoading, setIsLoading] \u003d useState(false);\\n  const [loadingMessage, setLoadingMessage] \u003d useState(\u0027\u0027);\\n  const [loadingStep, setLoadingStep] \u003d useState\u003cnumber\u003e(0);\\n  const [loadingFacts, setLoadingFacts] \u003d useState\u003cstring[]\u003e([]);\\n  const [error, setError] \u003d useState\u003cstring | null\u003e(null);\\n  \\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [imageHistory, setImageHistory] \u003d useState\u003cGeneratedImage[]\u003e([]);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [hasApiKey, setHasApiKey] \u003d useState(false);\\n  \\n  // Audio State refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const streamRef \u003d useRef\u003cMediaStream | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const nextStartTimeRef \u003d useRef(0);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027Intro to Astrophysics\u0027, duration: \u00271.5 hrs\u0027, isCompleted: false, subject: \u0027STEM\u0027 },\\n    { id: \u00272\u0027, title: \u0027Cellular Biology 101\u0027, duration: \u00272 hrs\u0027, isCompleted: false, subject: \u0027Biology\u0027 },\\n    { id: \u00273\u0027, title: \u0027Thermodynamics\u0027, duration: \u00273 hrs\u0027, isCompleted: false, subject: \u0027Physics\u0027 },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  const toggleLecture \u003d async () \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close();\\n      setIsLecturing(false);\\n      return;\\n    }\\n\\n    try {\\n      if (!audioContextRef.current) {\\n        audioContextRef.current \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      }\\n      \\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      streamRef.current \u003d stream;\\n      \\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          console.log(\\\"Lecture session opened\\\");\\n          const inputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n          const source \u003d inputCtx.createMediaStreamSource(stream);\\n          const scriptProcessor \u003d inputCtx.createScriptProcessor(4096, 1, 1);\\n          \\n          scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n            if (!isQuestioning) return; \\n            const inputData \u003d e.inputBuffer.getChannelData(0);\\n            const pcmBlob \u003d createPcmBlob(inputData);\\n            sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n          };\\n          \\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(inputCtx.destination);\\n        },\\n        onmessage: async (msg: any) \u003d\u003e {\\n          const base64Audio \u003d msg.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 audioContextRef.current) {\\n            const ctx \u003d audioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decodeBase64(base64Audio), ctx, 24000, 1);\\n            const source \u003d ctx.createBufferSource();\\n            source.buffer \u003d audioBuffer;\\n            source.connect(ctx.destination);\\n            source.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(source);\\n            source.onended \u003d () \u003d\u003e sourcesRef.current.delete(source);\\n          }\\n\\n          if (msg.toolCall) {\\n            for (const fc of msg.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                const imgData \u003d await generateInfographicImage(fc.args.description);\\n                const newSlide \u003d {\\n                  id: Date.now().toString(),\\n                  data: imgData,\\n                  prompt: fc.args.description,\\n                  timestamp: Date.now(),\\n                  subject: subject,\\n                  level: complexityLevel,\\n                  style: visualStyle\\n                };\\n                setCurrentSlide(newSlide);\\n                setImageHistory(prev \u003d\u003e [newSlide, ...prev]);\\n                sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                  functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Slide updated successfully\\\" } }\\n                }));\\n              }\\n            }\\n          }\\n\\n          if (msg.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n        },\\n        onclose: () \u003d\u003e setIsLecturing(false),\\n        onerror: (e: any) \u003d\u003e console.error(\\\"Session Error:\\\", e),\\n      }, subject, currentTopic);\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n    } catch (err) {\\n      console.error(\\\"Failed to start lecture:\\\", err);\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setIsLoading(true);\\n    setError(null);\\n    setLoadingStep(1);\\n    setLoadingMessage(`Updating Lesson: ${level} level in ${style} style...`);\\n\\n    try {\\n      const topicToUse \u003d currentTopic;\\n      const researchResult \u003d await researchTopicForPrompt(topicToUse, level, style, language, subject);\\n      \\n      setLoadingFacts(researchResult.facts);\\n      setLoadingStep(2);\\n      setLoadingMessage(`Rendering New Visual...`);\\n      \\n      const base64Data \u003d await generateInfographicImage(researchResult.imagePrompt);\\n      \\n      const newImage: GeneratedImage \u003d {\\n        id: Date.now().toString(),\\n        data: base64Data,\\n        prompt: researchResult.imagePrompt,\\n        timestamp: Date.now(),\\n        level: level,\\n        style: style,\\n        language: language,\\n        subject: subject\\n      };\\n\\n      setCurrentSlide(newImage);\\n      setImageHistory(prev \u003d\u003e [newImage, ...prev]);\\n    } catch (err: any) {\\n      console.error(err);\\n      setError(\u0027Visual regeneration failed. Academy systems are busy.\u0027);\\n    } finally {\\n      setIsLoading(false);\\n      setLoadingStep(0);\\n    }\\n  };\\n\\n  const markDone \u003d (id: string) \u003d\u003e {\\n    setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d id ? { ...t, isCompleted: true } : t));\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 flex flex-col transition-colors\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} /\u003e}\\n      \\n      \u003cheader className\u003d\\\"h-16 border-b border-slate-200 dark:border-white/10 flex items-center justify-between px-6 backdrop-blur-md sticky top-0 z-50\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n          \u003cGraduationCap className\u003d\\\"text-cyan-600 w-8 h-8\\\" /\u003e\\n          \u003ch1 className\u003d\\\"font-display font-bold text-xl tracking-tight text-slate-900 dark:text-white\\\"\u003eAlpha \u003cspan className\u003d\\\"text-cyan-600\\\"\u003eLecturer\u003c/span\u003e\u003c/h1\u003e\\n        \u003c/div\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-4\\\"\u003e\\n          \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"p-2 hover:bg-slate-200 dark:hover:bg-slate-800 rounded-full transition-colors\\\"\u003e\\n            {isDarkMode ? \u003cSun className\u003d\\\"w-5 h-5\\\" /\u003e : \u003cMoon className\u003d\\\"w-5 h-5\\\" /\u003e}\\n          \u003c/button\u003e\\n        \u003c/div\u003e\\n      \u003c/header\u003e\\n\\n      \u003cdiv className\u003d\\\"flex-1 flex overflow-hidden\\\"\u003e\\n        \u003cSyllabus topics\u003d{topics} currentId\u003d{topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic)?.id || \u0027\u0027} onSelect\u003d{(t) \u003d\u003e setCurrentTopic(t.title)} onDone\u003d{markDone} /\u003e\\n\\n        \u003cmain className\u003d\\\"flex-1 p-8 overflow-y-auto relative bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-950 dark:to-black\\\"\u003e\\n          \u003cdiv className\u003d\\\"max-w-5xl mx-auto space-y-8 pb-12\\\"\u003e\\n            \u003cdiv className\u003d\\\"flex flex-col md:flex-row items-start md:items-center justify-between gap-4\\\"\u003e\\n              \u003cdiv\u003e\\n                \u003ch2 className\u003d\\\"text-3xl font-display font-bold text-slate-800 dark:text-white\\\"\u003e{currentTopic}\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-500 dark:text-slate-400 flex items-center gap-2 mt-1\\\"\u003e\\n                  \u003cClock className\u003d\\\"w-4 h-4\\\" /\u003e Curriculum-aligned session\\n                \u003c/p\u003e\\n              \u003c/div\u003e\\n              \u003cbutton \\n                onClick\u003d{toggleLecture}\\n                className\u003d{`flex items-center gap-3 px-8 py-4 rounded-2xl font-bold transition-all shadow-xl ${\\n                  isLecturing \\n                  ? \u0027bg-red-500 text-white hover:bg-red-600\u0027 \\n                  : \u0027bg-cyan-600 text-white hover:bg-cyan-500 shadow-cyan-500/20\u0027\\n                }`}\\n              \u003e\\n                {isLecturing ? \u003cSquare className\u003d\\\"w-5 h-5 fill-current\\\" /\u003e : \u003cPlay className\u003d\\\"w-5 h-5 fill-current\\\" /\u003e}\\n                {isLecturing ? \u0027STOP LECTURE\u0027 : \u0027START LECTURE\u0027}\\n              \u003c/button\u003e\\n            \u003c/div\u003e\\n\\n            {isLoading ? (\\n                \u003cLoading status\u003d{loadingMessage} step\u003d{loadingStep} facts\u003d{loadingFacts} /\u003e\\n            ) : (\\n                \u003c\u003e\\n                {currentSlide ? (\\n                    \u003cInfographic \\n                        image\u003d{currentSlide} \\n                        onEdit\u003d{(p) \u003d\u003e console.log(\u0027Edit\u0027, p)} // Logic can be added if needed\\n                        onRegenerate\u003d{handleRegenerate}\\n                        isEditing\u003d{isLoading}\\n                    /\u003e\\n                ) : (\\n                    \u003cdiv className\u003d\\\"aspect-video w-full bg-white dark:bg-slate-900 rounded-[2.5rem] border border-slate-200 dark:border-white/5 shadow-inner overflow-hidden flex items-center justify-center relative group\\\"\u003e\\n                        \u003cdiv className\u003d\\\"flex flex-col items-center gap-4 opacity-20 group-hover:opacity-40 transition-opacity\\\"\u003e\\n                            \u003cdiv className\u003d\\\"w-24 h-24 border-4 border-dashed border-slate-400 dark:border-slate-500 rounded-3xl animate-[spin_20s_linear_infinite]\\\"\u003e\u003c/div\u003e\\n                            \u003cspan className\u003d\\\"font-display font-bold text-xl uppercase tracking-widest text-slate-500\\\"\u003eThe Whiteboard\u003c/span\u003e\\n                        \u003c/div\u003e\\n                        {isLecturing \u0026\u0026 (\\n                            \u003cdiv className\u003d\\\"absolute bottom-10 left-1/2 -translate-x-1/2 flex items-end gap-1 h-8\\\"\u003e\\n                            {[...Array(12)].map((_, i) \u003d\u003e (\\n                                \u003cdiv \\n                                key\u003d{i} \\n                                className\u003d\\\"w-1.5 bg-cyan-500 rounded-full animate-[bounce_1s_infinite]\\\" \\n                                style\u003d{{ animationDelay: `${i * 0.1}s`, height: `${Math.random() * 100}%` }}\\n                                /\u003e\\n                            ))}\\n                            \u003c/div\u003e\\n                        )}\\n                    \u003c/div\u003e\\n                )}\\n                \u003c/\u003e\\n            )}\\n\\n            {isLecturing \u0026\u0026 !isLoading \u0026\u0026 (\\n                \u003cdiv className\u003d\\\"flex justify-center\\\"\u003e\\n                \u003cbutton \\n                    onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                    className\u003d{`flex items-center gap-4 px-10 py-6 rounded-[2rem] font-bold text-xl transition-all border-4 ${\\n                    isQuestioning \\n                    ? \u0027bg-amber-500 text-white border-amber-400 scale-110 shadow-2xl shadow-amber-500/40\u0027 \\n                    : \u0027bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-transparent hover:border-cyan-500/50\u0027\\n                    }`}\\n                \u003e\\n                    {isQuestioning ? \u003cMic className\u003d\\\"w-8 h-8\\\" /\u003e : \u003cHand className\u003d\\\"w-8 h-8\\\" /\u003e}\\n                    {isQuestioning ? \u0027STUDENT SPEAKING...\u0027 : \u0027I HAVE A QUESTION\u0027}\\n                \u003c/button\u003e\\n                \u003c/div\u003e\\n            )}\\n          \u003c/div\u003e\\n     