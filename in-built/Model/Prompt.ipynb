3c/div\u003e\\n                  \u003cbutton \\n                    onClick\u003d{startVoiceInput}\\n                    className\u003d{`p-3.5 rounded-2xl shadow-lg ${isListening ? \u0027bg-red-500 text-white animate-pulse\u0027 : \u0027bg-white dark:bg-slate-800 text-slate-400 border border-slate-200 dark:border-white/10\u0027}`}\\n                  \u003e\\n                    \u003cMic className\u003d\\\"w-5 h-5\\\" /\u003e\\n                  \u003c/button\u003e\\n               \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            \u003cdiv className\u003d\\\"space-y-3\\\"\u003e\\n              \u003clabel className\u003d\\\"text-[9px] font-bold text-slate-400 uppercase tracking-widest ml-1\\\"\u003eCurriculum Registry\u003c/label\u003e\\n              \u003cdiv className\u003d\\\"space-y-2\\\"\u003e\\n                {topics.map((topic) \u003d\u003e (\\n                  \u003cbutton\\n                    key\u003d{topic.id}\\n                    disabled\u003d{topic.isLocked}\\n                    onClick\u003d{() \u003d\u003e onSelect(topic)}\\n                    className\u003d{`w-full text-left p-4 rounded-2xl transition-all border flex items-center justify-between gap-3 ${\\n                      topic.isLocked \\n                      ? \u0027bg-slate-50/50 dark:bg-slate-900/50 opacity-40 cursor-not-allowed\u0027\\n                      : currentId \u003d\u003d\u003d topic.id \\n                        ? \u0027bg-cyan-600/5 border-cyan-500/40\u0027 \\n                        : \u0027bg-transparent border-transparent hover:bg-slate-50 dark:hover:bg-slate-900\u0027\\n                    }`}\\n                  \u003e\\n                    \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n                      \u003ch4 className\u003d{`text-xs font-bold ${currentId \u003d\u003d\u003d topic.id ? \u0027text-cyan-700 dark:text-cyan-300\u0027 : \u0027text-slate-600 dark:text-slate-400\u0027}`}\u003e\\n                        {topic.title}\\n                      \u003c/h4\u003e\\n                    \u003c/div\u003e\\n                    {topic.isLocked ? (\\n                      \u003cLock className\u003d\\\"w-3.5 h-3.5 text-slate-400\\\" /\u003e\\n                    ) : topic.isCompleted ? (\\n                      \u003cCheckCircle className\u003d\\\"w-3.5 h-3.5 text-emerald-500\\\" /\u003e\\n                    ) : (\\n                      \u003cCircle className\u003d\\\"w-3.5 h-3.5 opacity-10\\\" /\u003e\\n                    )}\\n                  \u003c/button\u003e\\n                ))}\\n              \u003c/div\u003e\\n            \u003c/div\u003e\\n          \u003c/\u003e\\n        )}\\n      \u003c/div\u003e\\n\\n      \u003cdiv className\u003d\\\"p-8 border-t border-slate-200 dark:border-white/10 space-y-5 bg-slate-50/50 dark:bg-slate-900/10\\\"\u003e\\n        {student \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"flex gap-3\\\"\u003e\\n             \u003cbutton \\n                onClick\u003d{() \u003d\u003e toggleLecture(false)}\\n                className\u003d{`flex-1 py-4 rounded-2xl font-bold text-xs flex items-center justify-center gap-3 shadow-2xl transition-all ${\\n                    isLecturing \u0026\u0026 !isExamMode\\n                    ? \u0027bg-red-500 text-white\u0027 \\n                    : \u0027bg-cyan-600 text-white hover:bg-cyan-500 shadow-cyan-600/20\u0027\\n                }`}\\n            \u003e\\n                {isLecturing \u0026\u0026 !isExamMode ? \u003cSquare className\u003d\\\"w-3.5 h-3.5 fill-current\\\" /\u003e : \u003cPlay className\u003d\\\"w-3.5 h-3.5 fill-current\\\" /\u003e}\\n                {isLecturing \u0026\u0026 !isExamMode ? \u0027STOP\u0027 : \u0027STUDY\u0027}\\n            \u003c/button\u003e\\n            \u003cbutton onClick\u003d{onDone} disabled\u003d{!isLecturing} className\u003d\\\"px-5 py-4 rounded-2xl border-2 border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 font-bold text-xs disa