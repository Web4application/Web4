h-32 bg-slate-50 dark:bg-slate-950/50 border border-slate-200 dark:border-white/5 rounded-2xl p-4 text-sm font-medium focus:ring-2 ring-cyan-500 transition-all outline-none resize-none\\\"\\n                  placeholder\u003d\\\"Modify the image prompt here...\\\"\\n               /\u003e\\n               \u003cdiv className\u003d\\\"flex justify-end gap-3\\\"\u003e\\n                  \u003cbutton \\n                    type\u003d\\\"button\\\"\\n                    onClick\u003d{() \u003d\u003e setIsEditMode(false)}\\n                    className\u003d\\\"px-6 py-3 text-xs font-bold text-slate-500 uppercase tracking-widest hover:text-slate-900 dark:hover:text-white transition-colors\\\"\\n                  \u003e\\n                    Discard Changes\\n                  \u003c/button\u003e\\n                  \u003cbutton \\n                    type\u003d\\\"submit\\\"\\n                    className\u003d\\\"px-8 py-3 bg-cyan-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest shadow-lg shadow-cyan-600/20 flex items-center gap-2 hover:bg-cyan-500 transition-all\\\"\\n                  \u003e\\n                    \u003cSave className\u003d\\\"w-4 h-4\\\" /\u003e\\n                    Apply \u0026 Regenerate\\n                  \u003c/button\u003e\\n               \u003c/div\u003e\\n            \u003c/form\u003e\\n          \u003c/div\u003e\\n        ) : (\\n          \u003cdiv className\u003d\\\"flex flex-col gap-3\\\"\u003e\\n             {/* Integrated Control Panel */}\\n             \u003cdiv className\u003d\\\"bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl p-5 rounded-[2.5rem] shadow-2xl border border-slate-200 dark:border-white/10 flex flex-col gap-6\\\"\u003e\\n                \\n                \u003cdiv className\u003d\\\"grid grid-cols-1 lg:grid-cols-2 gap-8\\\"\u003e\\n                  {/* Visual Style Selection */}\\n                  \u003cdiv className\u003d\\\"space-y-3\\\"\u003e\\n                    \u003cdiv className\u00