leApplyModifiedPrompt \u003d (e: React.FormEvent) \u003d\u003e {\\n    e.preventDefault();\\n    if (!modifiedPrompt.trim()) return;\\n    onEdit(modifiedPrompt);\\n    setIsEditMode(false);\\n  };\\n\\n  const handleRegenerateClick \u003d () \u003d\u003e {\\n    onRegenerate(selectedLevel, selectedStyle);\\n  };\\n\\n  const handleZoomIn \u003d () \u003d\u003e setZoomLevel(prev \u003d\u003e Math.min(prev + 0.5, 4));\\n  const handleZoomOut \u003d () \u003d\u003e setZoomLevel(prev \u003d\u003e Math.max(prev - 0.5, 0.5));\\n  const handleResetZoom \u003d () \u003d\u003e setZoomLevel(1);\\n\\n  const complexities: ComplexityLevel[] \u003d [\u0027Elementary\u0027, \u0027High School\u0027, \u0027College\u0027, \u0027Expert\u0027];\\n  const styles: VisualStyle[] \u003d [\u0027Minimalist\u0027, \u0027Realistic\u0027, \u0027Cartoon\u0027, \u0027Futuristic\u0027];\\n\\n  // Helper to create a sanitized filename from the prompt\\n  const getDynamicFilename \u003d () \u003d\u003e {\\n    const sanitizedPrompt \u003d image.prompt\\n      .toLowerCase()\\n      .replace(/[^a-z0-9]/g, \u0027-\u0027)\\n      .split(\u0027-\u0027)\\n      .filter(Boolean)\\n      .slice(0, 5)\\n      .join(\u0027-\u0027);\\n    return `vision-${sanitizedPrompt || \u0027visual\u0027}-${image.id}.png`;\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"flex flex-col items-center w-full max-w-6xl mx-auto animate-in fade-in zoom-in duration-700\\\"\u003e\\n      \\n      {/* Image Container */}\\n      \u003cdiv className\u003d\\\"relative group w-full bg-slate-100 dark:bg-slate-900 rounded-[2.5rem] overflow-hidden shadow-2xl border border-slate-200 dark:border-white/5\\\"\u003e\\n        \u003cdiv className\u003d\\\"absolute top-0 left-0 w-16 h-16 border-t-2 border-l-2 border-cyan-500/30 rounded-tl-[2.5rem] z-20 pointer-events-none\\\"\u003e\u003c/div\u003e\\n        \u003cdiv className\u003d\\\"absolute top-0 right-0 w-16 h-16 border-t-2 border-r-2 border-cyan-500/30 rounded-tr-[2.5rem] z-20