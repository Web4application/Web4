\u003c/div\u003e\\n    )}\\n\\n    {showIntro ? (\\n      \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} /\u003e\\n    ) : (\\n    \u003cdiv className\u003d\\\"min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans selection:bg-cyan-500 pb-20 transition-colors\\\"\u003e\\n      \u003cdiv className\u003d\\\"fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-50 via-slate-50 to-white dark:from-slate-900/40 dark:via-slate-950 dark:to-black z-0\\\"\u003e\u003c/div\u003e\\n\\n      \u003cheader className\u003d\\\"border-b border-slate-200 dark:border-white/10 sticky top-0 z-50 backdrop-blur-md bg-white/70 dark:bg-slate-950/60\\\"\u003e\\n        \u003cdiv className\u003d\\\"max-w-7xl mx-auto px-4 h-16 md:h-20 flex items-center justify-between\\\"\u003e\\n          \u003cdiv className\u003d\\\"flex items-center gap-4\\\"\u003e\\n            \u003cdiv className\u003d\\\"bg-cyan-600 p-2 rounded-lg shadow-lg shadow-cyan-500/20\\\"\u003e\\n              \u003cGraduationCap className\u003d\\\"w-6 h-6 text-white\\\" /\u003e\\n            \u003c/div\u003e\\n            \u003cdiv className\u003d\\\"flex flex-col\\\"\u003e\\n              \u003cspan className\u003d\\\"font-display font-bold text-xl md:text-2xl text-slate-900 dark:text-white\\\"\u003e\\n                InfoGenius \u003cspan className\u003d\\\"text-cyan-600 dark:text-cyan-400\\\"\u003eAcademy\u003c/span\u003e\\n              \u003c/span\u003e\\n              \u003cspan className\u003d\\\"text-[10px] uppercase tracking-widest text-slate-500 font-bold\\\"\u003eVisual Subject Tutor\u003c/span\u003e\\n            \u003c/div\u003e\\n          \u003c/div\u003e\\n\\n          \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n              \u003cbutton onClick\u003d{handleSelectKey} className\u003d\\\"hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-white/10 text-xs font-b