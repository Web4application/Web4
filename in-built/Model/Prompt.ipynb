 disabled\u003d{!isLecturing}\\n                className\u003d\\\"flex-1 py-4 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 font-bold text-xs flex items-center justify-center gap-2 hover:bg-slate-50 transition-all disabled:opacity-20\\\"\\n            \u003e\\n                \u003cAward className\u003d\\\"w-3 h-3\\\" /\u003e Done\\n            \u003c/button\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        {allTopicsDone \u0026\u0026 student \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"p-4 bg-emerald-500/10 border border-emerald-500/30 rounded-2xl animate-in zoom-in duration-500\\\"\u003e\\n             \u003cp className\u003d\\\"text-[10px] text-emerald-600 dark:text-emerald-400 font-bold uppercase text-center mb-3\\\"\u003eScheme Complete\u003c/p\u003e\\n             \u003cbutton \\n                onClick\u003d{() \u003d\u003e isExamMode ? onPromote() : toggleLecture(true)}\\n                className\u003d\\\"w-full py-3 bg-emerald-500 text-white rounded-xl font-bold text-xs flex items-center justify-center gap-2 hover:bg-emerald-400 transition-all\\\"\\n             \u003e\\n                \u003cGraduationCap className\u003d\\\"w-4 h-4\\\" /\u003e\\n                {isExamMode ? \u0027SUBMIT EXAM\u0027 : \u0027START FINAL EXAM\u0027}\\n             \u003c/button\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        \u003cdiv className\u003d\\\"text-center\\\"\u003e\\n            \u003cp className\u003d\\\"text-[8px] text-slate-400 uppercase tracking-widest\\\"\u003eUniversity of Infogenius v4.0\u003c/p\u003e\\n        \u003c/div\u003e\\n      \u003c/div\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default Syllabus;\\n\"}]},{\"path\":\"services/geminiService.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Updated connectLecturer to handle Exam Mode instructions, enabling Gemini to act as an examiner for student promotion.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport { GoogleGenAI, FunctionDeclaration, Modality, Type } from \\\"@google/genai\\\";\\nimport { ComplexityLevel, VisualStyle, ResearchResult, SearchResultItem, Language, SubjectArea } from \\\"../types\\\";\\n\\nconst getAi \u003d () \u003d\u003e {\\n  return new GoogleGenAI({ apiKey: process.env.API_KEY });\\n};\\n\\nconst TEXT_MODEL \u003d \u0027gemini-3-pro-preview\u0027;\\nconst IMAGE_MODEL \u003d \u0027gemini-3-pro-image-preview\u0027;\\n\\n/**\\n * Establishes a real-time speech-to-speech lecture or exam session.\\n */\\nexport const connectLecturer \u003d (\\n  callbacks: any,\\n  subject: string,\\n  topic: string\\n) \u003d\u003e {\\n  const ai \u003d getAi();\\n  const isExam \u003d topic.includes(\\\"FINAL EXAM\\\");\\n  \\n  const renderVisualTool: FunctionDeclaration \u003d {\\n    name: \u0027render_visual\u0027,\\n    parameters: {\\n      type: Type.OBJECT,\\n      description: \u0027Generate and render a detailed educational visual or infographic to clarify complex concepts.\u0027,\\n      properties: {\\n        description: {\\n          type: Type.STRING,\\n          description: \u0027A detailed, vivid description of the visual to be rendered.\u0027\\n        }\\n      },\\n      required: [\u0027description\u0027]\\n    }\\n  };\\n\\n  const instruction \u003d isExam \\n    ? `You are Professor Alpha, an academic examiner. The student is taking their final exam for \\\"${topic}\\\".\\n       1. Ask 3-5 challenging questions verbally about the core concepts.\\n       2. Listen to the student\u0027s spoken responses.\\n       3. Provide immediate verbal feedback on their answers.\\n       4. If they answer correctly, use \u0027render_visual\u0027 to show a \u0027Certificate of Achievement\u0027 or an advanced diagram related to the success.\\n       5. Maintain a professional, encouraging mentor persona.`\\n    : `You are Professor Alpha, a world-class lecturer in ${subject}. \\n       Explain \\\"${topic}\\\" deeply using voice. \\n       Use \u0027render_visual\u0027 frequently to update the student\u0027s visual aids with descriptive infographics.\\n       If the student interrupts with a question, pause your lecture and address them as a friendly mentor.\\n       Your goal is for them to master the content so they can pass their promotion exam later.`;\\n\\n  return ai.live.connect({\\n    model: \u0027gemini-2.5-flash-native-audio-preview-12-2025\u0027,\\n    callbacks,\\n    config: {\\n      responseModalities: [Modality.AUDIO],\\n      systemInstruction: instruction,\\n      tools: [{ functionDeclarations: [renderVisualTool] }],\\n      speechConfig: {\\n        voiceConfig: { prebuiltVoiceConfig: { voiceName: \u0027Charon\u0027 } }\\n      }\\n    }\\n  });\\n};\\n\\nexport const researchTopicForPrompt \u003d async (\\n  topic: string, \\n  level: ComplexityLevel, \\n  style: VisualStyle,\\n  language: Language,\\n  subject: SubjectArea \u003d \u0027General\u0027\\n): Promise\u003cResearchResult\u003e \u003d\u003e {\\n  const ai \u003d getAi();\\n  const response \u003d await ai.models.generateContent({\\n    model: TEXT_MODEL,\\n    contents: `Research the topic \\\"${topic}\\\" for a ${level} level lecture in ${subject}. Provide 5 facts and an image prompt for a ${style} infographic.`,\\n    config: { tools: [{ googleSearch: {} }] },\\n  });\\n\\n  const text \u003d response.text || \\\"\\\";\\n  const facts \u003d text.split(\u0027\\\\n\u0027).filter(l \u003d\u003e l.includes(\u0027-\u0027)).slice(0, 5);\\n  const imagePrompt \u003d `Educational visual about ${topic}, ${style} style, ${level} complexity.`;\\n\\n  const searchResults: SearchResultItem[] \u003d [];\\n  response.candidates?.[0]?.groundingMetadata?.groundingChunks?.forEach(chunk \u003d\u003e {\\n    if (chunk.web?.uri \u0026\u0026 chunk.web?.title) {\\n      searchResults.push({ title: chunk.web.title, url: chunk.web.uri });\\n    }\\n  });\\n\\n  return { imagePrompt, facts, searchResults };\\n};\\n\\nexport const generateInfographicImage \u003d async (prompt: string): Promise\u003cstring\u003e \u003d\u003e {\\n  const response \u003d await getAi().models.generateContent({\\n    model: IMAGE_MODEL,\\n    contents: { parts: [{ text: prompt }] },\\n    config: { imageConfig: { aspectRatio: \\\"16:9\\\", imageSize: \\\"1K\\\" } }\\n  });\\n\\n  const parts \u003d response.candidates?.[0]?.content?.parts || [];\\n  for (const part of parts) {\\n    if (part.inlineData?.data) {\\n      return `data:image/png;base64,${part.inlineData.data}`;\\n    }\\n  }\\n  throw new Error(\\\"Visual generation failed.\\\");\\n};\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767888196,\"nanos\":798000000},\"doneTimestamp\":{\"seconds\":1767888198,\"nanos\":387000000}},{\"id\":209,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"A brief welcome to new users and a warm welcoming back to current user \\nSpeech to speech interaction\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888283,\"nanos\":620000000}},{\"id\":210,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Envisioning Future Enhancements**\\n\\nI\u0027m currently focused on the virtual university application\u0027s enhancements. I\u0027ve been working on a new enrollment process, envisioning students choosing majors and study hours. Progressing beyond the existing implementation, I\u0027m integrating text input and a microphone feature for topic selection, which is partially completed.\\n\\n\\n**Expanding UI Functionality**\\n\\nI\u0027m now integrating exam and promotion mechanics. After the study scheme is complete, tests will automatically promote students. I\u0027m focusing on user-friendliness, developing both new and returning user greetings. Ensuring a seamless speech-to-speech interaction is key, considering the Gemini Live API. I\u0027m balancing the addition of new features like enrollment with the current \\\"clean lecture screen,\\\" and I\u0027m transforming the \\\"Syllabus\\\" into a University Management sidebar to handle enrollment and study details. I plan to manage student and promotion states in `App.tsx` and friendly interactions and enrollment details in `Syllabus.tsx`.\\n\\n\\n**Refining Interaction Flow**\\n\\nI\u0027m currently focused on the user interaction flow. I\u0027m modifying `IntroScreen.tsx` to personalize the welcome message and handle returning students by checking local storage. I\u0027m refining the system instruction in `geminiService.ts` for improved \\\"friendly interaction\\\". I\u0027m also ensuring prominent topic input, both voice and text, within the `Syllabus` component, and double checking promotion triggering in `App.tsx`.\\n\\n\\n**Confirming Feature Placement**\\n\\nI\u0027m now implementing automatic exam issuing based on study scheme completion, incorporating `isExamMode` logic for robustness. I\u0027m also ensuring a personalized welcome message in `IntroScreen.tsx` for returning students and forcing enrollment when `student` is null in `App.tsx`. Refining the `Syllabus` UI for clearer topic selection and scheduling is crucial. I\u0027ve reconfirmed the lecture screen\u0027s \\\"two buttons\\\" rule, planning to keep the controls related to topic selection within the navigator.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888283,\"nanos\":620000000},\"doneTimestamp\":{\"seconds\":1767888294,\"nanos\":174000000}},{\"id\":211,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Refined student enrollment flow, added personalized welcome messages, and ensured automated academic promotion through a friendly AI interaction interface.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SubjectArea, CourseTopic, StudentProfile } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { Sun, Moon, Mic, Hand, Volume2, Menu, X, Award, CheckCircle2, Sparkles } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027The Laws of Motion\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n  const [isExamMode, setIsExamMode] \u003d useState(false);\\n  const [showPromotion, setShowPromotion] \u003d useState(false);\\n\\n  const [student, setStudent] \u003d useState\u003cStudentProfile | null\u003e(() \u003d\u003e {\\n    const saved \u003d localStorage.getItem(\u0027student_profile\u0027);\\n    return saved ? JSON.parse(saved) : null;\\n  });\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const studyTimerRef \u003d useRef\u003cnumber | null\u003e(null);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027The Laws of Motion\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027Physics\u0027 },\\n    { id: \u00272\u0027, title: \u0027Calculus in Engineering\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027 },\\n    { id: \u00273\u0027, title: \u0027Genetics and DNA Analysis\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Biology\u0027 },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (student) {\\n      localStorage.setItem(\u0027student_profile\u0027, JSON.stringify(student));\\n    }\\n  }, [student]);\\n\\n  // Track study hours while lecturing\\n  useEffect(() \u003d\u003e {\\n    if (isLecturing \u0026\u0026 !isExamMode) {\\n      studyTimerRef.current \u003d window.setInterval(() \u003d\u003e {\\n        setStudent(prev \u003d\u003e prev ? { ...prev, currentStudyHours: prev.currentStudyHours + (1/3600) } : null);\\n      }, 1000);\\n    } else {\\n      if (studyTimerRef.current) clearInterval(studyTimerRef.current);\\n    }\\n    return () \u003d\u003e { if (studyTimerRef.current) clearInterval(studyTimerRef.current); };\\n  }, [isLecturing, isExamMode]);\\n\\n  const toggleLecture \u003d async (exam: boolean \u003d false) \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      setIsExamMode(false);\\n      return;\\n    }\\n\\n    setIsExamMode(exam);\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) { console.error(e); }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(e),\\n        onclose: () \u003d\u003e { setIsLecturing(false); setIsExamMode(false); }\\n      }, student?.major || \u0027STEM\u0027, exam ? `FINAL EXAM FOR ${currentTopic}` : currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning \u0026\u0026 !exam) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false);\\n    } catch (e) {\\n      console.error(\\\"Session fail\\\", e);\\n    }\\n  };\\n\\n  const handleEnroll \u003d (name: string, major: SubjectArea, schedule: number) \u003d\u003e {\\n    setStudent({\\n      name,\\n      major,\\n      level: \u0027Elementary\u0027,\\n      enrolledDate: Date.now(),\\n      studyHoursGoal: schedule,\\n      currentStudyHours: 0\\n    });\\n    setComplexityLevel(\u0027Elementary\u0027);\\n  };\\n\\n  const markDone \u003d () \u003d\u003e {\\n    const active \u003d topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic);\\n    if (active) {\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d active.id ? { ...t, isCompleted: true } : t));\\n    }\\n  };\\n\\n  const promoteStudent \u003d () \u003d\u003e {\\n    const levels: ComplexityLevel[] \u003d [\u0027Elementary\u0027, \u0027High School\u0027, \u0027College\u0027, \u0027Expert\u0027];\\n    const currentIdx \u003d levels.indexOf(student?.level || \u0027Elementary\u0027);\\n    if (currentIdx \u003c levels.length - 1) {\\n      const nextLevel \u003d levels[currentIdx + 1];\\n      setStudent(prev \u003d\u003e prev ? { ...prev, level: nextLevel } : null);\\n      setComplexityLevel(nextLevel);\\n      setShowPromotion(true);\\n      setTimeout(() \u003d\u003e setShowPromotion(false), 5000);\\n      setIsExamMode(false);\\n      setIsLecturing(false);\\n      sessionRef.current?.close?.();\\n      // Reset topics for the next level\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e ({ ...t, isCompleted: false })));\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setComplexityLevel(level);\\n    setVisualStyle(style);\\n    if (currentSlide) {\\n      const data \u003d await generateInfographicImage(`Updated visual: ${currentSlide.prompt}. Complexity: ${level}, Style: ${style}`);\\n      setCurrentSlide({ ...currentSlide, data, level, style });\\n    }\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans transition-colors overflow-hidden\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} studentName\u003d{student?.name} /\u003e}\\n      \\n      {/* Navigator Toggle */}\\n      \u003cbutton \\n        onClick\u003d{() \u003d\u003e setIsSidebarOpen(!isSidebarOpen)}\\n        className\u003d\\\"fixed top-6 left-6 z-[60] p-4 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-white/10 hover:scale-105 active:scale-95 transition-all text-cyan-600 dark:text-cyan-400\\\"\\n      \u003e\\n        {isSidebarOpen ? \u003cX className\u003d\\\"w-6 h-6\\\" /\u003e : \u003cMenu className\u003d\\\"w-6 h-6\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Theme toggle */}\\n      \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"fixed top-8 right-8 z-[60] p-2 rounded-full opacity-20 hover:opacity-100 transition-opacity\\\"\u003e\\n        {isDarkMode ? \u003cSun className\u003d\\\"w-4 h-4\\\" /\u003e : \u003cMoon className\u003d\\\"w-4 h-4\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Sidebar (Navigator) */}\\n      \u003cdiv className\u003d{`fixed inset-0 z-50 transition-opacity duration-500 ${isSidebarOpen ? \u0027opacity-100\u0027 : \u0027opacity-0 pointer-events-none\u0027}`}\u003e\\n          \u003cdiv className\u003d\\\"absolute inset-0 bg-slate-950/40 backdrop-blur-sm\\\" onClick\u003d{() \u003d\u003e setIsSidebarOpen(false)}\u003e\u003c/div\u003e\\n          \u003cdiv className\u003d{`absolute top-0 left-0 h-full w-80 bg-white dark:bg-slate-950 shadow-2xl transition-transform duration-500 transform ${isSidebarOpen ? \u0027translate-x-0\u0027 : \u0027-translate-x-full\u0027}`}\u003e\\n              \u003cSyllabus \\n                topics\u003d{topics} \\n                currentId\u003d{topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic)?.id || \u00271\u0027} \\n                onSelect\u003d{(t) \u003d\u003e { setCurrentTopic(t.title); setIsSidebarOpen(false); }} \\n                onDone\u003d{markDone}\\n                isLecturing\u003d{isLecturing}\\n                toggleLecture\u003d{toggleLecture}\\n                student\u003d{student}\\n                onEnroll\u003d{handleEnroll}\\n                onTopicChange\u003d{setCurrentTopic}\\n                onPromote\u003d{promoteStudent}\\n                isExamMode\u003d{isExamMode}\\n              /\u003e\\n          \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      \u003cmain className\u003d\\\"flex-1 flex flex-col items-center justify-center p-8 relative\\\"\u003e\\n        {/* Promotion Celebration */}\\n        {showPromotion \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"absolute inset-0 z-[70] flex items-center justify-center bg-cyan-600/20 backdrop-blur-xl animate-in fade-in duration-1000\\\"\u003e\\n             \u003cdiv className\u003d\\\"bg-white dark:bg-slate-900 p-12 rounded-[3rem] shadow-2xl text-center space-y-4 scale-110 border border-cyan-500 relative\\\"\u003e\\n                \u003cdiv className\u003d\\\"absolute -top-12 left-1/2 -translate-x-1/2 bg-cyan-500 p-4 rounded-full shadow-lg\\\"\u003e\\n                  \u003cAward className\u003d\\\"w-12 h-12 text-white animate-bounce\\\" /\u003e\\n                \u003c/div\u003e\\n                \u003ch2 className\u003d\\\"text-4xl font-display font-bold\\\"\u003eAcademic Promotion!\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-500\\\"\u003eCongratulations! You have been elevated to \u003cb\u003e{student?.level}\u003c/b\u003e level.\u003c/p\u003e\\n                \u003cdiv className\u003d\\\"flex justify-center gap-2 text-emerald-500 items-center\\\"\u003e\\n                   \u003cCheckCircle2 className\u003d\\\"w-6 h-6\\\" /\u003e\\n                   \u003cspan className\u003d\\\"font-bold text-sm uppercase tracking-widest\\\"\u003eUniversity Credits Issued\u003c/span\u003e\\n                \u003c/div\u003e\\n                \u003cbutton onClick\u003d{() \u003d\u003e setShowPromotion(false)} className\u003d\\\"mt-6 px-6 py-2 bg-slate-100 dark:bg-slate-800 rounded-full