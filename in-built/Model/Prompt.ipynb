            onChange\u003d{e \u003d\u003e { setTopicInput(e.target.value); onTopicChange(e.target.value); }}\\n                        placeholder\u003d\\\"What shall we study?\\\" \\n                        className\u003d\\\"w-full bg-slate-100 dark:bg-slate-900 border-none rounded-xl px-4 py-2.5 text-xs pr-10 focus:ring-2 ring-cyan-500\\\"\\n                     /\u003e\\n                     \u003cbutton \\n                        onClick\u003d{() \u003d\u003e { onTopicChange(topicInput); }}\\n                        className\u003d\\\"absolute right-2 top-1/2 -translate-y-1/2 text-cyan-600 p-1\\\"\\n                     \u003e\\n                        \u003cSend className\u003d\\\"w-3 h-3\\\" /\u003e\\n                     \u003c/button\u003e\\n                  \u003c/div\u003e\\n                  \u003cbutton \\n                    onClick\u003d{startVoiceInput}\\n                    className\u003d{`p-2.5 rounded-xl transition-all ${isListening ? \u0027bg-red-500 text-white animate-pulse\u0027 : \u0027bg-slate-100 dark:bg-slate-900 text-slate-400\u0027}`}\\n                  \u003e\\n                    \u003cMic className\u003d\\\"w-4 h-4\\\" /\u003e\\n                  \u003c/button\u003e\\n               \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            {/* Topics List */}\\n            \u003cdiv className\u003d\\\"space-y-2\\\"\u003e\\n              \u003clabel className\u003d\\\"text-[9px] font-bold text-slate-400 uppercase tracking-widest\\\"\u003eCourse Scheme\u003c/label\u003e\\n              {topics.map((topic) \u003d\u003e (\\n                \u003cbutton\\n                  key\u003d{topic.id}\\n                  onClick\u003d{() \u003d\u003e onSelect(topic)}\\n                  className\u003d{`w-full text-left p-4 rounded-xl transition-all border flex flex-col gap-1 ${\\n                    currentId \u003d\u003d\u003d topic.id \\n                    ? \u0027bg-cyan-600/5 border-cyan-500/30\u0027 \\n                    : \u0027bg