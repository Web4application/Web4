 LIVE LECTURE IN PROGRESS\\n                 \u003c/div\u003e\\n               )}\\n            \u003c/div\u003e\\n\\n            {/* Interaction Footer */}\\n            \u003cdiv className\u003d\\\"flex flex-col items-center gap-6 py-12\\\"\u003e\\n               \u003cbutton \\n                  onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                  disabled\u003d{!isLecturing}\\n                  className\u003d{`group relative flex flex-col items-center justify-center w-32 h-32 rounded-full border-4 transition-all disabled:opacity-30 disabled:grayscale ${\\n                    isQuestioning \\n                    ? \u0027bg-amber-500 border-amber-400 scale-110 shadow-2xl shadow-amber-500/40 text-white\u0027 \\n                    : \u0027bg-white dark:bg-slate-800 border-slate-200 dark:border-white/10 text-slate-500 hover:border-cyan-500/50 hover:text-cyan-600 dark:hover:text-cyan-400\u0027\\n                  }`}\\n               \u003e\\n                 {isQuestioning ? \u003cMic className\u003d\\\"w-8 h-8 animate-bounce\\\" /\u003e : \u003cHand className\u003d\\\"w-8 h-8 group-hover:rotate-12 transition-transform\\\" /\u003e}\\n                 \u003cspan className\u003d\\\"absolute -bottom-8 whitespace-nowrap text-[10px] font-bold uppercase tracking-widest text-slate-400\\\"\u003e\\n                    {isQuestioning ? \u0027ASKING QUESTION...\u0027 : \u0027I HAVE A QUESTION\u0027}\\n                 \u003c/span\u003e\\n               \u003c/button\u003e\\n\\n               \u003cdiv className\u003d\\\"flex items-center gap-3 p-4 bg-cyan-100 dark:bg-cyan-950/30 rounded-2xl border border-cyan-200 dark:border-cyan-800/50 max-w-lg text-center\\\"\u003e\\n                  \u003cInfo className\u003d\\\"w-5 h-5 text-cyan-600 dark:text-cyan-400 flex-shrink-0\\\" /\u003e\\n                  \u003cp className\u003d\\\"text-xs text-cyan-800 dark:text-cyan-200 leading-relaxed\\\"\u003e\\n                    Alpha Academy uses \u003cb\u003eSpeech-to-Speech\u003c/b\u003e. Just pay attention! If you have a question, toggle the hand icon and speak. The AI will provide practical examples verbally.\\n                  \u003c/p\u003e\\n               \u003c/div\u003e\\n            \u003c/div\u003e\\n          \u003c/div\u003e\\n        \u003c/main\u003e\\n      \u003c/div\u003e\\n\\n      {/* Course Completion Button */}\\n      \u003cdiv className\u003d\\\"fixed bottom-8 right-8 z-50\\\"\u003e\\n          \u003cbutton \\n            onClick\u003d{markDone}\\n            className\u003d\\\"flex items-center gap-3 bg-emerald-500 text-white px-8 py-4 rounded-2xl font-bold shadow-2xl hover:bg-emerald-600 active:scale-95 transition-all shadow-emerald-500/30\\\"\\n          \u003e\\n            \u003cCheckCircle className\u003d\\\"w-5 h-5\\\" /\u003e\\n            ISSUE DONE\\n          \u003c/button\u003e\\n      \u003c/div\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default App;\\n\"}]},{\"path\":\"components/Syllabus.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Add a sidebar menu component to track topic progress and selection.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React from \u0027react\u0027;\\nimport { CourseTopic } from \u0027../types\u0027;\\nimport { BookOpen, CheckCircle, Circle, Clock } from \u0027lucide-react\u0027;\\n\\ninterface SyllabusProps {\\n  topics: CourseTopic[];\\n  currentId: string;\\n  onSelect: (topic: CourseTopic) \u003d\u003e void;\\n  onDone: () \u003d\u003e void;\\n}\\n\\nconst Syllabus: React.FC\u003cSyllabusProps\u003e \u003d ({ topics, currentId, onSelect, onDone }) \u003d\u003e {\\n  return (\\n    \u003caside className\u003d\\\"w-80 bg-white dark:bg-slate-950 border-r border-slate-200 dark:border-white/10 flex flex-col z-40\\\"\u003e\\n      \u003cdiv className\u003d\\\"p-6 border-b border-slate-200 dark:border-white/10\\\"\u003e\\n        \u003ch3 className\u003d\\\"text-xs font-bold text-slate-400 uppercase tracking-[0.3em] flex items-center gap-3\\\"\u003e\\n          \u003cBookOpen className\u003d\\\"w-4 h-4\\\" /\u003e Curriculum Path\\n        \u003c/h3\u003e\\n      \u003c/div\u003e\\n      \\n      \u003cdiv className\u003d\\\"flex-1 overflow-y-auto p-4 space-y-2\\\"\u003e\\n        {topics.map((topic) \u003d\u003e (\\n          \u003cbutton\\n            key\u003d{topic.id}\\n            onClick\u003d{() \u003d\u003e onSelect(topic)}\\n            className\u003d{`w-full text-left p-5 rounded-2xl transition-all border flex flex-col gap-2 ${\\n              currentId \u003d\u003d\u003d topic.id \\n              ? \u0027bg-cyan-600 border-cyan-500 text-white shadow-lg shadow-cyan-600/20\u0027 \\n              : \u0027bg-transparent border-transparent hover:bg-slate-100 dark:hover:bg-slate-900 text-slate-600 dark:text-slate-400\u0027\\n            }`}\\n          \u003e\\n            \u003cdiv className\u003d\\\"flex items-center justify-between\\\"\u003e\\n               \u003cspan className\u003d{`text-[9px] font-bold uppercase tracking-widest ${currentId \u003d\u003d\u003d topic.id ? \u0027text-cyan-200\u0027 : \u0027text-cyan-600 dark:text-cyan-400\u0027}`}\u003e\\n                 {topic.subject}\\n               \u003c/span\u003e\\n               {topic.isCompleted ? (\\n                 \u003cCheckCircle className\u003d\\\"w-4 h-4 text-emerald-400\\\" /\u003e\\n               ) : (\\n                 \u003cCircle className\u003d\\\"w-4 h-4 opacity-20\\\" /\u003e\\n               )}\\n            \u003c/div\u003e\\n            \u003ch4 className\u003d\\\"font-display font-bold leading-tight\\\"\u003e{topic.title}\u003c/h4\u003e\\n            \u003cdiv className\u003d\\\"flex items-center gap-2 mt-1 opacity-60 text-[10px] font-bold\\\"\u003e\\n               \u003cClock className\u003d\\\"w-3 h-3\\\" /\u003e {topic.duration} Est.\\n            \u003c/div\u003e\\n          \u003c/button\u003e\\n        ))}\\n      \u003c/div\u003e\\n\\n      \u003cdiv className\u003d\\\"p-6 bg-slate-50 dark:bg-slate-900/30 border-t border-slate-200 dark:border-white/10\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center justify-between text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3\\\"\u003e\\n           \u003cspan\u003eTotal Course Progress\u003c/span\u003e\\n           \u003cspan\u003e{Math.round((topics.filter(t \u003d\u003e t.isCompleted).length / topics.length) * 100)}%\u003c/span\u003e\\n        \u003c/div\u003e\\n        \u003cdiv className\u003d\\\"w-full h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden\\\"\u003e\\n           \u003cdiv \\n             className\u003d\\\"h-full bg-cyan-500 transition-all duration-1000\\\" \\n             style\u003d{{ width: `${(topics.filter(t \u003d\u003e t.isCompleted).length / topics.length) * 100}%` }}\\n           \u003e\u003c/div\u003e\\n        \u003c/div\u003e\\n      \u003c/div\u003e\\n    \u003c/aside\u003e\\n  );\\n};\\n\\nexport default Syllabus;\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767865916,\"nanos\":324000000},\"doneTimestamp\":{\"seconds\":1767865916,\"nanos\":405000000}},{\"id\":203,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"The lecture screen must only have 2 bottoms “I have a question “ and navigator switch\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767866020,\"nanos\":932000000}},{\"id\":204,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Focusing the Interface**\\n\\nI\u0027m currently streamlining the lecture screen. My focus is on radical simplification: removing clutter. I\u0027m prioritizing just two key buttons: a prominent \\\"I have a question\\\" button and a navigator toggle. I\u0027m exploring how to relocate or eliminate other UI elements like \\\"Start Lecture\\\" to create a cleaner user experience.\\n\\n\\n**Prioritizing Core Features**\\n\\nI\u0027ve realized the user\u0027s focus is truly on a minimal, \\\"Lecture Mode\\\" experience. My emphasis is now on consolidating the interface around just two core features. The \\\"navigator switch\\\" will toggle the syllabus visibility, allowing the user to view the whiteboard when it is closed, or the syllabus when the whiteboard is not active. The UI will focus on just these two functionalities: the whiteboard and the syllabus. Other elements are slated for relocation or removal.\\n\\n\\n**Refining Core Functionality**\\n\\nI\u0027m now integrating the \\\"Issue Done\\\" request into the syllabus sidebar, and I\u0027m further streamlining the lecture view. I\u0027ve refactored the layout to hide the syllabus by default, using a \\\"Navigator\\\" switch. \\\"Start Lecture\\\" and \\\"Issue Done\\\" logic now reside within the Syllabus. The interface will feature a minimalist Whiteboard, with floating \\\"Navigator\\\" and \\\"I have a question\\\" buttons. The user wants only two buttons: \\\"I have a question\\\" and the \\\"Navigator\\\" toggle. Selecting a syllabus topic should trigger the lecture.\\n\\n\\n**Integrating the Issue Done**\\n\\nI\u0027m now integrating the \\\"Issue Done\\\" button inside the Navigator (Syllabus) for each topic. I\u0027m updating `App.tsx` to manage a `sidebarOpen` state. I\u0027m moving the lecture controls into the `Syllabus` component, or automating them based on topic clicks. The main screen will now strictly feature just the \\\"I have a question\\\" button and the \\\"Navigator\\\" toggle. I will integrate a method to mark the lecture as done, inside the sidebar.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767866020,\"nanos\":932000000},\"doneTimestamp\":{\"seconds\":1767866033,\"nanos\":329000000}},{\"id\":205,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Refactored the UI to a focused lecture mode with only two main buttons: \u0027I have a question\u0027 and a \u0027Navigator\u0027 switch. Moved lecture controls and topic management into the sidebar.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SubjectArea, CourseTopic } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { GraduationCap, Sun, Moon, Mic, Hand, Play, Square, CheckCircle, Volume2, Menu, X } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [subject, setSubject] \u003d useState\u003cSubjectArea\u003e(\u0027STEM\u0027);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027Introduction to Modern Physics\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027Introduction to Modern Physics\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027Physics\u0027 },\\n    { id: \u00272\u0027, title: \u0027Calculus in Engineering\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027 },\\n    { id: \u00273\u0027, title: \u0027Genetics and DNA Analysis\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Biology\u0027 },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  const toggleLecture \u003d async () \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      return;\\n    }\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          console.log(\\\"Lecture hall opened.\\\");\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) {\\n                  console.error(\\\"Tool execution failed\\\", e);\\n                }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(\\\"Lecture Error\\\", e),\\n        onclose: () \u003d\u003e setIsLecturing(false)\\n      }, subject, currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false); // Close sidebar when lecture starts\\n    } catch (e) {\\n      console.error(\\\"Could not start lecture\\\", e);\\n    }\\n  };\\n\\n  const markDone \u003d () \u003d\u003e {\\n    const active \u003d topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic);\\n    if (active) {\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d active.id ? { ...t, isCompleted: true } : t));\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setComplexityLevel(level);\\n    setVisualStyle(style);\\n    if (currentSlide) {\\n      const data \u003d await generateInfographicImage(`Updated visual: ${currentSlide.prompt}. Complexity: ${level}, Style: ${style}`);\\n      setCurrentSlide({ ...currentSlide, data, level, style });\\n    }\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans transition-colors overflow-hidden\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} /\u003e}\\n      \\n      {/* Navigator Toggle Button (Button 1) */}\\n      \u003cbutton \\n        onClick\u003d{() \u003d\u003e setIsSidebarOpen(!isSidebarOpen)}\\n        className\u003d\\\"fixed top-6 left-6 z-[60] p-4 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-white/10 hover:scale-105 active:scale-95 transition-all text-cyan-600 dark:text-cyan-400\\\"\\n      \u003e\\n        {isSidebarOpen ? \u003cX className\u003d\\\"w-6 h-6\\\" /\u003e : \u003cMenu className\u003d\\\"w-6 h-6\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Theme Toggle (Hidden to satisfy \\\"only 2 buttons\\\" request, but can be keep as a secondary small toggle or moved to sidebar) */}\\n      \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"fixed top-8 right-8 z-[60] p-2 rounded-full opacity-20 hover:opacity-100 transition-opacity\\\"\u003e\\n        {isDarkMode ? \u003cSun className\u003d\\\"w-4 h-4\\\" /\u003e : \u003cMoon className\u003d\\\"w-4 h-4\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Sidebar Overlay */}\\n      \u003cdiv className\u003d{`fixed inset-0 z-50 transition-opacity duration-500 ${isSidebarOpen ? \u0027opacity-100\u0027 : \u0027opacity-0 pointer-events-none\u0027}`}\u003e\\n          \u003cdiv className\u003d\\\"absolute inset-0 bg-slate-950/40 backdrop-blur-sm\\\" onClick\u003d{() \u003d\u003e setIsSidebarOpen(false)}\u003e\u003c/div\u003e\\n          \u003cdiv className\u003d{`absolute top-0 left-0 h-full w-80 bg-white dark:bg-slate-950 shadow-2xl transition-transform duration-500 transform ${isSidebarOpen ? \u0027translate-x-0\u0027 : \u0027-translate-x-full\u0027}`}\u003e\\n              \u003cSyllabus \\n                topics\u003d{topics} \\n                currentId\u003d{topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic)?.id || \u00271\u0027} \\n                onSelect\u003d{(t) \u003d\u003e { setCurrentTopic(t.title); setIsSidebarOpen(false); }} \\n                onDone\u003d{markDone}\\n                isLecturing\u003d{isLecturing}\\n                toggleLecture\u003d{toggleLecture}\\n              /\u003e\\n          \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      \u003cmain className\u003d\\\"flex-1 flex flex-col items-center justify-center p-8 relative\\\"\u003e\\n        \u003cdiv className\u003d\\\"max-w-5xl w-full flex flex-col items-center gap-12\\\"\u003e\\n            \\n            {/* Whiteboard Area */}\\n            \u003cdiv className\u003d\\\"w-full relative group\\\"\u003e\\n               {currentSlide ? (\\n                  \u003cInfographic \\n                    image\u003d{currentSlide} \\n                    onEdit\u003d{() \u003d\u003e {}} \\n                    onRegenerate\u003d{handleRegenerate}\\n                    isEditing\u003d{false}\\n                  /\u003e\\n               ) : (\\n                  \u003cdiv className\u003d\\\"aspect-video w-full bg-white dark:bg-slate-900 rounded-[3rem] border border-slate-200 dark:border-white/5 shadow-2xl flex flex-col items-center justify-center gap-6 text-slate-300 dark:text-slate-700\\\"\u003e\\n                    \u003cdiv className\u003d\\\"relative\\\"\u003e\\n                      \u003cVolume2 className\u003d\\\"w-20 h-20 opacity-20\\\" /\u003e\\n                      {isLecturing \u0026\u0026 (\\n                        \u003cdiv className\u003d\\\"absolute inset-0 flex items-center justify-center\\\"\u003e\\n                          \u003cdiv className\u003d\\\"w-full h-full border-4 border-cyan-500 rounded-full animate-ping opacity-20\\\"\u003e\u003c/div\u003e\\n                        \u003c/div\u003e\\n                      )}\\n                    \u003c/div\u003e\\n                    \u003cdiv className\u003d\\\"text-center space-y-2\\\"\u003e\\n                        \u003cp className\u003d\\\"font-display font-bold uppercase tracking-[0.3em] text-sm\\\"\u003eVisual Laboratory\u003c/p\u003e\\n                        \u003cp className\u003d\\\"text-xs opacity-50 italic\\\"\u003e{isLecturing ? \\\"Professor is preparing materials...\\\" : \\\"Please select a topic and start the lecture\\\"}\u003c/p\u003e\\n                    \u003c/div\u003e\\n                  \u003c/div\u003e\\n               )}\\n\\n               {isLecturing \u0026\u0026 (\\n                 \u003cdiv className\u003d\\\"absolute top-6 right-6 flex items-center gap-2 bg-emerald-500/90 backdrop-blur-md text-white px-4 py-2 rounded-full text-[10px] font-bold shadow-lg animate-pulse\\\"\u003e\\n                    \u003cdiv className\u003d\\\"w-1.5 h-1.5 bg-white rounded-full\\\"\u003e\u003c/div\u003e\\n                    SESSION ACTIVE\\n                 \u003c/div\u003e\\n               )}\\n            \u003c/div\u003e\\n\\n            {/* Question Button (Button 2) */}\\n            \u003cdiv className\u003d\\\"relative group\\\"\u003e\\n               \u003cbutton \\n                  onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                  disabled\u003d{!isLecturing}\\n                  className\u003d{`flex flex-col items-center justify-center w-40 h-40 rounded-full border-8 transition-all disabled:opacity-20 disabled:grayscale disabled:scale-95 ${\\n                    isQuestioning \\n                    ? \u0027bg-amber-500 border-amber-400 scale-110 shadow-[0_0_50px_rgba(245,158,11,0.4)] text-white\u0027 \\n                    : \u0027bg-white dark:bg-slate-800 border-white dark:border-slate-800 text-slate-400 hover:border-cyan-500 dark:hover:border-cyan-500 hover:text-cyan-600 dark:hover:text-cyan-400 shadow-xl\u0027\\n                  }`}\\n               \u003e\\n                 {isQuestioning ? \u003cMic className\u003d\\\"w-12 h-12 animate-pulse\\\" /\u003e : \u003cHand className\u003d\\\"w-12 h-12\\\" /\u003e}\\n                 \u003cspan className\u003d{`mt-2 text-[9px] font-bold uppercase tracking-[0.2em] ${isQuestioning ? \u0027text-white\u0027 : \u0027text-slate-400\u0027}`}\u003e\\n                    {isQuestioning ? \u0027Listening...\u0027 : \u0027I have a question\u0027}\\n                 \u003c/span\u003e\\n               \u003c/button\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n\\n        {/* Subtle Status Line */}\\n        \u003cdiv className\u003d\\\"absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-4 text-slate-400/30\\\"\u003e\\n            \u003cspan className\u003d\\\"text-[10px] font-bold uppercase tracking-widest\\\"\u003e{currentTopic}\u003c/span\u003e\\n            \u003cdiv className\u003d\\\"w-1 h-1 bg-slate-400/20 rounded-full\\\"\u003e\u003c/div\u003e\\n            \u003cspan className\u003d\\\"text-[10px] font-bold uppercase tracking-widest\\\"\u003e{complexityLevel}\u003c/span\u003e\\n        \u003c/div\u003e\\n      \u003c/main\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default App;\\n\"}]},{\"path\":\"components/Syllabus.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Added lecture controls (Play/Stop and Issue Done) into the Syllabus sidebar to keep the main screen focused on only two buttons.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React from \u0027react\u0027;\\nimport { CourseTopic } from \u0027../types\u0027;\\nimport { BookOpen, CheckCircle, Circle, Clock, Play, Square, Award } from \u0027lucide-react\u0027;\\n\\ninterface SyllabusProps {\\n  topics: CourseTopic[];\\n  currentId: string;\\n  onSelect: (topic: CourseTopic) \u003d\u003e void;\\n  onDone: () \u003d\u003e void;\\n  isLecturing: boolean;\\n  toggleLecture: () \u003d\u003e void;\\n}\\n\\nconst Syllabus: React.FC\u003cSyllabusProps\u003e \u003d ({ topics, currentId, onSelect, onDone, isLecturing, toggleLecture }) \u003d\u003e {\\n  const currentTopic \u003d topics.find(t \u003d\u003e t.id \u003d\u003d\u003d currentId);\\n\\n  return (\\n    \u003cdiv className\u003d\\\"flex flex-col h-full\\\"\u003e\\n      \u003cdiv className\u003d\\\"p-8 border-b border-slate-200 dark:border-white/10\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-3 mb-2\\\"\u003e\\n            \u003cBookOpen className\u003d\\\"w-5 h-5 text-cyan-600\\\" /\u003e\\n            \u003ch3 className\u003d\\\"text-xs font-bold text-slate-400 uppercase tracking-[0.3em]\\\"\u003eCourse Navigator\u003c/h3\u003e\\n        \u003c/div\u003e\\n        \u003cp className\u003d\\\"text-[10px] text-slate-500\\\"\u003eSelect a module to begin your visual session.\u003c/p\u003e\\n      \u003c/div\u003e\\n      \\n      \u003cdiv className\u003d\\\"flex-1 overflow-y-auto p-4 space-y-2\\\"\u003e\\n        {topics.map((topic) \u003d\u003e (\\n          \u003cbutton\\n            key\u003d{topic.id}\\n            onClick\u003d{() \u003d\u003e onSelect(topic)}\\n            className\u003d{`w-full text-left p-5 rounded-2xl transition-all border flex flex-col gap-2 ${\\n              currentId \u003d\u003d\u003d topic.id \\n              ? \u0027bg-cyan-600/10 border-cyan-500/50 text-cyan-700 dark:text-cyan-300\u0027 \\n              : \u0027bg-transparent border-transparent hover:bg-slate-100 dark:hover:bg-slate-900 text-slate-600 dark:text-slate-400\u0027\\n            }`}\\n          \u003e\\n            \u003cdiv className\u003d\\\"flex items-center justify-between\\\"\u003e\\n               \u003cspan className\u003d\\\"text-[8px] font-bold uppercase tracking-widest opacity-60\\\"\u003e\\n                 {topic.subject}\\n               \u003c/span\u003e\\n               {topic.isCompleted ? (\\n                 \u003cCheckCircle className\u003d\\\"w-4 h-4 text-emerald-400\\\" /\u003e\\n               ) : (\\n                 \u003cCircle className\u003d\\\"w-4 h-4 opacity-10\\\" /\u003e\\n               )}\\n            \u003c/div\u003e\\n            \u003ch4 className\u003d{`font-display font-bold leading-tight ${currentId \u003d\u003d\u003d topic.id ? \u0027text-cyan-600 dark:text-cyan-400\u0027 : \u0027\u0027}`}\u003e\\n                {topic.title}\\n            \u003c/h4\u003e\\n          \u003c/button\u003e\\n        ))}\\n      \u003c/div\u003e\\n\\n      \u003cdiv className\u003d\\\"p-6 bg-slate-50 dark:bg-slate-900/30 border-t border-slate-200 dark:border-white/10 space-y-6\\\"\u003e\\n        {/* Lecture Controls */}\\n        \u003cdiv className\u003d\\\"space-y-3\\\"\u003e\\n            \u003cbutton \\n                onClick\u003d{toggleLecture}\\n                className\u003d{`w-full py-4 rounded-xl font-bold flex items-center justify-center gap-3 shadow-lg transition-all ${\\n                    isLecturing \\n                    ? \u0027bg-red-500 text-white hover:bg-red-600\u0027 \\n                    : \u0027bg-cyan-600 text-white hover:bg-cyan-500 shadow-cyan-500/20\u0027\\n                }`}\\n            \u003e\\n                {isLecturing ? \u003cSquare className\u003d\\\"w-4 h-4 fill-current\\\" /\u003e : \u003cPlay className\u003d\\\"w-4 h-4 fill-current\\\" /\u003e}\\n                {isLecturing ? \u0027Terminate Session\u0027 : \u0027Start Lecture\u0027}\\n            \u003c/button\u003e\\n            \\n            \u003cbutton \\n                onClick\u003d{onDone}\\n                disabled\u003d{!currentTopic?.isCompleted \u0026\u0026 !isLecturing}\\n                className\u003d\\\"w-full py-4 rounded-xl border-2 border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 font-bold flex items-center justify-center gap-3 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all disabled:opacity-30\\\"\\n            \u003e\\n                \u003cAward className\u003d\\\"w-4 h-4\\\" /\u003e\\n                Issue Lesson Done\\n            \u003c/button\u003e\\n        \u003c/div\u003e\\n\\n        \u003cdiv className\u003d\\\"space-y-2\\\"\u003e\\n            \u003cdiv className\u003d\\\"flex items-center justify-between text-[9px] font-bold text-slate-400 uppercase tracking-widest\\\"\u003e\\n               \u003cspan\u003eAcademy Credits\u003c/span\u003e\\n               \u003cspan\u003e{Math.round((topics.filter(t \u003d\u003e t.isCompleted).length / topics.length) * 100)}%\u003c/span\u003e\\n            \u003c/div\u003e\\n            \u003cdiv className\u003d\\\"w-full h-1 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden\\\"\u003e\\n               \u003cdiv \\n                 className\u003d\\\"h-full bg-cyan-500 transition-all duration-1000\\\" \\n                 style\u003d{{ width: `${(topics.filter(t \u003d\u003e t.isCompleted).length / topics.length) * 100}%` }}\\n               \u003e\u003c/div\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n      \u003c/div\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default Syllabus;\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767866033,\"nanos\":330000000},\"doneTimestamp\":{\"seconds\":1767866049,\"nanos\":791000000}},{\"id\":206,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"Add a text input field and a microphone button to allow the user to input the lecture topic via speech or text. This should be placed near the subject selection.\\nAllow enrollment into virtual university select area of study sign up for classes save details of students issue out test after completing scheme of study automatically promote to next stage if the student passes, schedule hours of study , friendly interactions between students and Gemini\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888174,\"nanos\":943000000}},{\"id\":207,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Considering Features for App**\\n\\nOkay, so I\u0027m thinking about the \\\"InfoGenius Academy\\\" app. I\u0027m focusing on the user\u0027s needs. I\u0027ve begun to consider the specific features they mentioned. I\u0027m working to include the text input and mic button alongside the subject selection. Furthermore, I\u0027m integrating study area selection, class sign-up, and saving student info. I\u0027m moving toward an effective, comprehensive app design.\\n\\n\\n**Analyzing New Feature Integration**\\n\\nI\u0027m now integrating the student profile and enrollment features. I\u0027m focusing on the \\\"Navigator\\\" sidebar and adding sections for student identity. These sections are for things like name, subject, and complexity level. I\u0027m also adding an \\\"Enroll\\\" button to start the course. I am simultaneously focused on topic input, with text and microphone options.\\n\\n\\n**Integrating Study Progression Features**\\n\\nI\u0027m currently focused on the progression system. I\u0027m adding \\\"Study Hours\\\" tracking, simulating study time based on lecture duration. I\u0027ll trigger a final exam when a syllabus is complete, utilizing a Gemini-powered conversational quiz. Successful completion will lead to user promotion across defined levels. Concurrently, I\u0027m refining the UI, implementing the \\\"Navigator\\\" sidebar for enrollment and study scheduling. I\u0027m aiming for minimalism on the main screen, with topic input and enrollment features accessible within the sidebar. I\u0027m adding a \\\"Peer Chat\\\" toggle to add a more friendly experience.\\n\\n\\n**Coding Application Components**\\n\\nI\u0027m now diving into the code. I\u0027m adding `StudentProfile` and `ExamState` to `types.ts`, and I\u0027ll manage student data, the study timer, exam logic, and topic input in `App.tsx`. I\u0027ll update `Syllabus.tsx` for enrollment and scheduling, and add the exam logic to the Gemini Service. I\u0027m working on the student profile, with details saved in `localStorage`. I\u0027m switching the navigator menu to a clearer label, and implementing voice input for topics with `window.SpeechRecognition`. Finally, I\u0027ll add a study schedule field to the sidebar.\\n\\n\\n**Refining Study Hour Logic**\\n\\nI\u0027m now refining the study hour tracking. I am focusing on the calculation of study hours based on lecture duration and level. I\u0027m also ensuring the correct logic for exam triggering at the end of a syllabus. I am improving the Gemini quiz functionality and designing an engaging user progression flow to the UI.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767888174,\"nanos\":944000000},\"doneTimestamp\":{\"seconds\":1767888196,\"nanos\":798000000}},{\"id\":208,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"types.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Added StudentProfile and CourseProgress types to support enrollment, study scheduling, and academic progression.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nexport type AspectRatio \u003d \u002716:9\u0027 | \u00279:16\u0027 | \u00271:1\u0027;\\n\\nexport type ComplexityLevel \u003d \u0027Elementary\u0027 | \u0027High School\u0027 | \u0027College\u0027 | \u0027Expert\u0027;\\n\\nexport type SubjectArea \u003d \u0027STEM\u0027 | \u0027History\u0027 | \u0027Biology\u0027 | \u0027Physics\u0027 | \u0027Geography\u0027 | \u0027Literature\u0027 | \u0027Engineering\u0027 | \u0027General\u0027;\\n\\nexport type VisualStyle \u003d \u0027Default\u0027 | \u0027Minimalist\u0027 | \u0027Realistic\u0027 | \u0027Cartoon\u0027 | \u0027Vintage\u0027 | \u0027Futuristic\u0027 | \u00273D Render\u0027 | \u0027Sketch\u0027;\\n\\nexport type Language \u003d \u0027English\u0027 | \u0027Spanish\u0027 | \u0027French\u0027 | \u0027German\u0027 | \u0027Mandarin\u0027 | \u0027Japanese\u0027 | \u0027Hindi\u0027 | \u0027Arabic\u0027 | \u0027Portuguese\u0027 | \u0027Russian\u0027;\\n\\nexport interface StudentProfile {\\n  name: string;\\n  major: SubjectArea;\\n  level: ComplexityLevel;\\n  enrolledDate: number;\\n  studyHoursGoal: number;\\n  currentStudyHours: number;\\n}\\n\\n/**\\n * Interface representing a course topic in the syllabus.\\n */\\nexport interface CourseTopic {\\n  id: string;\\n  title: string;\\n  duration: string;\\n  isCompleted: boolean;\\n  subject: SubjectArea;\\n}\\n\\nexport interface GeneratedImage {\\n  id: string;\\n  data: string; // Base64 data URL\\n  prompt: string;\\n  timestamp: number;\\n  level?: ComplexityLevel;\\n  style?: VisualStyle;\\n  language?: Language;\\n  subject?: SubjectArea;\\n}\\n\\nexport interface SearchResultItem {\\n  title: string;\\n  url: string;\\n}\\n\\nexport interface ResearchResult {\\n  imagePrompt: string;\\n  facts: string[];\\n  searchResults: SearchResultItem[];\\n}\\n\\ndeclare global {\\n  interface AIStudio {\\n    hasSelectedApiKey: () \u003d\u003e Promise\u003cboolean\u003e;\\n    openSelectKey: () \u003d\u003e Promise\u003cvoid\u003e;\\n  }\\n  interface Window {\\n    SpeechRecognition: any;\\n    webkitSpeechRecognition: any;\\n  }\\n}\\n\"}]},{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Implemented student enrollment, automated promotion via exams, study time tracking, and voice-to-text topic selection inside the Navigator.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SubjectArea, CourseTopic, StudentProfile } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { Sun, Moon, Mic, Hand, Volume2, Menu, X, Award, CheckCircle2 } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027The Laws of Motion\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n  const [isExamMode, setIsExamMode] \u003d useState(false);\\n  const [showPromotion, setShowPromotion] \u003d useState(false);\\n\\n  const [student, setStudent] \u003d useState\u003cStudentProfile | null\u003e(() \u003d\u003e {\\n    const saved \u003d localStorage.getItem(\u0027student_profile\u0027);\\n    return saved ? JSON.parse(saved) : null;\\n  });\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const studyTimerRef \u003d useRef\u003cnumber | null\u003e(null);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027The Laws of Motion\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027Physics\u0027 },\\n    { id: \u00272\u0027, title: \u0027Calculus in Engineering\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027 },\\n    { id: \u00273\u0027, title: \u0027Genetics and DNA Analysis\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Biology\u0027 },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (student) {\\n      localStorage.setItem(\u0027student_profile\u0027, JSON.stringify(student));\\n    }\\n  }, [student]);\\n\\n  // Track study hours while lecturing\\n  useEffect(() \u003d\u003e {\\n    if (isLecturing \u0026\u0026 !isExamMode) {\\n      studyTimerRef.current \u003d window.setInterval(() \u003d\u003e {\\n        setStudent(prev \u003d\u003e prev ? { ...prev, currentStudyHours: prev.currentStudyHours + (1/3600) } : null);\\n      }, 1000);\\n    } else {\\n      if (studyTimerRef.current) clearInterval(studyTimerRef.current);\\n    }\\n    return () \u003d\u003e { if (studyTimerRef.current) clearInterval(studyTimerRef.current); };\\n  }, [isLecturing, isExamMode]);\\n\\n  const toggleLecture \u003d async (exam: boolean \u003d false) \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      setIsExamMode(false);\\n      return;\\n    }\\n\\n    setIsExamMode(exam);\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) { console.error(e); }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(e),\\n        onclose: () \u003d\u003e { setIsLecturing(false); setIsExamMode(false); }\\n      }, student?.major || \u0027STEM\u0027, exam ? `FINAL EXAM FOR ${currentTopic}` : currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning \u0026\u0026 !exam) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false);\\n    } catch (e) {\\n      console.error(\\\"Session fail\\\", e);\\n    }\\n  };\\n\\n  const handleEnroll \u003d (name: string, major: SubjectArea, schedule: number) \u003d\u003e {\\n    setStudent({\\n      name,\\n      major,\\n      level: \u0027Elementary\u0027,\\n      enrolledDate: Date.now(),\\n      studyHoursGoal: schedule,\\n      currentStudyHours: 0\\n    });\\n    setComplexityLevel(\u0027Elementary\u0027);\\n  };\\n\\n  const markDone \u003d () \u003d\u003e {\\n    const active \u003d topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic);\\n    if (active) {\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d active.id ? { ...t, isCompleted: true } : t));\\n    }\\n  };\\n\\n  const promoteStudent \u003d () \u003d\u003e {\\n    const levels: ComplexityLevel[] \u003d [\u0027Elementary\u0027, \u0027High School\u0027, \u0027College\u0027, \u0027Expert\u0027];\\n    const currentIdx \u003d levels.indexOf(student?.level || \u0027Elementary\u0027);\\n    if (currentIdx \u003c levels.length - 1) {\\n      const nextLevel \u003d levels[currentIdx + 1];\\n      setStudent(prev \u003d\u003e prev ? { ...prev, level: nextLevel } : null);\\n      setComplexityLevel(nextLevel);\\n      setShowPromotion(true);\\n      setTimeout(() \u003d\u003e setShowPromotion(false), 5000);\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setComplexityLevel(level);\\n    setVisualStyle(style);\\n    if (currentSlide) {\\n      const data \u003d await generateInfographicImage(`Updated visual: ${currentSlide.prompt}. Complexity: ${level}, Style: ${style}`);\\n      setCurrentSlide({ ...currentSlide, data, level, style });\\n    }\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans transition-colors overflow-hidden\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} /\u003e}\\n      \\n      {/* Navigator Toggle */}\\n      \u003cbutton \\n        onClick\u003d{() \u003d\u003e setIsSidebarOpen(!isSidebarOpen)}\\n        className\u003d\\\"fixed top-6 left-6 z-[60] p-4 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-white/10 hover:scale-105 active:scale-95 transition-all text-cyan-600 dark:text-cyan-400\\\"\\n      \u003e\\n        {isSidebarOpen ? \u003cX className\u003d\\\"w-6 h-6\\\" /\u003e : \u003cMenu className\u003d\\\"w-6 h-6\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Theme toggle */}\\n      \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"fixed top-8 right-8 z-[60] p-2 rounded-full opacity-20 hover:opacity-100 transition-opacity\\\"\u003e\\n        {isDarkMode ? \u003cSun className\u003d\\\"w-4 h-4\\\" /\u003e : \u003cMoon className\u003d\\\"w-4 h-4\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      {/* Sidebar (Navigator) */}\\n      \u003cdiv className\u003d{`fixed inset-0 z-50 transition-opacity duration-500 ${isSidebarOpen ? \u0027opacity-100\u0027 : \u0027opacity-0 pointer-events-none\u0027}`}\u003e\\n          \u003cdiv className\u003d\\\"absolute inset-0 bg-slate-950/40 backdrop-blur-sm\\\" onClick\u003d{() \u003d\u003e setIsSidebarOpen(false)}\u003e\u003c/div\u003e\\n          \u003cdiv className\u003d{`absolute top-0 left-0 h-full w-80 bg-white dark:bg-slate-950 shadow-2xl transition-transform duration-500 transform ${isSidebarOpen ? \u0027translate-x-0\u0027 : \u0027-translate-x-full\u0027}`}\u003e\\n              \u003cSyllabus \\n                topics\u003d{topics} \\n                currentId\u003d{topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic)?.id || \u00271\u0027} \\n                onSelect\u003d{(t) \u003d\u003e { setCurrentTopic(t.title); setIsSidebarOpen(false); }} \\n                onDone\u003d{markDone}\\n                isLecturing\u003d{isLecturing}\\n                toggleLecture\u003d{toggleLecture}\\n                student\u003d{student}\\n                onEnroll\u003d{handleEnroll}\\n                onTopicChange\u003d{setCurrentTopic}\\n                onPromote\u003d{promoteStudent}\\n                isExamMode\u003d{isExamMode}\\n              /\u003e\\n          \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      \u003cmain className\u003d\\\"flex-1 flex flex-col items-center justify-center p-8 relative\\\"\u003e\\n        {/* Promotion Celebration */}\\n        {showPromotion \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"absolute inset-0 z-50 flex items-center justify-center bg-cyan-600/20 backdrop-blur-xl animate-in fade-in duration-1000\\\"\u003e\\n             \u003cdiv className\u003d\\\"bg-white dark:bg-slate-900 p-12 rounded-[3rem] shadow-2xl text-center space-y-4 scale-110 border border-cyan-500\\\"\u003e\\n                \u003cAward className\u003d\\\"w-20 h-20 text-cyan-500 mx-auto animate-bounce\\\" /\u003e\\n                \u003ch2 className\u003d\\\"text-4xl font-display font-bold\\\"\u003eAcademic Promotion!\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-500\\\"\u003eYou have been elevated to \u003cb\u003e{student?.level}\u003c/b\u003e level.\u003c/p\u003e\\n                \u003cdiv className\u003d\\\"flex justify-center gap-2\\\"\u003e\\n                   \u003cCheckCircle2 className\u003d\\\"text-emerald-500 w-6 h-6\\\" /\u003e\\n                   \u003cspan className\u003d\\\"font-bold\\\"\u003eUniversity Credits Issued\u003c/span\u003e\\n                \u003c/div\u003e\\n             \u003c/div\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        \u003cdiv className\u003d\\\"max-w-5xl w-full flex flex-col items-center gap-12\\\"\u003e\\n            {/* Whiteboard */}\\n            \u003cdiv className\u003d\\\"w-full relative\\\"\u003e\\n               {currentSlide ? (\\n                  \u003cInfographic \\n                    image\u003d{currentSlide} \\n                    onEdit\u003d{() \u003d\u003e {}} \\n                    onRegenerate\u003d{handleRegenerate}\\n                    isEditing\u003d{false}\\n                  /\u003e\\n               ) : (\\n                  \u003cdiv className\u003d\\\"aspect-video w-full bg-white dark:bg-slate-900 rounded-[3rem] border border-slate-200 dark:border-white/5 shadow-2xl flex flex-col items-center justify-center gap-6\\\"\u003e\\n                    \u003cVolume2 className\u003d\\\"w-20 h-20 opacity-10\\\" /\u003e\\n                    \u003cdiv className\u003d\\\"text-center space-y-2 opacity-30\\\"\u003e\\n                        \u003cp className\u003d\\\"font-display font-bold uppercase tracking-[0.3em] text-sm\\\"\u003eInteractive Hall\u003c/p\u003e\\n                        \u003cp className\u003d\\\"text-xs italic\\\"\u003e{isLecturing ? \\\"Professor is rendering insights...\\\" : \\\"Open Navigator to sign up and begin\\\"}\u003c/p\u003e\\n                    \