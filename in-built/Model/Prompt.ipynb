\\n\\n               {isLecturing \u0026\u0026 (\\n                 \u003cdiv className\u003d\\\"absolute top-6 right-6 flex items-center gap-2 bg-emerald-500/90 backdrop-blur-md text-white px-4 py-2 rounded-full text-[10px] font-bold shadow-lg\\\"\u003e\\n                    \u003cSparkles className\u003d\\\"w-3 h-3 animate-pulse\\\" /\u003e\\n                    {isExamMode ? \u0027EXAMINATION IN SESSION\u0027 : \u0027LECTURE IN PROGRESS\u0027}\\n                 \u003c/div\u003e\\n               )}\\n            \u003c/div\u003e\\n\\n            \u003cdiv className\u003d\\\"relative\\\"\u003e\\n               \u003cbutton \\n                  onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                  disabled\u003d{!isLecturing || isExamMode}\\n                  className\u003d{`flex flex-col items-center justify-center w-40 h-40 rounded-full border-8 transition-all disabled:opacity-20 disabled:scale-90 ${\\n                    isQuestioning \\n                    ? \u0027bg-amber-500 border-amber-400 scale-110 shadow-[0_0_50px_rgba(245,158,11,0.4)] text-white\u0027 \\n                    : \u0027bg-white dark:bg-slate-800 border-white dark:border-slate-800 text-slate-400 hover:border-cyan-500 hover:text-cyan-600 dark:hover:text-cyan-400 shadow-xl\u0027\\n                  }`}\\n               \u003e\\n                 {isQuestioning ? \u003cMic className\u003d\\\"w-12 h-12 animate-pulse\\\" /\u003e : \u003cHand className\u003d\\\"w-12 h-12\\\" /\u003e}\\n                 \u003cspan className\u003d{`mt-2 text-[9px] font-bold uppercase tracking-[0.2em] ${isQuestioning ? \u0027text-white\u0027 : \u0027text-slate-400\u0027}`}\u003e\\n                    {isQuestioning ? \u0027Speaking...\u0027 : \u0027Ask a Question\u0027}\\n                 \u003c/span\u003e\\n               \u003c/button\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n\\n        \u003cdiv className\u003d\\\"absolute bottom-8 left-1/2 -translate-x-1/2 flex