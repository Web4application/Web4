ecognition not supported.\\\");\\n    \\n    const rec \u003d new Recognition();\\n    rec.lang \u003d \u0027en-US\u0027;\\n    rec.onstart \u003d () \u003d\u003e setIsListening(true);\\n    rec.onresult \u003d (e: any) \u003d\u003e {\\n      const transcript \u003d e.results[0][0].transcript;\\n      setTopicInput(transcript);\\n      onTopicChange(transcript);\\n    };\\n    rec.onend \u003d () \u003d\u003e setIsListening(false);\\n    rec.start();\\n  };\\n\\n  const allTopicsDone \u003d topics.every(t \u003d\u003e t.isCompleted);\\n\\n  const plans \u003d [\\n    { id: \u0027Standard\u0027, name: \u0027Standard\u0027, icon: Zap, price: \u0027Free\u0027, features: [\u0027STEM Core\u0027, \u0027Physics Lab\u0027], color: \u0027text-slate-400\u0027 },\\n    { id: \u0027Scholar\u0027, name: \u0027Scholar\u0027, icon: Star, price: \u0027$9/mo\u0027, features: [\u0027Engineering\u0027, \u0027Economics\u0027, \u0027Music Theory\u0027], color: \u0027text-cyan-500\u0027 },\\n    { id: \u0027Grandmaster\u0027, name: \u0027Grandmaster\u0027, icon: Crown, price: \u0027$19/mo\u0027, features: [\u0027All Subjects\u0027, \u0027Speech priority\u0027, \u0027Expert levels\u0027], color: \u0027text-amber-500\u0027 },\\n  ];\\n\\n  return (\\n    \u003cdiv className\u003d\\\"flex flex-col h-full bg-white dark:bg-slate-950 border-r border-slate-200 dark:border-white/10 shadow-2xl overflow-hidden\\\"\u003e\\n      \u003cdiv className\u003d\\\"p-8 border-b border-slate-200 dark:border-white/10 flex items-center justify-between\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n            \u003cBookOpen className\u003d\\\"w-5 h-5 text-cyan-600\\\" /\u003e\\n            \u003ch3 className\u003d\\\"text-xs font-bold text-slate-400 uppercase tracking-[0.3em]\\\"\u003eNavigator\u003c/h3\u003e\\n        \u003c/div\u003e\\n        {student \u0026\u0026 (\\n          \u003cbutton onClick\u003d{onLogout} className\u003d\\\"p-2 text-slate-400 hover:text-red-50