0027subjects\u0027);\\n\\n  if (!student) return null;\\n\\n  const categories \u003d [\\n    { id: \u0027class\u0027, label: \u0027In-Session\u0027, icon: Laptop },\\n    { id: \u0027subjects\u0027, label: \u0027Curriculum\u0027, icon: Compass },\\n    { id: \u0027activities\u0027, label: \u0027Activities\u0027, icon: Activity },\\n    { id: \u0027portal\u0027, label: \u0027Portal\u0027, icon: Shield },\\n    { id: \u0027alumni\u0027, label: \u0027Alumni\u0027, icon: Users },\\n  ];\\n\\n  return (\\n    \u003cdiv className\u003d\\\"flex flex-col h-full bg-slate-900 text-white overflow-hidden\\\"\u003e\\n      {/* Header */}\\n      \u003cdiv className\u003d\\\"p-6 border-b border-white/5 flex items-center justify-between\\\"\u003e\\n        \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n            \u003cBookOpen className\u003d\\\"w-5 h-5 text-cyan-500\\\" /\u003e\\n            \u003ch3 className\u003d\\\"text-xs font-bold text-slate-400 uppercase tracking-widest\\\"\u003eAcademic Menu\u003c/h3\u003e\\n        \u003c/div\u003e\\n        \u003cbutton onClick\u003d{onClose} className\u003d\\\"p-2 text-slate-500 hover:text-white transition-colors\\\"\u003e\\n          \u003cX className\u003d\\\"w-5 h-5\\\" /\u003e\\n        \u003c/button\u003e\\n      \u003c/div\u003e\\n\\n      {/* Category Icons */}\\n      \u003cdiv className\u003d\\\"flex border-b border-white/5\\\"\u003e\\n         {categories.map(cat \u003d\u003e (\\n           \u003cbutton \\n             key\u003d{cat.id}\\n             onClick\u003d{() \u003d\u003e setActiveCategory(cat.id as any)}\\n             className\u003d{`flex-1 py-4 flex flex-col items-center gap-1 transition-all ${activeCategory \u003d\u003d\u003d cat.id ? \u0027bg-cyan-600/10 text-cyan-400 border-b-2 border-cyan-500\u0027 : \u0027text-slate-500 hover:text-slate-300\u0027}`}\\n           \u003e\\n             \u003ccat.icon className\u003d\\\"w-5 h-5\\\" /\u003e\\n             \u003cspan className\u003d\\\"text-[8px] font-bold uppercase tracking-tighter\\\"\u003e{cat.label}\u003c/span\u003e\\n           \u003c/button\u003e\\n         ))}\\n      \u003c/div\u003e\\n      \\n      \u003cdiv className\u003d\\\"flex-1 overflow-y-auto p-6 space-y-8 custom-scrollbar\\\"\u003e\\n        {activeCategory \u003d\u003d\u003d \u0027subjects\u0027 \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"space-y-4 animate-in fade-in slide-in-from-right-4\\\"\u003e\\n             \u003cdiv className\u003d\\\"space-y-2\\\"\u003e\\n                \u003cp className\u003d\\\"text-[9px] font-bold text-slate-500 uppercase tracking-widest\\\"\u003eActive Study Paths for {student.major}\u003c/p\u003e\\n                {topics.map((topic) \u003d\u003e (\\n                  \u003cbutton\\n                    key\u003d{topic.id}\\n                    disabled\u003d{topic.isLocked}\\n                    onClick\u003d{() \u003d\u003e onSelect(topic)}\\n                    className\u003d{`w-full text-left p-4 rounded-2xl transition-all border flex items-center justify-between gap-3 ${\\n                      topic.isLocked \\n                      ? \u0027bg-slate-800/50 opacity-40 cursor-not-allowed\u0027\\n                      : currentId \u003d\u003d\u003d topic.id \\n                        ? \u0027bg-cyan-600/20 border-cyan-500/40\u0027 \\n                        : \u0027bg-slate-800/40 border-transparent hover:bg-slate-800\u0027\\n                    }`}\\n                  \u003e\\n                    \u003ch4 className\u003d{`text-xs font-bold ${currentId \u003d\u003d\u003d topic.id ? \u0027text-cyan-400\u0027 : \u0027text-slate-300\u0027}`}\u003e\\n                      {topic.title}\\n                    \u003c/h4\u003e\\n                    {topic.isLocked ? \u003cLock className\u003d\\\"w-3 h-3 text-slate-500\\\" /\u003e : \u003cCircle className\u003d\\\"w-3 h-3 opacity-20\\\" /\u003e}\\n                  \u003c/button\u003e\\n                ))}\\n             \u003c/div\u003e\\n        