raphicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { Sun, Moon, Mic, Hand, Volume2, Menu, X, Award, CheckCircle2, Sparkles, ShieldCheck } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027Indigenous Worldviews\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n  const [isExamMode, setIsExamMode] \u003d useState(false);\\n  const [showPromotion, setShowPromotion] \u003d useState(false);\\n\\n  const [student, setStudent] \u003d useState\u003cStudentProfile | null\u003e(() \u003d\u003e {\\n    const saved \u003d localStorage.getItem(\u0027student_profile\u0027);\\n    return saved ? JSON.parse(saved) : null;\\n  });\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const studyTimerRef \u003d useRef\u003cnumber | null\u003e(null);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027Indigenous Worldviews\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027History\u0027 },\\n    { id: \u00272\u0027, title: \u0027Astrophysics \u0026 Navigation\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Astronomy\u0027, isLocked: true },\\n    { id: \u00273\u0027, title: \u0027Architectural Engineering\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027, isLocked: true },\\n    { id: \u00274\u0027, title: \u0027The Philosophy of Mind\u0027, duration: \u00272.0 hrs\u0027, isCompleted: false, subject: \u0027Philosophy\u0027, isLocked: true },\\n    { id: \u00275\u0027, title: \u0027Quantum Archeology\u0027, duration: \u00271.5 hrs\u0027, isCompleted: false, subject: \u0027Archeology\u0027, isLocked: true },\\n    { id: \u00276\u0027, title: \u0027Ethno-Linguistics\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Linguistics\u0027, isLocked: true },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (student) {\\n      localStorage.setItem(\u0027student_profile\u0027, JSON.stringify(student));\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e {\\n        if (student.tier \u003d\u003d\u003d \u0027Grandmaster\u0027) return { ...t, isLocked: false };\\n        if (student.tier \u003d\u003d\u003d \u0027Scholar\u0027) {\\n          return ([\u0027Philosophy\u0027, \u0027Archeology\u0027, \u0027Linguistics\u0027].includes(t.subject)) ? { ...t, isLocked: true } : { ...t, isLocked: false };\\n        }\\n        return ([\u0027History\u0027, \u0027STEM\u0027, \u0027General\u0027].includes(t.subject)) ? { ...t, isLocked: false } : { ...t, isLocked: true };\\n      }));\\n    }\\n  }, [student]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isLecturing \u0026\u0026 !isExamMode) {\\n      studyTimerRef.current \u003d window.setInterval(() \u003d\u003e {\\n        setStudent(prev \u003d\u003e prev ? { ...prev, currentStudyHours: prev.currentStudyHours + (1/3600) } : null);\\n      }, 1000);\\n    } else {\\n      if (studyTimerRef.current) clearInterval(studyTimerRef.current);\\n    }\\n    return () \u003d\u003e { if (studyTimerRef.current) clearInterval(studyTimerRef.current); };\\n  }, [isLecturing, isExamMode]);\\n\\n  const toggleLecture \u003d async (exam: boolean \u003d false) \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      setIsExamMode(false);\\n      return;\\n    }\\n\\n    // MANDATORY: Check for API key selection when models like gemini-3-pro-image-preview are in use via function calling\\n    if (!(await window.aistudio.hasSelectedApiKey())) {\\n      await window.aistudio.openSelectKey();\\n    }\\n\\n    setIsExamMode(exam);\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) { \\n                  // Reset key selection if entity not found error occurs as per guidelines\\n                  if (e instanceof Error \u0026\u0026 e.message.includes(\\\"Requested entity was not found.\\\")) {\\n                    await window.aistudio.openSelectKey();\\n                  }\\n                  console.error(e); \\n                }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(e),\\n        onclose: () \u003d\u003e { setIsLecturing(false); setIsExamMode(false); }\\n      }, student?.major || \u0027STEM\u0027, exam ? `FINAL EXAM FOR ${currentTopic}` : currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning \u0026\u0026 !exam) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false);\\n    } catch (e) {\\n      console.error(\\\"Session fail\\\", e);\\n    }\\n  };\\n\\n  const handleEnroll \u003d (name: string, major: SubjectArea, schedule: number, tier: SubscriptionTier) \u003d\u003e {\\n    setStudent({\\n      name,\\n      major,\\n      level: \u0027Elementary\u0027,\\n      tier: tier,\\n      enrolledDate: Date.now(),\\n      studyHoursGoal: schedule,\\n      currentStudyHours: 0\\n    });\\n    setComplexityLevel(\u0027Elementary\u0027);\\n  };\\n\\n  const markDone \u003d () \u003d\u003e {\\n    const active \u003d topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic);\\n    if (active) {\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e t.id \u003d\u003d\u003d active.id ? { ...t, isCompleted: true } : t));\\n    }\\n  };\\n\\n  const promoteStudent \u003d () \u003d\u003e {\\n    const levels: ComplexityLevel[] \u003d [\u0027Elementary\u0027, \u0027High School\u0027, \u0027College\u0027, \u0027Expert\u0027];\\n    const currentIdx \u003d levels.indexOf(student?.level || \u0027Elementary\u0027);\\n    if (currentIdx \u003c levels.length - 1) {\\n      const nextLevel \u003d levels[currentIdx + 1];\\n      setStudent(prev \u003d\u003e prev ? { ...prev, level: nextLevel } : null);\\n      setComplexityLevel(nextLevel);\\n      setShowPromotion(true);\\n      setTimeout(() \u003d\u003e setShowPromotion(false), 5000);\\n      setIsExamMode(false);\\n      setIsLecturing(false);\\n      sessionRef.current?.close?.();\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e ({ ...t, isCompleted: false })));\\n    }\\n  };\\n\\n  const handleRegenerate \u003d async (level: ComplexityLevel, style: VisualStyle) \u003d\u003e {\\n    setComplexityLevel(level);\\n    setVisualStyle(style);\\n    if (currentSlide) {\\n      try {\\n        const data \u003d await generateInfographicImage(`Updated visual: ${currentSlide.prompt}. Complexity: ${level}, Style: ${style}`);\\n        setCurrentSlide({ ...currentSlide, data, level, style });\\n      } catch (e) {\\n        if (e instanceof Error \u0026\u0026 e.message.includes(\\\"Requested entity was not found.\\\")) {\\n          await window.aistudio.openSelectKey();\\n        }\\n        console.error(e);\\n      }\\n    }\\n  };\\n\\n  const handleUpdateTier \u003d (tier: SubscriptionTier) \u003d\u003e {\\n    setStudent(prev \u003d\u003e prev ? { ...prev, tier } : null);\\n    setIsSidebarOpen(true);\\n  };\\n\\n  const handleLogout \u003d () \u003d\u003e {\\n    setStudent(null);\\n    localStorage.removeItem(\u0027student_profile\u0027);\\n    setIsSidebarOpen(false);\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans transition-colors overflow-hidden\\\"\u003e\\n      {showIntro \u0026\u0026 \u003cIntroScreen onComplete\u003d{async () \u003d\u003e {\\n        // MANDATORY: Check for API key selection before entering the app\\n        if (!(await window.aistudio.hasSelectedApiKey())) {\\n          await window.aistudio.openSelectKey();\\n        }\\n        setShowIntro(false);\\n      }} studentName\u003d{student?.name} /\u003e}\\n      \\n      \u003cbutton \\n        onClick\u003d{() \u003d\u003e setIsSidebarOpen(!isSidebarOpen)}\\n        className\u003d\\\"fixed top-6 left-6 z-[60] p-4 bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-white/10 hover:scale-105 active:scale-95 transition-all text-cyan-600 dark:text-cyan-400\\\"\\n      \u003e\\n        {isSidebarOpen ? \u003cX className\u003d\\\"w-6 h-6\\\" /\u003e : \u003cMenu className\u003d\\\"w-6 h-6\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      \u003cbutton onClick\u003d{() \u003d\u003e setIsDarkMode(!isDarkMode)} className\u003d\\\"fixed top-8 right-8 z-[60] p-2 rounded-full opacity-20 hover:opacity-100 transition-opacity\\\"\u003e\\n        {isDarkMode ? \u003cSun className\u003d\\\"w-4 h-4\\\" /\u003e : \u003cMoon className\u003d\\\"w-4 h-4\\\" /\u003e}\\n      \u003c/button\u003e\\n\\n      \u003cdiv className\u003d{`fixed inset-0 z-50 transition-opacity duration-500 ${isSidebarOpen ? \u0027opacity-100\u0027 : \u0027opacity-0 pointer-events-none\u0027}`}\u003e\\n          \u003cdiv className\u003d\\\"absolute inset-0 bg-slate-950/40 backdrop-blur-sm\\\" onClick\u003d{() \u003d\u003e setIsSidebarOpen(false)}\u003e\u003c/div\u003e\\n          \u003cdiv className\u003d{`absolute top-0 left-0 h-full w-80 bg-white dark:bg-slate-950 shadow-2xl transition-transform duration-500 transform ${isSidebarOpen ? \u0027translate-x-0\u0027 : \u0027-translate-x-full\u0027}`}\u003e\\n              \u003cSyllabus \\n                topics\u003d{topics} \\n                currentId\u003d{topics.find(t \u003d\u003e t.title \u003d\u003d\u003d currentTopic)?.id || \u00271\u0027} \\n                onSelect\u003d{(t) \u003d\u003e { setCurrentTopic(t.title); setIsSidebarOpen(false); }} \\n                onDone\u003d{markDone}\\n                isLecturing\u003d{isLecturing}\\n                toggleLecture\u003d{toggleLecture}\\n                student\u003d{student}\\n                onEnroll\u003d{handleEnroll}\\n                onTopicChange\u003d{setCurrentTopic}\\n                onPromote\u003d{promoteStudent}\\n                isExamMode\u003d{isExamMode}\\n                onUpdateTier\u003d{handleUpdateTier}\\n                onLogout\u003d{handleLogout}\\n              /\u003e\\n          \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      \u003cmain className\u003d\\\"flex-1 flex flex-col items-center justify-center p-8 relative\\\"\u003e\\n        {showPromotion \u0026\u0026 (\\n          \u003cdiv className\u003d\\\"absolute inset-0 z-[70] flex items-center justify-center bg-cyan-600/20 backdrop-blur-xl animate-in fade-in duration-1000\\\"\u003e\\n             \u003cdiv className\u003d\\\"bg-white dark:bg-slate-900 p-12 rounded-[3rem] shadow-2xl text-center space-y-4 scale-110 border border-cyan-500 relative\\\"\u003e\\n                \u003cdiv className\u003d\\\"absolute -top-12 left-1/2 -translate-x-1/2 bg-cyan-500 p-4 rounded-full shadow-lg\\\"\u003e\\n                  \u003cAward className\u003d\\\"w-12 h-12 text-white animate-bounce\\\" /\u003e\\n                \u003c/div\u003e\\n                \u003ch2 className\u003d\\\"text-4xl font-display font-bold\\\"\u003eAcademic Promotion!\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-500\\\"\u003eCongratulations! You have been elevated to \u003cb\u003e{student?.level}\u003c/b\u003e level.\u003c/p\u003e\\n                \u003cdiv className\u003d\\\"flex justify-center gap-2 text-emerald-500 items-center\\\"\u003e\\n                   \u003cCheckCircle2 className\u003d\\\"w-6 h-6\\\" /\u003e\\n                   \u003cspan className\u003d\\\"font-bold text-sm uppercase tracking-widest\\\"\u003eUniversity Credits Issued\u003c/span\u003e\\n                \u003c/div\u003e\\n                \u003cbutton onClick\u003d{() \u003d\u003e setShowPromotion(false)} className\u003d\\\"mt-6 px-6 py-2 bg-slate-100 dark:bg-slate-800 rounded-full text-xs font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors\\\"\u003eDismiss\u003c/button\u003e\\n             \u003c/div\u003e\\n          \u003c/div\u003e\\n        )}\\n\\n        \u003cdiv className\u003d\\\"max-w-5xl w-full flex flex-col items-center gap-12\\\"\u003e\\n            \u003cdiv className\u003d\\\"w-full relative\\\"\u003e\\n               {currentSlide ? (\\n                  \u003cInfographic \\n                    image\u003d{currentSlide} \\n                    onEdit\u003d{() \u003d\u003e {}} \\n                    onRegenerate\u003d{handleRegenerate}\\n                    isEditing\u003d{false}\\n                  /\u003e\\n               ) : (\\n                  \u003cdiv className\u003d\\\"aspect-video w-full bg-white dark:bg-slate-900 rounded-[3rem] border border-slate-200 dark:border-white/5 shadow-2xl flex flex-col items-center justify-center gap-6 group\\\"\u003e\\n                    \u003cdiv className\u003d\\\"relative\\\"\u003e\\n                      \u003cVolume2 className\u003d\\\"w-20 h-20 opacity-10 group-hover:opacity-20 transition-opacity\\\" /\u003e\\n                      {isLecturing \u0026\u0026 \u003cdiv className\u003d\\\"absolute inset-0 border-2 border-cyan-500 rounded-full animate-ping opacity-20\\\"\u003e\u003c/div\u003e}\\n                    \u003c/div\u003e\\n                    \u003cdiv className\u003d\\\"text-center space-y-2 opacity-30\\\"\u003e\\n                        \u003cp className\u003d\\\"font-display font-bold uppercase tracking-[0.3em] text-sm\\\"\u003eInteractive Hall\u003c/p\u003e\\n                        \u003cp className\u003d\\\"text-xs italic\\\"\u003e{isLecturing ? \\\"Professor Alpha is preparing insights...\\\" : \\\"Open Navigator to enroll and begin your session\\\"}\u003c/p\u003e\\n                    \u003c/div\u003e\\n                  \u003c/div\u003e\\n               )}\\n\\n               {isLecturing \u0026\u0026 (\\n                 \u003cdiv className\u003d\\\"absolute top-6 right-6 flex items-center gap-2 bg-emerald-500/90 backdrop-blur-md text-white px-4 py-2 rounded-full text-[10px] font-bold shadow-lg\\\"\u003e\\n                    \u003cSparkles className\u003d\\\"w-3 h-3 animate-pulse\\\" /\u003e\\n                    {isExamMode ? \u0027EXAMINATION IN SESSION\u0027 : \u0027LECTURE IN PROGRESS\u0027}\\n                 \u003c/div\u003e\\n               )}\\n            \u003c/div\u003e\\n\\n            \u003cdiv className\u003d\\\"relative\\\"\u003e\\n               \u003cbutton \\n                  onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)}\\n                  disabled\u003d{!isLecturing || isExamMode}\\n                  className\u003d{`flex flex-col items-center justify-center w-40 h-40 rounded-full border-8 transition-all disabled:opacity-20 disabled:scale-90 ${\\n                    isQuestioning \\n                    ? \u0027bg-amber-500 border-amber-400 scale-110 shadow-[0_0_50px_rgba(245,158,11,0.4)] text-white\u0027 \\n                    : \u0027bg-white dark:bg-slate-800 border-white dark:border-slate-800 text-slate-400 hover:border-cyan-500 hover:text-cyan-600 dark:hover:text-cyan-400 shadow-xl\u0027\\n                  }`}\\n               \u003e\\n                 {isQuestioning ? \u003cMic className\u003d\\\"w-12 h-12 animate-pulse\\\" /\u003e : \u003cHand className\u003d\\\"w-12 h-12\\\" /\u003e}\\n                 \u003cspan className\u003d{`mt-2 text-[9px] font-bold uppercase tracking-[0.2em] ${isQuestioning ? \u0027text-white\u0027 : \u0027text-slate-400\u0027}`}\u003e\\n                    {isQuestioning ? \u0027Speaking...\u0027 : \u0027I have a question\u0027}\\n                 \u003c/span\u003e\\n               \u003c/button\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n\\n        \u003cdiv className\u003d\\\"absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-6 px-8 py-3 bg-white/70 dark:bg-slate-900/70 rounded-full backdrop-blur-xl border border-slate-200 dark:border-white/5 shadow-sm text-slate-400\\\"\u003e\\n            \u003cdiv className\u003d\\\"flex items-center gap-2\\\"\u003e\\n               \u003cdiv className\u003d\\\"flex items-center gap-1.5\\\"\u003e\\n                  \u003cShieldCheck className\u003d{`w-3 h-3 ${student?.tier \u003d\u003d\u003d \u0027Grandmaster\u0027 ? \u0027text-amber-500\u0027 : student?.tier \u003d\u003d\u003d \u0027Scholar\u0027 ? \u0027text-cyan-500\u0027 : \u0027text-slate-400\u0027}`} /\u003e\\n                  \u003cspan className\u003d\\\"text-[9px] font-bold uppercase tracking-widest text-slate-600 dark:text-slate-300\\\"\u003e{student?.name || \u0027Guest Student\u0027}\u003c/span\u003e\\n               \u003c/div\u003e\\n               \u003cdiv className\u003d\\\"w-1 h-1 bg-cyan-500 rounded-full\\\"\u003e\u003c/div\u003e\\n               \u003cspan className\u003d\\\"text-[9px] font-bold uppercase tracking-widest\\\"\u003e{student?.major || \u0027Undeclared\u0027}\u003c/span\u003e\\n            \u003c/div\u003e\\n            \u003cdiv className\u003d\\\"w-px h-3 bg-slate-300 dark:bg-slate-800\\\"\u003e\u003c/div\u003e\\n            \u003cspan className\u003d\\\"text-[9px] font-bold uppercase tracking-widest text-cyan-500 font-display\\\"\u003e{student?.level || \u0027Preparatory\u0027}\u003c/span\u003e\\n            {student \u0026\u0026 (\\n               \u003cdiv className\u003d\\\"flex items-center gap-3\\\"\u003e\\n                  \u003cdiv className\u003d\\\"w-16 h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden\\\"\u003e\\n                     \u003cdiv \\n                        className\u003d\\\"h-full bg-cyan-500 transition-all duration-1000\\\" \\n                        style\u003d{{ width: `${Math.min(100, (student.currentStudyHours / student.studyHoursGoal) * 100)}%` }}\\n                     \u003e\u003c/div\u003e\\n                  \u003c/div\u003e\\n                  \u003cspan className\u003d\\\"text-[8px] font-bold font-mono tracking-tighter\\\"\u003e\\n                    {Math.floor(student.currentStudyHours * 60)}M / {student.studyHoursGoal}H\\n                  \u003c/span\u003e\\n               \u003c/div\u003e\\n            )}\\n        \u003c/div\u003e\\n      \u003c/main\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default App;\\n\"}]}]},\"createdTimestamp\":{\"seconds\":1767888815,\"nanos\":132000000},\"doneTimestamp\":{\"seconds\":1767888834,\"nanos\":625000000}},{\"id\":223,\"author\":\"user\",\"payload\":{\"type\":\"text\",\"text\":\"Simulate virtually the future of learning once user installed this program with a display message welcome to the future of learning a voice delivery to be precise, after the delivery message an enrolment botton fir new user and login botton for current users , next page after that fur new users details and information page consisting of name are address past education information what exactly does new users wants to study ( this will set up gemini on what to handle about new users ) after the enrolment straight to dashboard \\nThe dashboard will only have one botton menu under menu we have class , students portal,subjects , learning activities and alumni \\nEach category should be set up and structured configured according to students information taken\",\"files\":[],\"fileUploads\":[],\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767889518,\"nanos\":989000000}},{\"id\":224,\"author\":\"model\",\"payload\":{\"type\":\"thinking\",\"text\":\"**Conceptualizing Learning\u0027s Future**\\n\\nI\u0027m focusing on the user\u0027s request: simulating a future learning experience. I envision a welcome message delivered via voice. My initial screen will offer enrollment for new users and login for returning ones. I\u0027m now exploring the enrollment process.\\n\\n\\n**Refining Enrollment Process**\\n\\nI\u0027m now delving into the new user enrollment flow, specifying details like name, address, and past education. The \\\"Area of Study\\\" selection will tailor Gemini\u0027s focus. Post-enrollment, I\u0027m setting the dashboard as the immediate destination, accessible by a prominent menu button. I\u0027m structuring classes, student portals, subjects, learning activities, and alumni sections, all tailored to the user\u0027s data. I\u0027m updating the intro screen and designing app components for navigation.\\n\\n\\n**Developing Menu Navigation**\\n\\nI\u0027m now iterating on the menu logic and the dashboard\u0027s single-button interface. The design focuses on categories: Classes link to lectures; Student Portals display profiles and subscriptions; Subjects reveal syllabi; Learning Activities include quizzes; and Alumni offer a community space. I\u0027m leveraging `gemini-2.5-flash-preview-tts` and `gemini-2.5-flash-native-audio-preview-12-2025` for TTS and native audio interactions, potentially using `gemini-3-pro-image-preview` for visuals if necessary. I\u0027ll need to adjust `types.ts`, `IntroScreen.tsx`, and `App.tsx` for these menu updates.\\n\\n\\n**Integrating New Components**\\n\\nI\u0027ve just added `Dashboard.tsx` with its vital Menu button. Following this, `UniversityMenu.tsx` is implemented for the categorized views. I\u0027m prioritizing the implementation of Text-to-Speech in the Intro screen. I\u0027m focusing on ensuring these components seamlessly integrate, establishing the core navigation.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767889518,\"nanos\":989000000},\"doneTimestamp\":{\"seconds\":1767889529,\"nanos\":582000000}},{\"id\":225,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"types.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Expanded StudentProfile to include address and past education for personalized AI configuration.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nexport type AspectRatio \u003d \u002716:9\u0027 | \u00279:16\u0027 | \u00271:1\u0027;\\n\\nexport type ComplexityLevel \u003d \u0027Elementary\u0027 | \u0027High School\u0027 | \u0027College\u0027 | \u0027Expert\u0027;\\n\\nexport type SubscriptionTier \u003d \u0027Standard\u0027 | \u0027Scholar\u0027 | \u0027Grandmaster\u0027;\\n\\nexport type SubjectArea \u003d \\n  | \u0027STEM\u0027 \\n  | \u0027History\u0027 \\n  | \u0027Biology\u0027 \\n  | \u0027Physics\u0027 \\n  | \u0027Geography\u0027 \\n  | \u0027Literature\u0027 \\n  | \u0027Engineering\u0027 \\n  | \u0027Economics\u0027\\n  | \u0027Music Theory\u0027\\n  | \u0027Philosophy\u0027\\n  | \u0027Archeology\u0027\\n  | \u0027Linguistics\u0027\\n  | \u0027Astronomy\u0027\\n  | \u0027General\u0027;\\n\\nexport type VisualStyle \u003d \u0027Default\u0027 | \u0027Minimalist\u0027 | \u0027Realistic\u0027 | \u0027Cartoon\u0027 | \u0027Vintage\u0027 | \u0027Futuristic\u0027 | \u00273D Render\u0027 | \u0027Sketch\u0027;\\n\\nexport type Language \u003d \u0027English\u0027 | \u0027Spanish\u0027 | \u0027French\u0027 | \u0027German\u0027 | \u0027Mandarin\u0027 | \u0027Japanese\u0027 | \u0027Hindi\u0027 | \u0027Arabic\u0027 | \u0027Portuguese\u0027 | \u0027Russian\u0027;\\n\\nexport interface StudentProfile {\\n  name: string;\\n  address: string;\\n  pastEducation: string;\\n  major: SubjectArea;\\n  level: ComplexityLevel;\\n  tier: SubscriptionTier;\\n  enrolledDate: number;\\n  studyHoursGoal: number;\\n  currentStudyHours: number;\\n}\\n\\n/**\\n * Interface representing a course topic in the syllabus.\\n */\\nexport interface CourseTopic {\\n  id: string;\\n  title: string;\\n  duration: string;\\n  isCompleted: boolean;\\n  subject: SubjectArea;\\n  isLocked?: boolean;\\n}\\n\\nexport interface GeneratedImage {\\n  id: string;\\n  data: string; // Base64 data URL\\n  prompt: string;\\n  timestamp: number;\\n  level?: ComplexityLevel;\\n  style?: VisualStyle;\\n  language?: Language;\\n  subject?: SubjectArea;\\n}\\n\\nexport interface SearchResultItem {\\n  title: string;\\n  url: string;\\n}\\n\\nexport interface ResearchResult {\\n  imagePrompt: string;\\n  facts: string[];\\n  searchResults: SearchResultItem[];\\n}\\n\\ndeclare global {\\n  interface AIStudio {\\n    hasSelectedApiKey: () \u003d\u003e Promise\u003cboolean\u003e;\\n    openSelectKey: () \u003d\u003e Promise\u003cvoid\u003e;\\n  }\\n  interface Window {\\n    SpeechRecognition: any;\\n    webkitSpeechRecognition: any;\\n  }\\n}\\n\"}]},{\"path\":\"services/geminiService.ts\",\"generationType\":1,\"isDone\":true,\"description\":\"Added TTS support for the welcome message and updated lecturer instructions to use specific student background info.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport { GoogleGenAI, FunctionDeclaration, Modality, Type } from \\\"@google/genai\\\";\\nimport { ComplexityLevel, VisualStyle, ResearchResult, SearchResultItem, Language, SubjectArea, StudentProfile } from \\\"../types\\\";\\n\\nconst getAi \u003d () \u003d\u003e {\\n  return new GoogleGenAI({ apiKey: process.env.API_KEY });\\n};\\n\\nconst TEXT_MODEL \u003d \u0027gemini-3-pro-preview\u0027;\\nconst IMAGE_MODEL \u003d \u0027gemini-3-pro-image-preview\u0027;\\n\\n/**\\n * Generates audio for the welcome message using TTS.\\n */\\nexport const generateWelcomeAudio \u003d async (text: string) \u003d\u003e {\\n  const ai \u003d getAi();\\n  const response \u003d await ai.models.generateContent({\\n    model: \\\"gemini-2.5-flash-preview-tts\\\",\\n    contents: [{ parts: [{ text }] }],\\n    config: {\\n      responseModalities: [Modality.AUDIO],\\n      speechConfig: {\\n        voiceConfig: {\\n          prebuiltVoiceConfig: { voiceName: \u0027Kore\u0027 },\\n        },\\n      },\\n    },\\n  });\\n  return response.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;\\n};\\n\\n/**\\n * Establishes a real-time speech-to-speech lecture or exam session.\\n */\\nexport const connectLecturer \u003d (\\n  callbacks: any,\\n  student: StudentProfile,\\n  topic: string\\n) \u003d\u003e {\\n  const ai \u003d getAi();\\n  const isExam \u003d topic.includes(\\\"FINAL EXAM\\\");\\n  \\n  const renderVisualTool: FunctionDeclaration \u003d {\\n    name: \u0027render_visual\u0027,\\n    parameters: {\\n      type: Type.OBJECT,\\n      description: \u0027Generate and render a detailed educational visual or infographic to clarify complex concepts.\u0027,\\n      properties: {\\n        description: {\\n          type: Type.STRING,\\n          description: \u0027A detailed, vivid description of the visual to be rendered.\u0027\\n        }\\n      },\\n      required: [\u0027description\u0027]\\n    }\\n  };\\n\\n  const instruction \u003d isExam \\n    ? `You are Professor Alpha, a kind academic examiner. The student, ${student.name}, has a background in ${student.pastEducation} and is now testing for ${topic}.\\n       1. Tailor questions to their past experience in ${student.address || \u0027their region\u0027} where applicable.\\n       2. Ask 3-5 challenging questions verbally.\\n       3. Listen carefully to responses and provide immediate feedback.`\\n    : `You are Professor Alpha, a world-class lecturer for ${student.major}. \\n       Explain \\\"${topic}\\\" to ${student.name}, who previously studied ${student.pastEducation}. \\n       Keep the tone warm and mentor-like. Use their location ${student.address} for local analogies if possible.\\n       Use \u0027render_visual\u0027 to show infographics during your explanation.`;\\n\\n  return ai.live.connect({\\n    model: \u0027gemini-2.5-flash-native-audio-preview-12-2025\u0027,\\n    callbacks,\\n    config: {\\n      responseModalities: [Modality.AUDIO],\\n      systemInstruction: instruction,\\n      tools: [{ functionDeclarations: [renderVisualTool] }],\\n      speechConfig: {\\n        voiceConfig: { prebuiltVoiceConfig: { voiceName: \u0027Charon\u0027 } }\\n      }\\n    }\\n  });\\n};\\n\\nexport const researchTopicForPrompt \u003d async (\\n  topic: string, \\n  level: ComplexityLevel, \\n  style: VisualStyle,\\n  language: Language,\\n  subject: SubjectArea \u003d \u0027General\u0027\\n): Promise\u003cResearchResult\u003e \u003d\u003e {\\n  const ai \u003d getAi();\\n  const response \u003d await ai.models.generateContent({\\n    model: TEXT_MODEL,\\n    contents: `Research the topic \\\"${topic}\\\" for a ${level} level lecture in ${subject}. Provide 5 facts and an image prompt for a ${style} infographic.`,\\n    config: { tools: [{ googleSearch: {} }] },\\n  });\\n\\n  const text \u003d response.text || \\\"\\\";\\n  const facts \u003d text.split(\u0027\\\\n\u0027).filter(l \u003d\u003e l.includes(\u0027-\u0027)).slice(0, 5);\\n  const imagePrompt \u003d `Educational visual about ${topic}, ${style} style, ${level} complexity.`;\\n\\n  const searchResults: SearchResultItem[] \u003d [];\\n  response.candidates?.[0]?.groundingMetadata?.groundingChunks?.forEach(chunk \u003d\u003e {\\n    if (chunk.web?.uri \u0026\u0026 chunk.web?.title) {\\n      searchResults.push({ title: chunk.web.title, url: chunk.web.uri });\\n    }\\n  });\\n\\n  return { imagePrompt, facts, searchResults };\\n};\\n\\nexport const generateInfographicImage \u003d async (prompt: string): Promise\u003cstring\u003e \u003d\u003e {\\n  const response \u003d await getAi().models.generateContent({\\n    model: IMAGE_MODEL,\\n    contents: { parts: [{ text: prompt }] },\\n    config: { imageConfig: { aspectRatio: \\\"16:9\\\", imageSize: \\\"1K\\\" } }\\n  });\\n\\n  const parts \u003d response.candidates?.[0]?.content?.parts || [];\\n  for (const part of parts) {\\n    if (part.inlineData?.data) {\\n      return `data:image/png;base64,${part.inlineData.data}`;\\n    }\\n  }\\n  throw new Error(\\\"Visual generation failed.\\\");\\n};\\n\"}]},{\"path\":\"App.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Implemented the new flow: Intro -\u003e Login/Enroll -\u003e Form -\u003e Dashboard. Dashboard now features a single \u0027Menu\u0027 button as requested.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SubjectArea, CourseTopic, StudentProfile, SubscriptionTier } from \u0027./types\u0027;\\nimport { connectLecturer, generateInfographicImage } from \u0027./services/geminiService\u0027;\\nimport { decode, decodeAudioData, createBlob } from \u0027./services/audioService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Syllabus from \u0027./components/Syllabus\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport { Sun, Moon, Mic, Hand, Volume2, Menu, X, Award, CheckCircle2, Sparkles, ShieldCheck, GraduationCap, ArrowLeft, UserCircle, MapPin, Book, Heart } from \u0027lucide-react\u0027;\\n\\ntype ViewState \u003d \u0027intro\u0027 | \u0027auth\u0027 | \u0027enroll\u0027 | \u0027dashboard\u0027 | \u0027class\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [view, setView] \u003d useState\u003cViewState\u003e(\u0027intro\u0027);\\n  const [currentTopic, setCurrentTopic] \u003d useState\u003cstring\u003e(\u0027Indigenous Worldviews\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Realistic\u0027);\\n  \\n  const [isLecturing, setIsLecturing] \u003d useState(false);\\n  const [isQuestioning, setIsQuestioning] \u003d useState(false);\\n  const [currentSlide, setCurrentSlide] \u003d useState\u003cGeneratedImage | null\u003e(null);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n  const [isSidebarOpen, setIsSidebarOpen] \u003d useState(false);\\n  const [isExamMode, setIsExamMode] \u003d useState(false);\\n  const [showPromotion, setShowPromotion] \u003d useState(false);\\n\\n  const [student, setStudent] \u003d useState\u003cStudentProfile | null\u003e(() \u003d\u003e {\\n    const saved \u003d localStorage.getItem(\u0027student_profile\u0027);\\n    return saved ? JSON.parse(saved) : null;\\n  });\\n\\n  // Enrollment form state\\n  const [enrollForm, setEnrollForm] \u003d useState({\\n    name: \u0027\u0027,\\n    address: \u0027\u0027,\\n    pastEducation: \u0027\u0027,\\n    major: \u0027History\u0027 as SubjectArea,\\n    tier: \u0027Standard\u0027 as SubscriptionTier\\n  });\\n\\n  // Audio refs\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const outputAudioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n  const sessionRef \u003d useRef\u003cany\u003e(null);\\n  const nextStartTimeRef \u003d useRef(0);\\n  const sourcesRef \u003d useRef\u003cSet\u003cAudioBufferSourceNode\u003e\u003e(new Set());\\n  const studyTimerRef \u003d useRef\u003cnumber | null\u003e(null);\\n\\n  const [topics, setTopics] \u003d useState\u003cCourseTopic[]\u003e([\\n    { id: \u00271\u0027, title: \u0027Indigenous Worldviews\u0027, duration: \u00271.2 hrs\u0027, isCompleted: false, subject: \u0027History\u0027 },\\n    { id: \u00272\u0027, title: \u0027Astrophysics \u0026 Navigation\u0027, duration: \u00272.5 hrs\u0027, isCompleted: false, subject: \u0027Astronomy\u0027, isLocked: true },\\n    { id: \u00273\u0027, title: \u0027Architectural Engineering\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Engineering\u0027, isLocked: true },\\n    { id: \u00274\u0027, title: \u0027The Philosophy of Mind\u0027, duration: \u00272.0 hrs\u0027, isCompleted: false, subject: \u0027Philosophy\u0027, isLocked: true },\\n    { id: \u00275\u0027, title: \u0027Quantum Archeology\u0027, duration: \u00271.5 hrs\u0027, isCompleted: false, subject: \u0027Archeology\u0027, isLocked: true },\\n    { id: \u00276\u0027, title: \u0027Ethno-Linguistics\u0027, duration: \u00271.8 hrs\u0027, isCompleted: false, subject: \u0027Linguistics\u0027, isLocked: true },\\n  ]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) document.documentElement.classList.add(\u0027class\u0027, \u0027dark\u0027);\\n    else document.documentElement.classList.remove(\u0027dark\u0027);\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    if (student) {\\n      localStorage.setItem(\u0027student_profile\u0027, JSON.stringify(student));\\n      setTopics(prev \u003d\u003e prev.map(t \u003d\u003e {\\n        if (student.tier \u003d\u003d\u003d \u0027Grandmaster\u0027) return { ...t, isLocked: false };\\n        if (student.tier \u003d\u003d\u003d \u0027Scholar\u0027) {\\n          return ([\u0027Philosophy\u0027, \u0027Archeology\u0027, \u0027Linguistics\u0027].includes(t.subject)) ? { ...t, isLocked: true } : { ...t, isLocked: false };\\n        }\\n        return ([\u0027History\u0027, \u0027STEM\u0027, \u0027General\u0027].includes(t.subject)) ? { ...t, isLocked: false } : { ...t, isLocked: true };\\n      }));\\n    }\\n  }, [student]);\\n\\n  const toggleLecture \u003d async (exam: boolean \u003d false) \u003d\u003e {\\n    if (isLecturing) {\\n      sessionRef.current?.close?.();\\n      setIsLecturing(false);\\n      setIsExamMode(false);\\n      return;\\n    }\\n\\n    if (!(await window.aistudio.hasSelectedApiKey())) {\\n      await window.aistudio.openSelectKey();\\n    }\\n\\n    setIsExamMode(exam);\\n\\n    try {\\n      const audioCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });\\n      const outputCtx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n      audioContextRef.current \u003d audioCtx;\\n      outputAudioContextRef.current \u003d outputCtx;\\n\\n      const stream \u003d await navigator.mediaDevices.getUserMedia({ audio: true });\\n      const source \u003d audioCtx.createMediaStreamSource(stream);\\n      const scriptProcessor \u003d audioCtx.createScriptProcessor(4096, 1, 1);\\n\\n      const sessionPromise \u003d connectLecturer({\\n        onopen: () \u003d\u003e {\\n          source.connect(scriptProcessor);\\n          scriptProcessor.connect(audioCtx.destination);\\n        },\\n        onmessage: async (message: any) \u003d\u003e {\\n          const base64Audio \u003d message.serverContent?.modelTurn?.parts[0]?.inlineData?.data;\\n          if (base64Audio \u0026\u0026 outputAudioContextRef.current) {\\n            const ctx \u003d outputAudioContextRef.current;\\n            nextStartTimeRef.current \u003d Math.max(nextStartTimeRef.current, ctx.currentTime);\\n            const audioBuffer \u003d await decodeAudioData(decode(base64Audio), ctx, 24000, 1);\\n            const sourceNode \u003d ctx.createBufferSource();\\n            sourceNode.buffer \u003d audioBuffer;\\n            sourceNode.connect(ctx.destination);\\n            sourceNode.start(nextStartTimeRef.current);\\n            nextStartTimeRef.current +\u003d audioBuffer.duration;\\n            sourcesRef.current.add(sourceNode);\\n            sourceNode.onended \u003d () \u003d\u003e sourcesRef.current.delete(sourceNode);\\n          }\\n\\n          if (message.serverContent?.interrupted) {\\n            sourcesRef.current.forEach(s \u003d\u003e s.stop());\\n            sourcesRef.current.clear();\\n            nextStartTimeRef.current \u003d 0;\\n          }\\n\\n          if (message.toolCall) {\\n            for (const fc of message.toolCall.functionCalls) {\\n              if (fc.name \u003d\u003d\u003d \u0027render_visual\u0027) {\\n                try {\\n                  const data \u003d await generateInfographicImage(fc.args.description);\\n                  setCurrentSlide({\\n                    id: Date.now().toString(),\\n                    data,\\n                    prompt: fc.args.description,\\n                    timestamp: Date.now(),\\n                    level: complexityLevel,\\n                    style: visualStyle\\n                  });\\n                  sessionPromise.then(s \u003d\u003e s.sendToolResponse({\\n                    functionResponses: { id: fc.id, name: fc.name, response: { result: \\\"Visual aid updated.\\\" } }\\n                  }));\\n                } catch (e) { \\n                  if (e instanceof Error \u0026\u0026 e.message.includes(\\\"Requested entity was not found.\\\")) {\\n                    await window.aistudio.openSelectKey();\\n                  }\\n                }\\n              }\\n            }\\n          }\\n        },\\n        onerror: (e: any) \u003d\u003e console.error(e),\\n        onclose: () \u003d\u003e { setIsLecturing(false); setIsExamMode(false); }\\n      }, student!, exam ? `FINAL EXAM FOR ${currentTopic}` : currentTopic);\\n\\n      scriptProcessor.onaudioprocess \u003d (e) \u003d\u003e {\\n        if (!isQuestioning \u0026\u0026 !exam) return;\\n        const inputData \u003d e.inputBuffer.getChannelData(0);\\n        const pcmBlob \u003d createBlob(inputData);\\n        sessionPromise.then(session \u003d\u003e session.sendRealtimeInput({ media: pcmBlob }));\\n      };\\n\\n      sessionRef.current \u003d await sessionPromise;\\n      setIsLecturing(true);\\n      setIsSidebarOpen(false);\\n    } catch (e) {\\n      console.error(\\\"Session fail\\\", e);\\n    }\\n  };\\n\\n  const handleEnrollSubmit \u003d (e: React.FormEvent) \u003d\u003e {\\n    e.preventDefault();\\n    if (enrollForm.name) {\\n      const newStudent: StudentProfile \u003d {\\n        ...enrollForm,\\n        level: \u0027Elementary\u0027,\\n        enrolledDate: Date.now(),\\n  