c/button\u003e\\n      \u003cmain className\u003d\\\"flex-1 flex flex-col items-center justify-center p-8 relative overflow-y-auto\\\"\u003e\\n        \u003cdiv className\u003d\\\"max-w-5xl w-full flex flex-col items-center gap-12 pt-16\\\"\u003e\\n            \u003cdiv className\u003d\\\"w-full relative\\\"\u003e\\n               {currentSlide ? (\\n                  \u003cInfographic \\n                    image\u003d{currentSlide} \\n                    onEdit\u003d{handleEditPrompt} \\n                    onRegenerate\u003d{handleRegenerate} \\n                    isEditing\u003d{isGeneratingVisual} \\n                  /\u003e\\n               ) : (\\n                  \u003cdiv className\u003d\\\"aspect-video w-full bg-slate-900 rounded-[3rem] border border-white/5 shadow-2xl flex flex-col items-center justify-center gap-6\\\"\u003e\\n                    \u003cVolume2 className\u003d\\\"w-20 h-20 opacity-10 animate-pulse\\\" /\u003e\\n                    \u003cdiv className\u003d\\\"text-center space-y-2 opacity-30\\\"\u003e\\n                        \u003cp className\u003d\\\"font-display font-bold uppercase tracking-[0.3em] text-sm\\\"\u003e{currentTopic}\u003c/p\u003e\\n                        \u003cp className\u003d\\\"text-xs italic\\\"\u003e{isLecturing ? \\\"Professor Alpha is transmitting knowledge...\\\" : \\\"Ready to begin study session\\\"}\u003c/p\u003e\\n                    \u003c/div\u003e\\n                  \u003c/div\u003e\\n               )}\\n            \u003c/div\u003e\\n            \u003cdiv className\u003d\\\"relative pb-24\\\"\u003e\\n               \u003cbutton onClick\u003d{() \u003d\u003e setIsQuestioning(!isQuestioning)} disabled\u003d{!isLecturing} className\u003d{`flex flex-col items-center justify-center w-40 h-40 rounded-full border-8 transition-all disabled:opacity-20 ${isQuestioning ? \u0027bg-amber-500 border-amber-400 scale-110 shadow-[0_0_50px_rgba(245,158,11,0.4)]\u0027 : \u0027bg-slate-900 border-white/5 text-slate-500 hover:text-cyan-400\u0027}`}\u003e\\n                 {isQuestioning ? \u003cMic className\u003d\\\"w-12 h-12 animate-pulse\\\" /\u003e : \u003cHand className\u003d\\\"w-12 h-12\\\" /\u003e}\\n                 \u003cspan className\u003d{`mt-2 text-[9px] font-bold uppercase tracking-[0.2em] ${isQuestioning ? \u0027text-white\u0027 : \u0027text-slate-500\u0027}`}\u003e{isQuestioning ? \u0027Speaking...\u0027 : \u0027Ask Question\u0027}\u003c/span\u003e\\n               \u003c/button\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n        \u003cdiv className\u003d\\\"fixed bottom-8 left-1/2 -translate-x-1/2 z-50\\\"\u003e\\n             \u003cbutton onClick\u003d{() \u003d\u003e toggleLecture(false)} className\u003d{`py-4 px-12 rounded-2xl font-bold text-xs flex items-center gap-3 transition-all ${isLecturing ? \u0027bg-red-500 text-white\u0027 : \u0027bg-cyan-600 text-white hover:bg-cyan-500 shadow-2xl shadow-cyan-600/20\u0027}`}\u003e\\n                {isLecturing ? \u003cSquare className\u003d\\\"w-4 h-4 fill-current\\\" /\u003e : \u003cPlay className\u003d\\\"w-4 h-4 fill-current\\\" /\u003e}\\n                {isLecturing ? \u0027STOP LECTURE\u0027 : \u0027START SESSION\u0027}\\n            \u003c/button\u003e\\n        \u003c/div\u003e\\n      \u003c/main\u003e\\n    \u003c/div\u003e\\n  );\\n};\\n\\nexport default App;\\n\"}]},{\"path\":\"components/IntroScreen.tsx\",\"generationType\":1,\"isDone\":true,\"description\":\"Updated to use the renamed decodePCM16 function for robust raw audio decoding.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect, useRef } from \u0027react\u0027;\\nimport { Play, GraduationCap, Globe, BookOpen, Lightbulb, Sparkles, Volume2 } from \u0027lucide-react\u0027;\\nimport { generateWelcomeAudio } from \u0027../services/geminiService\u0027;\\nimport { decode, decodePCM16 } from \u0027../services/audioService\u0027;\\n\\ninterface IntroScreenProps {\\n  onComplete: () \u003d\u003e void;\\n  studentName?: string;\\n}\\n\\nconst IntroScreen: React.FC\u003cIntroScreenProps\u003e \u003d ({ onComplete, studentName }) \u003d\u003e {\\n  const [phase, setPhase] \u003d useState(0); \\n  const [isSpeaking, setIsSpeaking] \u003d useState(false);\\n  const audioContextRef \u003d useRef\u003cAudioContext | null\u003e(null);\\n\\n  useEffect(() \u003d\u003e {\\n    // Initial delay for ambient visuals\\n    const timer1 \u003d setTimeout(() \u003d\u003e setPhase(1), 1000);\\n    return () \u003d\u003e clearTimeout(timer1);\\n  }, []);\\n\\n  const playWelcomeSpeech \u003d async () \u003d\u003e {\\n    setIsSpeaking(true);\\n    const welcomeText \u003d studentName \\n      ? `Welcome back, ${studentName}, to the future of learning. Our vision terminal is ready to expand your mind.`\\n      : \\\"Welcome to the future of learning - a voice delivery to be precise. Welcome to Info-Genius Academy.\\\";\\n    \\n    try {\\n      const base64Audio \u003d await generateWelcomeAudio(welcomeText);\\n      if (base64Audio) {\\n        // Sample rate for Gemini TTS is typically 24000Hz\\n        const ctx \u003d new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 24000 });\\n        audioContextRef.current \u003d ctx;\\n        \\n        // CRITICAL: Must use custom PCM decoder for raw streams\\n        const audioBuffer \u003d decodePCM16(decode(base64Audio), ctx, 24000, 1);\\n        \\n        const source \u003d ctx.createBufferSource();\\n        source.buffer \u003d audioBuffer;\\n        source.connect(ctx.destination);\\n        source.onended \u003d () \u003d\u003e {\\n          setIsSpeaking(false);\\n          setPhase(2);\\n          setTimeout(() \u003d\u003e setPhase(3), 500);\\n        };\\n        source.start();\\n      } else {\\n        // Fallback if audio fails\\n        setPhase(2);\\n        setTimeout(() \u003d\u003e setPhase(3), 500);\\n      }\\n    } catch (e) {\\n      console.error(\\\"Audio playback error:\\\", e);\\n      setPhase(2);\\n      setTimeout(() \u003d\u003e setPhase(3), 500);\\n    }\\n  };\\n\\n  return (\\n    \u003cdiv className\u003d\\\"fixed inset-0 z-[100] bg-slate-950 flex flex-col items-center justify-center overflow-hidden font-display\\\"\u003e\\n      \u003cdiv className\u003d\\\"absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-cyan-900/30 via-slate-950 to-black\\\"\u003e\u003c/div\u003e\\n      \\n      \u003cdiv className\u003d\\\"relative w-80 h-80 flex items-center justify-center perspective-1000\\\"\u003e\\n        \u003cdiv className\u003d{`relative transition-all duration-1000 ${phase \u003e\u003d 2 ? \u0027scale-125\u0027 : \u0027scale-100\u0027}`}\u003e\\n            \u003cdiv \\n              onClick\u003d{() \u003d\u003e phase \u003d\u003d\u003d 1 \u0026\u0026 !isSpeaking \u0026\u0026 playWelcomeSpeech()}\\n              className\u003d{`w-32 h-32 rounded-3xl flex items-center justify-center shadow-[0_0_50px_rgba(6,182,212,0.4)] relative z-10 transition-all duration-1000 cursor-pointer ${phase \u003e\u003d 2 ? \u0027bg-white dark:bg-slate-900 rotate-[360deg]\u0027 : \u0027bg-cyan-600 rotate-0\u0027} ${isSpeaking ? \u0027animate-pulse\u0027 : \u0027\u0027}`}\\n            \u003e\\n                {isSpeaking ? (\\n                  \u003cVolume2 className\u003d\\\"w-16 h-16 text-white dark:text-cyan-400\\\" /\u003e\\n                ) : (\\n                  \u003cGraduationCap className\u003d{`w-16 h-16 ${phase \u003e\u003d 2 ? \u0027text-cyan-500\u0027 : \u0027text-white\u0027}`} /\u003e\\n                )}\\n            \u003c/div\u003e\\n            \\n            {phase \u003e\u003d 1 \u0026\u0026 [BookOpen, Lightbulb, Globe].map((Icon, i) \u003d\u003e (\\n                \u003cdiv \\n                    key\u003d{i}\\n                    className\u003d\\\"absolute top-1/2 left-1/2 transition-all duration-1000\\\"\\n                    style\u003d{{\\n                        transform: phase \u003e\u003d 2 \\n                            ? `translate(calc(-50% + ${Math.cos(i * 120 * Math.PI / 180) * 120}px), calc(-50% + ${Math.sin(i * 120 * Math.PI / 180) * 120}px)) scale(1)` \\n                            : \u0027translate(-50%, -50%) scale(0)\u0027,\\n                        opacity: phase \u003e\u003d 2 ? 1 : 0\\n                    }}\\n                \u003e\\n                    \u003cdiv className\u003d\\\"p-3 bg-slate-900 border border-cyan-500/30 rounded-full text-cyan-400 shadow-xl\\\"\u003e\\n                        \u003cIcon className\u003d\\\"w-6 h-6\\\" /\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n            ))}\\n        \u003c/div\u003e\\n      \u003c/div\u003e\\n\\n      \u003cdiv className\u003d{`absolute bottom-20 flex flex-col items-center transition-all duration-1000 px-6 ${phase \u003d\u003d\u003d 3 ? \u0027opacity-100 translate-y-0\u0027 : \u0027opacity-0 translate-y-10\u0027}`}\u003e\\n         \u003ch1 className\u003d\\\"text-4xl md:text-5xl font-bold text-white mb-2 tracking-tighter text-center\\\"\u003e\\n            The Future of \u003cspan className\u003d\\\"text-cyan-400\\\"\u003eLearning\u003c/span\u003e\\n         \u003c/h1\u003e\\n         \u003cp className\u003d\\\"text-slate-400 text-[10px] uppercase tracking-[0.4em] mb-10 text-center\\\"\u003eA personalized AI experience beyond boundaries\u003c/p\u003e\\n         \\n         \u003cbutton \\n            onClick\u003d{onComplete}\\n            className\u003d\\\"group relative px-10 py-4 overflow-hidden rounded-full transition-all hover:scale-105\\\"\\n         \u003e\\n            \u003cdiv className\u003d\\\"absolute inset-0 bg-cyan-600 group-hover:bg-cyan-50 transition-colors\\\"\u003e\u003c/div\u003e\\n            \u003cdiv className\u003d\\\"relative flex items-center gap-3\\\"\u003e\\n                \u003cspan className\u003d\\\"text-white font-bold tracking-[0