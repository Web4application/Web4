rately. I\u0027ve also focused on user experience for these web search results.\\n\\n\\n\",\"cMarkNode\":{}},\"createdTimestamp\":{\"seconds\":1767865363,\"nanos\":899000000},\"doneTimestamp\":{\"seconds\":1767865423,\"nanos\":397000000}},{\"id\":188,\"author\":\"model\",\"payload\":{\"type\":\"generationTable\",\"entries\":[{\"path\":\"App.tsx\",\"generationType\":2,\"isDone\":true,\"description\":\"Import missing ScrollText icon from lucide-react to fix the reference error in the subjects list.\",\"diffs\":[{\"target\":\"\",\"replacement\":\"\\n/**\\n * @license\\n * SPDX-License-Identifier: Apache-2.0\\n*/\\nimport React, { useState, useEffect } from \u0027react\u0027;\\nimport { GeneratedImage, ComplexityLevel, VisualStyle, Language, SearchResultItem, SubjectArea } from \u0027./types\u0027;\\nimport { \\n  researchTopicForPrompt, \\n  generateInfographicImage, \\n  editInfographicImage,\\n} from \u0027./services/geminiService\u0027;\\nimport Infographic from \u0027./components/Infographic\u0027;\\nimport Loading from \u0027./components/Loading\u0027;\\nimport IntroScreen from \u0027./components/IntroScreen\u0027;\\nimport SearchResults from \u0027./components/SearchResults\u0027;\\n// Added ScrollText to the lucide-react import list\\nimport { Search, AlertCircle, History, GraduationCap, Palette, Microscope, Atom, Compass, Globe, Sun, Moon, Key, CreditCard, ExternalLink, DollarSign, BookOpen, FlaskConical, Languages, Calculator, LandPlot, Zap, ScrollText } from \u0027lucide-react\u0027;\\n\\nconst App: React.FC \u003d () \u003d\u003e {\\n  const [showIntro, setShowIntro] \u003d useState(true);\\n  const [topic, setTopic] \u003d useState(\u0027\u0027);\\n  const [complexityLevel, setComplexityLevel] \u003d useState\u003cComplexityLevel\u003e(\u0027High School\u0027);\\n  const [visualStyle, setVisualStyle] \u003d useState\u003cVisualStyle\u003e(\u0027Default\u0027);\\n  const [language, setLanguage] \u003d useState\u003cLanguage\u003e(\u0027English\u0027);\\n  const [subject, setSubject] \u003d useState\u003cSubjectArea\u003e(\u0027STEM\u0027);\\n  \\n  const [isLoading, setIsLoading] \u003d useState(false);\\n  const [loadingMessage, setLoadingMessage] \u003d useState(\u0027\u0027);\\n  const [loadingStep, setLoadingStep] \u003d useState\u003cnumber\u003e(0);\\n  const [loadingFacts, setLoadingFacts] \u003d useState\u003cstring[]\u003e([]);\\n  const [error, setError] \u003d useState\u003cstring | null\u003e(null);\\n  \\n  const [imageHistory, setImageHistory] \u003d useState\u003cGeneratedImage[]\u003e([]);\\n  const [currentSearchResults, setCurrentSearchResults] \u003d useState\u003cSearchResultItem[]\u003e([]);\\n  const [isDarkMode, setIsDarkMode] \u003d useState(true);\\n\\n  // API Key State\\n  const [hasApiKey, setHasApiKey] \u003d useState(false);\\n  const [checkingKey, setCheckingKey] \u003d useState(true);\\n\\n  useEffect(() \u003d\u003e {\\n    if (isDarkMode) {\\n      document.documentElement.classList.add(\u0027dark\u0027);\\n    } else {\\n      document.documentElement.classList.remove(\u0027dark\u0027);\\n    }\\n  }, [isDarkMode]);\\n\\n  useEffect(() \u003d\u003e {\\n    const checkKey \u003d async () \u003d\u003e {\\n      try {\\n        if (window.aistudio \u0026\u0026 window.aistudio.hasSelectedApiKey) {\\n          const hasKey \u003d await window.aistudio.hasSelectedApiKey();\\n          setHasApiKey(hasKey);\\n        } else {\\n          setHasApiKey(true);\\n        }\\n      } catch (e) {\\n        console.error(\\\"Error checking API key:\\\", e);\\n      } finally {\\n        setCheckingKey(false);\\n      }\\n    };\\n    checkKey();\\n  }, []);\\n\\n  const handleSelectKey \u003d async () \u003d\u003e {\\n    if (window.aistudio \u0026\u0026 window.aistudio.openSelectKey) {\\n      try {\\n        await window.aistudio.openSelectKey();\\n        setHasApiKey(true);\\n        setError(null);\\n      } catch (e) {\\n        console.error(\\\"Failed to open key selector:\\\", e);\\n      }\\n    }\\n  };\\n\\n  const handleGenerate \u003d async (e: React.FormEvent) \u003d\u003e {\\n    e.preventDefault();\\n    if (isLoading) return;\\n\\n    if (!topic.trim()) {\\n        setError(\\\"Please specify a lesson topic.\\\");\\n        return;\\n    }\\n\\n    setIsLoading(true);\\n    setError(null);\\n    setLoadingStep(1);\\n    setLoadingFacts([]);\\n    setCurrentSearchResults([]);\\n    setLoadingMessage(`Consulting Department: ${subject}...`);\\n\\n    try {\\n      const researchResult \u003d await researchTopicForPrompt(topic, complexityLevel, visualStyle, language, subject);\\n      \\n      setLoadingFacts(researchResult.facts);\\n      setCurrentSearchResults(researchResult.searchResults);\\n      \\n      setLoadingStep(2);\\n      setLoadingMessage(`Rendering Educational Visual...`);\\n      \\n      let base64Data \u003d await generateInfographicImage(researchResult.imagePrompt);\\n      \\n      const newImage: GeneratedImage \u003d {\\n        id: Date.now().toString(),\\n        data: base64Data,\\n        prompt: topic,\\n        timestamp: Date.now(),\\n        level: complexityLevel,\\n        style: visualStyle,\\n        language: language,\\n        subject: subject\\n      };\\n\\n      setImageHistory([newImage, ...imageHistory]);\\n    } catch (err: any) {\\n      console.error(err);\\n      if (err.message \u0026\u0026 (err.message.includes(\\\"Requested entity was not found\\\") || err.message.includes(\\\"404\\\") || err.message.includes(\\\"403\\\"))) {\\n          setError(\\\"Session expired or billing required. Please re-select your academy access key.\\\");\\n          setHasApiKey(false);\\n      } else {\\n          setError(\u0027The academy systems are temporarily offline. Please try again.\u0027);\\n      }\\n    } finally {\\n      setIsLoading(false);\\n      setLoadingStep(0);\\n    }\\n  };\\n\\n  const handleEdit \u003d async (editPrompt: string) \u003d\u003e {\\n    if (imageHistory.length \u003d\u003d\u003d 0) return;\\n    const currentImage \u003d imageHistory[0];\\n    setIsLoading(true);\\n    setError(null);\\n    setLoadingStep(2);\\n    setLoadingMessage(`Applying Correction: \\\"${editPrompt}\\\"...`);\\n\\n    try {\\n      const base64Data \u003d await editInfographicImage(currentImage.data, editPrompt);\\n      const newImage: GeneratedImage \u003d {\\n        id: Date.now().toString(),\\n        data: base64Data,\\n        prompt: editPrompt,\\n        timestamp: Date.now(),\\n        level: currentImage.level,\\n        style: currentImage.style,\\n        language: currentImage.language,\\n        subject: currentImage.subject\\n      };\\n      setImageHistory([newImage, ...imageHistory]);\\n    } catch (err: any) {\\n      console.error(err);\\n      setError(\u0027Visual modification failed. Please try a simpler correction.\u0027);\\n    } finally {\\n      setIsLoading(false);\\n      setLoadingStep(0);\\n    }\\n  };\\n\\n  const restoreImage \u003d (img: GeneratedImage) \u003d\u003e {\\n     const newHistory \u003d imageHistory.filter(i \u003d\u003e i.id !\u003d\u003d img.id);\\n     setImageHistory([img, ...newHistory]);\\n  };\\n\\n  const subjects: {id: SubjectArea, icon: any, label: string, color: string}[] \u003d [\\n    {id: \u0027STEM\u0027, icon: FlaskConical, label: \u0027STEM\u0027, color: \u0027text-cyan-500\u0027},\\n    {id: \u0027History\u0027, icon: ScrollText, label: \u0027History\u0027, color: \u0027text-amber-600\u0027},\\n    {id: \u0027Biology\u0027, icon: Microscope, label: \u0027Biology\u0027, color: \u0027text-emerald-500\u0027},\\n    {id: \u0027Physics\u0027, icon: Zap, label: \u0027Physics\u0027, color: \u0027text-indigo-500\u0027},\\n    {id: \u0027Geography\u0027, icon: LandPlot, label: \u0027Geography\u0027, color: \u0027text-sky-500\u0027},\\n    {id: \u0027Engineering\u0027, icon: Calculator, label: \u0027Engineering\u0027, color: \u0027text-slate-500\u0027},\\n  ];\\n\\n  return (\\n    \u003c\u003e\\n    {!checkingKey \u0026\u0026 !hasApiKey \u0026\u0026 (\\n        \u003cdiv className\u003d\\\"fixed inset-0 z-[200] bg-slate-950/90 backdrop-blur-md flex items-center justify-center p-4\\\"\u003e\\n            \u003cdiv className\u003d\\\"bg-white dark:bg-slate-900 border-2 border-cyan-500/50 rounded-2xl shadow-2xl max-w-md w-full p-8 text-center space-y-6\\\"\u003e\\n                \u003cGraduationCap className\u003d\\\"w-16 h-16 mx-auto text-cyan-500\\\" /\u003e\\n                \u003ch2 className\u003d\\\"text-2xl font-display font-bold text-slate-900 dark:text-white\\\"\u003eAcademy Admission\u003c/h2\u003e\\n                \u003cp className\u003d\\\"text-slate-600 dark:text-slate-400\\\"\u003ePlease provide a valid Billing-Enabled API key to access our visual learning resources.\u003c/p\u003e\\n                \u003cbutton onClick\u003d{handleSelectKey} className\u003d\\\"w-full py-4 bg-cyan-600 text-white rounded-xl font-bold shadow-lg hover:bg-cyan-500 transition-all flex items-center justify-center gap-2\\\"\u003e\\n                    \u003cKey className\u003d\\\"w-4 h-4\\\" /\u003e Initialize Academy Access\\n                \u003c/button\u003e\\n                \u003ca href\u003d\\\"https://ai.google.dev/gemini-api/docs/billing\\\" target\u003d\\\"_blank\\\" className\u003d\\\"text-xs text-cyan-600 hover:underline\\\"\u003eBilling Documentation\u003c/a\u003e\\n            \u003c/div\u003e\\n        \u003c/div\u003e\\n    )}\\n\\n    {showIntro ? (\\n      \u003cIntroScreen onComplete\u003d{() \u003d\u003e setShowIntro(false)} /\u003e\\n    ) : (\\n    \u003cdiv className\u003d\\\"min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 font-sans selection:bg-cyan-500 pb-20 transition-colors\\\"\u003e\\n      \u003cdiv className\u003d\\\"fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-50 via-slate-50 to-white dark:from-slate-900/40 dark:via-slate-950 dark:to-black z-0\\\"\u003e\u003c/div\u003e\\n\\n      